---
import Layout from '@/layouts/Layout.astro';
import { allProjects } from '@/data/projects/index';

// Components
import Redesigned_Hero from '@/components/portfolio/redesign/PortfolioHero.astro';
import Redesigned_Problems from '@/components/portfolio/redesign/PortfolioProblems.astro';
import Redesigned_Strategy from '@/components/portfolio/redesign/PortfolioStrategy.astro';
import Redesigned_Execution from '@/components/portfolio/redesign/PortfolioExecution.astro';
import Redesigned_Results from '@/components/portfolio/redesign/PortfolioResults.astro';
import Redesigned_Thumbnail from '@/components/portfolio/redesign/PortfolioThumbnail.astro';

export async function getStaticPaths() {
  return allProjects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={project.hero.title}>
  <Redesigned_Hero {...project.hero} />
  
  <Redesigned_Problems {...project.problems} /> 
  
  <Redesigned_Strategy {...project.strategy} />
  
  <Redesigned_Execution {...project.execution} />
  
  <Redesigned_Results {...project.results} /> 
  
  <Redesigned_Thumbnail {...project.thumbnail} />
</Layout>