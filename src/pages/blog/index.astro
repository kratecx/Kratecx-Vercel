---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import heroVideo from '@/assets/home/video_2.mp4';

const posts = (await getCollection('blog', ({ data }) => !data.draft && !data.noIndex))
  .sort((a, b) => +b.data.publishedAt - +a.data.publishedAt);

const formatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

/** Resolve a post's hero image to a plain URL string (or undefined). */
function imageUrl(img: unknown): string | undefined {
  if (!img) return undefined;
  if (typeof img === 'string') return img;
  if (typeof img === 'object' && img !== null && 'src' in img) {
    return (img as { src: string }).src;
  }
  return undefined;
}
---

<Layout>
  {/* ─────────── HERO with background video ─────────── */}
  <section
    id="blog-hero"
    class="relative flex min-h-[72vh] w-full flex-col items-center justify-center overflow-hidden bg-black px-4 pt-32 pb-16 sm:pt-36 sm:pb-20"
  >
    {/* Background video */}
    <div class="absolute inset-0 z-0 overflow-hidden">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        class="h-full w-full object-cover opacity-40"
        aria-hidden="true"
      >
        <source src={heroVideo} type="video/mp4" />
      </video>
      {/* Cinematic vignette + orange glow to match the rest of the site */}
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/60 to-black"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(249,115,22,0.12),transparent_55%)]"></div>
    </div>

    {/* Hero content */}
    <div class="relative z-10 mx-auto max-w-4xl text-center" data-anim="reveal">
      <div class="mb-6 inline-flex items-center gap-3">
        <span class="h-px w-10 bg-orange-400/60"></span>
        <p class="font-mono text-[11px] uppercase tracking-[0.45em] text-orange-400">
          The Kratecx Journal
        </p>
        <span class="h-px w-10 bg-orange-400/60"></span>
      </div>

      <h1 class="text-5xl font-semibold tracking-tighter leading-[0.95] text-white sm:text-6xl md:text-7xl lg:text-[80px]">
        Notes on web,
        <span class="text-orange-400"> performance</span>
        <br class="hidden sm:block" />
        &amp; product.
      </h1>

      <p class="mx-auto mt-7 max-w-2xl text-base font-light leading-relaxed text-zinc-300 sm:text-lg">
        Short essays on the tools, process, and engineering decisions behind
        fast websites, Shopify stores, and SaaS products.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3 text-[11px] text-zinc-500">
        <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 uppercase tracking-[0.25em]">
          {posts.length} posts
        </span>
        <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 uppercase tracking-[0.25em]">
          Updated weekly
        </span>
      </div>
    </div>

    {/* Subtle downward arrow to imply scroll */}
    <div class="absolute bottom-6 left-1/2 z-10 -translate-x-1/2 text-zinc-500">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7-7-7M19 5l-7 7-7-7" />
      </svg>
    </div>
  </section>

  {/* ─────────── Posts grid ─────────── */}
  <section class="relative bg-[#050505] py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
        <h2 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">
          Latest writing
        </h2>
        <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-zinc-500">
          All categories
        </p>
      </div>

      {posts.length === 0 ? (
        <p class="text-center text-zinc-500">No posts yet. Check back soon.</p>
      ) : (
        <ul
          class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4"
          data-stagger="90"
        >
          {posts.map((post) => {
            const thumb = imageUrl(post.data.image);
            return (
              <li class="h-full">
                <a
                  href={`/blog/${post.slug}`}
                  class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.02] transition-all duration-500 hover:border-orange-400/40 hover:bg-white/[0.04] hover:-translate-y-1"
                >
                  {/* Thumbnail */}
                  <div class="relative aspect-[16/10] w-full overflow-hidden bg-black">
                    {thumb ? (
                      <img
                        src={thumb}
                        alt={post.data.imageAlt ?? post.data.title}
                        width="640"
                        height="400"
                        loading="lazy"
                        decoding="async"
                        class="h-full w-full object-cover opacity-80 transition-all duration-700 group-hover:scale-105 group-hover:opacity-100"
                      />
                    ) : (
                      <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-orange-500/20 to-transparent">
                        <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-orange-400/70">
                          {post.data.category}
                        </span>
                      </div>
                    )}
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/30 to-transparent"></div>
                    <span class="absolute left-4 top-4 rounded-full border border-orange-400/30 bg-orange-400/10 px-2.5 py-1 font-mono text-[9px] uppercase tracking-[0.3em] text-orange-300 backdrop-blur-sm">
                      {post.data.category}
                    </span>
                  </div>

                  {/* Body */}
                  <div class="flex flex-1 flex-col gap-3 p-5 sm:p-6">
                    <h3 class="text-lg font-medium leading-snug text-white transition-colors group-hover:text-orange-400 sm:text-xl">
                      {post.data.title}
                    </h3>
                    <p class="line-clamp-3 text-sm font-light leading-relaxed text-zinc-400">
                      {post.data.description}
                    </p>

                    <div class="mt-auto flex items-center justify-between pt-4">
                      <time
                        datetime={post.data.publishedAt.toISOString()}
                        class="font-mono text-[10px] uppercase tracking-[0.2em] text-zinc-500"
                      >
                        {formatter.format(post.data.publishedAt)}
                      </time>
                      <span class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-[0.2em] text-orange-400 opacity-0 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0.5">
                        Read
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                        </svg>
                      </span>
                    </div>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>
</Layout>
