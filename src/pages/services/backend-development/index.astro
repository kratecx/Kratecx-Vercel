---
import Layout from "@/layouts/Layout.astro";
import { backendDevelopmentPage } from "@/data/service";

import ServiceHero from "@/components/services/ServiceHero.astro";
import ServiceWhatIsIncluded from "@/components/services/ServiceWhatIsIncluded.astro";
import ServiceDeliverables from "@/components/services/ServiceDeliverables.astro";
import ServiceCaseStudies from "@/components/services/ServiceCaseStudies.astro";
import ServiceFAQs from "@/components/services/mainpage/ServiceFAQ.astro";

const p = backendDevelopmentPage;
---

<Layout title={p.layoutTitle}>
  <ServiceHero {...p.hero} mainImage={p.heroImage} />

  <ServiceWhatIsIncluded items={[...p.features]} />

  <ServiceDeliverables deliverables={[...p.deliverables]} mainImage={p.heroImage} />

  <ServiceCaseStudies
    title={p.sectionTitles.caseStudiesTitle}
    titleAccent={p.sectionTitles.caseStudiesTitleAccent}
    projects={[...p.caseStudies]}
  />

  <ServiceFAQs
    faqs={[...p.faqs]}
    title={p.sectionTitles.faqTitle}
    titleAccent={p.sectionTitles.faqTitleAccent}
  />
</Layout>
