---
import Layout from '../../layouts/Layout.astro';

import ServiceHeroBanner from '@/components/services/mainpage/ServiceHeroBanner.astro';
import ServicesCards from '@/components/services/mainpage/ServicesCards.astro';
import ServiceFAQ from '@/components/services/mainpage/ServiceFAQ.astro';
import ProcessTimeline from '@/components/process/ProcessTimeline.astro';
import ProcessDeliverables from '@/components/process/ProcessDeliverables.astro';
import Testimonials from '@/components/home/Testimonials.astro';
import ProcessCTA from '@/components/process/ProcessCTA.astro';

import { SITE, resolveSeo } from '@/data/seo';
import { serviceSchema } from '@/data/schema';

const seo = resolveSeo('/services');
const pageUrl = new URL('/services', SITE.domain).href;

const schemas = [
  serviceSchema({
    name: 'Web Development Services',
    description: seo.description,
    url: pageUrl,
    serviceType: 'Web Development',
  }),
];
---

<Layout extraSchemas={schemas}>
  <ServiceHeroBanner />
  <ServicesCards />
  <ProcessTimeline />
  <ProcessDeliverables />
  <ServiceFAQ />
  <Testimonials />
  <ProcessCTA />
</Layout>
