---
// PremiumDynamicNavbar.astro
import { Image } from "astro:assets";
// import logo from "@/assets/about/kratecs_image5.svg";
import logo from "@/assets/about/kratecx_full.svg";
import { servicesCatalog } from "@/data/servicesCatalog";

const navLinks = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Portfolio", href: "/portfolio" },
  { name: "Services", href: "/services", dropdown: true },
 
  { name: "Process", href: "/process" },
  { name: "Blog", href: "/blog" },
  { name: "Faqs", href: "/faqs" },

] as const;
---

<header 
  id="nav-header" 
  class="fixed top-0 left-0 w-full z-[100] border-b border-transparent bg-transparent antialiased transition-all duration-500 ease-in-out py-3 sm:py-3.5 lg:py-2"
>
  <div class="relative z-[110] mx-auto flex max-w-7xl items-center justify-between gap-2 px-3 sm:gap-3 sm:px-5 lg:px-6">
    
    <div class="flex-1 min-w-0">
      <a href="/" class="inline-block group">
        <Image src={logo} alt="Kratecx — web development agency" width={200} height={56} class="h-9 w-auto sm:h-10" />
      </a>
    </div>

    <nav class="hidden lg:block">
      <ul class="flex items-center gap-8 lg:gap-10">
        {navLinks.map((link) => (
          <li class="relative group">
            <a
              href={link.href}
              data-nav-link
              class:list={[
                "text-white/70 text-[16px] tracking-[0.04em] hover:text-white transition-all duration-300 flex items-center gap-2 py-1.5 active-nav-text",
                "dropdown" in link && link.dropdown && "gap-1.5",
              ]}
            >
              {"dropdown" in link && link.dropdown ? (
                <>
                  <span>{link.name}</span>
                  <svg
                    class="w-2.5 h-2.5 shrink-0 opacity-40 transition-transform group-hover:rotate-180"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                  </svg>
                </>
              ) : (
                link.name
              )}
            </a>

            <span class="absolute bottom-0 left-0 w-0 h-[1px] bg-orange-400 transition-all duration-500 group-hover:w-full active-underline" />

            {"dropdown" in link && link.dropdown && (
              <div class="nav-services-dropdown pointer-events-none absolute top-full left-1/2 z-[120] -translate-x-1/2 pt-4 opacity-0 translate-y-2 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:pointer-events-auto group-hover:opacity-100 group-hover:translate-y-0">
                <div class="nav-services-dropdown-panel relative w-[min(94vw,56rem)] overflow-hidden rounded-2xl border border-white/[0.08] bg-[#0a0a0a]/95 shadow-[0_32px_80px_-20px_rgba(0,0,0,0.85)] backdrop-blur-2xl">
                  {/* subtle top accent line */}
                  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-orange-400/40 to-transparent" aria-hidden="true" />

                  {/* Header strip */}
                  <div class="flex items-center justify-between border-b border-white/[0.05] px-6 py-3">
                    <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-orange-400/80">
                      Services
                    </p>
                    <a href="/services" class="group/all inline-flex items-center gap-1.5 text-[11px] tracking-wide text-white/50 transition-colors hover:text-orange-400">
                      View all
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover/all:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                      </svg>
                    </a>
                  </div>

                  {/* Services grid */}
                  <div class="p-3 lg:p-4">
                    <div class="grid grid-cols-3 gap-1.5">
                      {servicesCatalog.map((s) => (
                        <a
                          href={s.href}
                          data-nav-link
                          class="nav-services-dropdown-link group/drop relative flex min-w-0 items-start gap-3 rounded-lg px-3 py-3 text-left transition-all duration-200 hover:bg-white/[0.04]"
                        >
                          <span
                            class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-white/[0.08] bg-white/[0.02] text-orange-400/80 transition-all duration-200 group-hover/drop:border-orange-400/35 group-hover/drop:bg-orange-400/10 group-hover/drop:text-orange-400"
                            aria-hidden="true"
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                              <path d={s.icon} />
                            </svg>
                          </span>
                          <span class="flex min-w-0 flex-col">
                            <span class="truncate text-[13px] font-medium leading-tight text-white/85 transition-colors group-hover/drop:text-white">
                              {s.title}
                            </span>
                            <span class="mt-1 line-clamp-2 text-[11px] font-normal leading-snug text-white/40 transition-colors group-hover/drop:text-white/60">
                              {s.description}
                            </span>
                          </span>
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="flex flex-1 justify-end items-center gap-2 sm:gap-3">
      <a 
        href="/contact" 
        class="hidden lg:flex group relative items-center gap-2 py-1.5"
      >
        <span class="text-[17px] font-semibold tracking-[0.05em] text-white transition-all duration-500 group-hover:text-orange-400">
          Contact 
        </span>

        {/* animated orange arrow chip */}
        <span class="relative z-10 flex h-7 w-7 items-center justify-center overflow-hidden rounded-full bg-orange-400 text-black shadow-[0_0_16px_rgba(249,133,2,0.45)]">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-3.5 w-3.5 transition-transform duration-500 ease-[cubic-bezier(0.65,0,0.35,1)] group-hover:translate-x-4 group-hover:-translate-y-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7 17L17 7" />
            <path d="M7 7h10v10" />
          </svg>
          {/* second arrow that slides in from bottom-left — creates a continuous loop feel */}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="absolute h-3.5 w-3.5 -translate-x-4 translate-y-4 transition-transform duration-500 ease-[cubic-bezier(0.65,0,0.35,1)] group-hover:translate-x-0 group-hover:translate-y-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7 17L17 7" />
            <path d="M7 7h10v10" />
          </svg>
        </span>
      </a>

      <div id="nav-mobile-root" class="relative lg:hidden">
        <button
          type="button"
          id="nav-mobile-toggle"
          class="relative z-[1] flex h-11 w-11 shrink-0 items-center justify-center rounded-sm border border-white/20 bg-black/50 text-white backdrop-blur-sm transition-colors hover:border-white/35 hover:bg-black/70"
          aria-controls="nav-mobile-panel"
          aria-expanded="false"
          aria-haspopup="true"
          aria-label="Open menu"
        >
          <span class="sr-only">Menu</span>
          <svg id="nav-mobile-icon-open" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="nav-mobile-icon-close" class="hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <div
          id="nav-mobile-panel"
          class="nav-mobile-panel absolute right-0 top-full z-[130] mt-2 w-[min(18.5rem,calc(100vw-2rem))] origin-top-right lg:hidden"
          aria-hidden="true"
        >
          <div class="border border-white/[0.12] bg-[#0a0a0a]/98 shadow-[0_24px_48px_-12px_rgba(0,0,0,0.75)] backdrop-blur-xl">
            <div class="border-b border-white/[0.08] px-3 py-2 sm:px-4">
              <p class="font-mono text-[10px] font-bold tracking-[0.05em] text-white/35">Navigation</p>
            </div>
            <nav class="flex max-h-[min(70vh,22rem)] flex-col overflow-y-auto py-1" aria-label="Mobile">
              {navLinks.map((link) =>
                "dropdown" in link && link.dropdown ? (
                  <div class="border-b border-white/[0.06] last:border-b-0">
                    <a
                      href={link.href}
                      data-nav-link
                      data-mobile-nav-link
                      class="block border-b border-white/[0.05] px-3 py-3 text-[13px] font-medium tracking-[0.04em] text-white/65 transition-colors hover:bg-white/[0.04] hover:text-white active-nav-text sm:px-4"
                    >
                      {link.name}
                    </a>
                    <details class="group border-b-0">
                      <summary class="flex cursor-pointer list-none items-center justify-between gap-2 px-3 py-2.5 text-[10px] font-medium tracking-[0.04em] text-white/45 outline-none marker:content-none [&::-webkit-details-marker]:hidden hover:bg-white/[0.04] hover:text-white/80 sm:px-4 sm:py-3">
                        <span>Browse by service</span>
                        <svg class="nav-mobile-chevron h-3 w-3 shrink-0 text-white/35 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                        </svg>
                      </summary>
                      <div class="max-h-[min(50vh,16rem)] overflow-y-auto border-t border-white/[0.05] bg-black/40 px-2 py-2 sm:px-3">
                        {servicesCatalog.map((s) => (
                          <a
                            href={s.href}
                            data-nav-link
                            data-mobile-nav-link
                            class="group/mdrop flex items-center gap-3 rounded-md px-2 py-2.5 text-left transition-colors hover:bg-white/[0.04]"
                          >
                            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded border border-white/[0.08] bg-white/[0.02] text-orange-400/80 transition-colors group-hover/mdrop:border-orange-400/35 group-hover/mdrop:text-orange-400" aria-hidden="true">
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                <path d={s.icon} />
                              </svg>
                            </span>
                            <span class="truncate text-[13px] font-medium text-white/75 transition-colors group-hover/mdrop:text-white">
                              {s.title}
                            </span>
                          </a>
                        ))}
                      </div>
                    </details>
                  </div>
                ) : (
                  <a
                    href={link.href}
                    data-nav-link
                    data-mobile-nav-link
                    class="border-b border-white/[0.06] px-3 py-3 text-[13px] font-medium tracking-[0.04em] text-white/65 transition-colors hover:bg-white/[0.04] hover:text-white active-nav-text last:border-b-0 sm:px-4"
                  >
                    {link.name}
                  </a>
                )
              )}
              <div class="border-t border-white/[0.08] px-3 py-2.5 sm:px-4 sm:py-3">
                <a
                  href="/contact"
                  data-mobile-nav-link
                  class="block text-center text-[12px] font-bold tracking-[0.05em] text-orange-400/90 transition-colors hover:text-orange-400"
                >
                  Contact
                </a>
              </div>
            </nav>
          </div>
        </div>
      </div>
    </div>

  </div>
</header>

<script>
  function initNav() {
    const header = document.getElementById('nav-header');
    const links = document.querySelectorAll('[data-nav-link]');
    const currentPath = window.location.pathname;

    // 1. Scroll Logic
    const onHeaderScroll = () => {
      if (window.scrollY > 40) {
        header?.classList.add(
          'border-white/10',
          'bg-black',
          'shadow-lg',
          'py-2',
          'sm:py-2.5',
          'lg:py-1.5'
        );
        header?.classList.remove('border-transparent', 'bg-transparent', 'py-3', 'sm:py-3.5', 'lg:py-2');
      } else {
        header?.classList.remove(
          'border-white/10',
          'bg-black',
          'shadow-lg',
          'py-2',
          'sm:py-2.5',
          'lg:py-1.5'
        );
        header?.classList.add('border-transparent', 'bg-transparent', 'py-3', 'sm:py-3.5', 'lg:py-2');
      }
    };
    window.addEventListener('scroll', onHeaderScroll);
    onHeaderScroll();

    // 2. Active Page Logic
    links.forEach(link => {
      const href = link.getAttribute('href');
      // Matches exact path or sub-paths for a "serious" persistent feel
      if (href && (currentPath === href || (href !== '/' && currentPath.startsWith(href)))) {
        link.classList.add('text-white');
        link.classList.remove('text-white/70');
        // Find the specific underline span for this link
        const underline = link.nextElementSibling;
        if (underline && underline.classList.contains('active-underline')) {
          underline.classList.remove('w-0');
          underline.classList.add('w-full');
        }
      }
    });
  }

  function closeMobileNav() {
    const panel = document.getElementById('nav-mobile-panel');
    const toggle = document.getElementById('nav-mobile-toggle');
    const iconOpen = document.getElementById('nav-mobile-icon-open');
    const iconClose = document.getElementById('nav-mobile-icon-close');
    if (!panel || !toggle) return;
    panel.classList.remove('nav-mobile-panel--open');
    panel.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open menu');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  }

  function initMobileMenu() {
    const root = document.getElementById('nav-mobile-root');
    const toggle = document.getElementById('nav-mobile-toggle');
    const panel = document.getElementById('nav-mobile-panel');
    const iconOpen = document.getElementById('nav-mobile-icon-open');
    const iconClose = document.getElementById('nav-mobile-icon-close');
    if (!toggle || !panel || !root) return;
    if (toggle.dataset.ready === '1') return;
    toggle.dataset.ready = '1';

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const shouldOpen = !panel.classList.contains('nav-mobile-panel--open');
      if (!shouldOpen) {
        closeMobileNav();
        return;
      }
      panel.classList.add('nav-mobile-panel--open');
      panel.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close menu');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
    });

    panel.querySelectorAll('[data-mobile-nav-link]').forEach((el) => {
      el.addEventListener('click', () => closeMobileNav());
    });

    if (document.documentElement.dataset.navMobileGlobals !== '1') {
      document.documentElement.dataset.navMobileGlobals = '1';
      document.addEventListener('click', (e) => {
        if (!panel.classList.contains('nav-mobile-panel--open')) return;
        const t = e.target;
        if (t instanceof Node && !root.contains(t)) closeMobileNav();
      });
      window.addEventListener('resize', () => {
        if (window.matchMedia('(min-width: 1024px)').matches) closeMobileNav();
      });
      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMobileNav();
      });
    }
  }

  // Runs on initial load
  initNav();
  initMobileMenu();
  // Runs after Astro view transitions (if you use them)
  document.addEventListener('astro:after-swap', () => {
    initNav();
    initMobileMenu();
  });
</script>

<style>
  header {
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-mobile-panel {
    pointer-events: none;
    visibility: hidden;
    opacity: 0;
    transform: translateY(-0.35rem) scale(0.985);
    transition:
      opacity 0.18s ease-out,
      transform 0.22s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0.18s ease-out;
  }

  .nav-mobile-panel.nav-mobile-panel--open {
    pointer-events: auto;
    visibility: visible;
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  details[open] .nav-mobile-chevron {
    transform: rotate(180deg);
  }

</style>