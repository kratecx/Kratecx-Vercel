---
/**
 * Collaboration_Protocols_White.astro
 * Style: Simple Tabular / Technical Light
 * Theme: White Base | Orange-400 & Slate-900
 */
import { Users, Eye, MessageSquare, Award } from 'lucide-react';

const protocols = [
  {
    phase: "01. Project Alignment",
    task: "Approve goals, scope, and project direction",
    icon: Users,
    status: "Required"
  },
  {
    phase: "02. Design Approval",
    task: "Review and confirm website design direction",
    icon: Eye,
    status: "Required"
  },
  {
    phase: "03. Progress Feedback",
    task: "Share feedback during development updates",
    icon: MessageSquare,
    status: "Ongoing"
  },
  {
    phase: "04. Project Completion",
    task: "Final review and approval before handover",
    icon: Award,
    status: "Final"
  }
];
---

<section class="w-full scroll-mt-24 bg-white px-4 py-16 font-sans antialiased text-slate-900 sm:scroll-mt-28 sm:px-6 sm:py-20 md:py-24 lg:py-28" id="requirements">
  <div class="mx-auto max-w-4xl" data-reveal>
    <div class="relative z-10 mx-auto mb-14 max-w-7xl text-center sm:mb-20 md:mb-24">
      <div class="mb-6 flex items-center justify-center gap-2 sm:mb-8 sm:gap-4">
        <span class="h-0.5 w-8 bg-orange-400 sm:w-10"></span>
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.3em] text-orange-400 sm:text-sm sm:tracking-[0.45em] md:text-sm md:tracking-[0.5em]">
          Collaboration Flow
        </p>
        <span class="h-0.5 w-8 bg-orange-400 sm:w-10"></span>
      </div>

      <div class="flex flex-col items-center justify-center px-1">
        <h2 class="text-balance text-4xl font-[900] uppercase leading-[0.88] tracking-tighter text-black sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl">
          <span class="text-orange-400">Client</span>
          <span class="text-black"> Involvement</span>
        </h2>
        <div class="my-5 h-1 w-44 rounded-full bg-orange-400 opacity-50 sm:my-6 sm:w-60 md:w-72"></div>
        <p class="mx-auto max-w-2xl text-base font-light leading-relaxed text-gray-500 sm:text-lg md:text-xl">
          Clear checkpoints that keep you involved at key stages while ensuring smooth progress and complete transparency.
        </p>
      </div>
    </div>

    <div class="divide-y divide-slate-200 overflow-hidden rounded-sm border border-slate-200 shadow-sm">
      <div class="hidden bg-slate-50 text-[10px] font-inter uppercase tracking-[0.2em] text-black md:flex">
        <div class="w-1/3 border-r border-slate-200 py-3 pl-4 pr-2 font-extrabold sm:px-6 md:px-8 md:py-4">Project Phase</div>
        <div class="w-1/3 border-r border-slate-200 py-3 px-2 font-extrabold sm:px-6 md:px-8 md:py-4">Client Input</div>
        <div class="w-1/3 py-3 pl-2 pr-4 text-right font-extrabold sm:px-6 md:px-8 md:py-4">Status</div>
      </div>

      {protocols.map((item) => (
        <div class="group flex flex-col transition-all duration-300 hover:bg-orange-50/50 md:flex-row md:items-center">
          <div class="flex w-full items-center gap-3 border-b border-slate-100 px-4 py-5 sm:gap-4 sm:px-6 md:w-1/3 md:border-b-0 md:border-r md:py-6 md:pl-4 md:pr-2 lg:px-8">
            <div class="shrink-0 rounded-sm border border-slate-200 bg-slate-50 p-2 transition-colors group-hover:border-orange-400/40">
              <item.icon size={16} className="text-slate-400 transition-colors group-hover:text-orange-400" />
            </div>
            <span class="min-w-0 text-left text-xs font-bold uppercase tracking-tight text-slate-900/90 sm:text-sm">{item.phase}</span>
          </div>

          <div class="w-full border-b border-slate-100 px-4 py-4 sm:px-6 md:w-1/3 md:border-b-0 md:border-r md:py-6 md:px-4 lg:px-8">
            <p class="mb-1 font-mono text-[9px] uppercase tracking-widest text-orange-500 md:hidden">Client Input</p>
            <span class="text-xs font-medium uppercase tracking-wider text-slate-500 transition-colors group-hover:text-slate-700 sm:text-[13px]">
              {item.task}
            </span>
          </div>

          <div class="flex w-full items-center justify-between bg-slate-50/30 px-4 py-4 transition-colors group-hover:bg-transparent sm:px-6 md:w-1/3 md:justify-end md:bg-transparent md:py-6 md:pl-2 md:pr-4 lg:px-8">
            <p class="font-mono text-[9px] uppercase tracking-widest text-orange-500 md:hidden">Status</p>
            <span class="font-poppins text-sm uppercase tracking-wide text-orange-400 sm:text-[14px]">{item.status}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="flex flex-col items-center justify-center gap-6 border-t border-slate-200 pt-8 sm:gap-10 sm:pt-10 md:pt-12">
      <div class="group relative mt-4 inline-block max-w-full overflow-hidden rounded-full bg-gradient-to-r from-slate-200/80 via-orange-400/60 to-slate-200/80 p-1 shadow-2xl shadow-orange-400/10 sm:mt-6 md:mt-8">
        <div class="absolute -inset-4 bg-orange-400/20 opacity-0 blur-3xl transition-opacity duration-700 group-hover:opacity-100"></div>

        <a
          href="/contact"
          class="relative flex w-full max-w-lg items-center gap-4 rounded-full bg-[#080808] py-2.5 pl-2.5 pr-4 transition-all duration-500 hover:bg-black sm:w-auto sm:max-w-none sm:gap-8 sm:py-3 sm:pl-3 sm:pr-8 md:gap-10"
        >
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-orange-400 text-black shadow-[0_0_30px_rgba(251,133,0,0.4)] transition-transform duration-1000 ease-in-out group-hover:rotate-[360deg] sm:h-14 sm:w-14 md:h-16 md:w-16">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
            </svg>
          </div>

          <div class="min-w-0 flex flex-col text-left">
            <p class="mb-1 text-[9px] font-black uppercase leading-none tracking-[0.35em] text-orange-400 sm:mb-2 sm:tracking-[.4em]">Want to Move Forward?</p>
            <span class="text-base font-black uppercase tracking-tight text-white transition-colors group-hover:text-orange-400 sm:text-lg md:text-xl">
              Let’s discuss your goals.
            </span>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    -webkit-font-smoothing: antialiased;
  }
</style>