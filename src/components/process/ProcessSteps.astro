---
import { Search, Lightbulb, Layout, Rocket, LineChart } from 'lucide-react';

const steps = [
  { 
    id: "01", 
    phase: "Discovery", 
    status: "Website Audit",
    status2: "Goals Defined",
    outcome: "We analyze your current website, identify gaps, and define clear goals focused on improving trust, engagement, and lead generation.",
    icon: Search
  },
  { 
    id: "02", 
    phase: "Strategy", 
    status: "Plan Structured",
    status2: "Conversion Focused",
    outcome: "We create a clear structure and strategy for your website, focusing on user flow, messaging, and conversion optimization.",
    icon: Lightbulb
  },
  { 
    id: "03", 
    phase: "Design & Development", 
    status: "Build in Progress",
    status2: "User-Focused",
    outcome: "We design and develop your website with a focus on clarity, performance, and a seamless user experience across all devices.",
    icon: Layout
  },
  { 
    id: "04", 
    phase: "Launch", 
    status: "Website Live",
    status2: "Performance Optimized",
    outcome: "Your website is launched with optimized speed, responsiveness, and on-page SEO for better visibility and performance.",
    icon: Rocket
  },
  { 
    id: "05", 
    phase: "Growth", 
    status: "Performance Tracked",
    status2: "Ongoing Improvements",
    outcome: "We monitor performance and provide ongoing improvements to increase conversions, user engagement, and business growth.",
    icon: LineChart
  }
];
---

<section id="steps" class="relative scroll-mt-24 overflow-hidden bg-[#FCFCFC] px-4 py-16 font-sans antialiased text-black sm:scroll-mt-28 sm:px-6 sm:py-24 md:py-28 lg:px-12 lg:py-32 xl:px-20">
  <div class="relative z-10 mx-auto max-w-7xl" data-reveal>
    
    <!-- <div class="text-center mb-32 md:mb-40">
        <div class="flex items-center justify-center gap-4 mb-8">
          <span class="h-[2px] w-10 bg-orange-400 block"></span>
          <p class="font-mono text-[14px] uppercase tracking-[0.5em] text-orange-400 font-bold">
            Steps to Growth
          </p>
          <span class="h-[2px] w-10 bg-orange-400 block"></span>
        </div>

        <h2 class="relative w-fit mx-auto text-6xl md:text-8xl font-black text-black mb-4 tracking-tighter uppercase pb-8">
            From Idea to <span class="text-orange-400">Execution</span>
            <span class="absolute bottom-0 left-1/2 -translate-x-1/2 my-6 w-48 md:w-80 h-[4px] bg-orange-400 opacity-60 rounded-full"></span>
        </h2>
        <p class="text-gray-500 max-w-2xl mx-auto text-xl font-light leading-relaxed">
            A precision-engineered lifecycle designed to transition your product from initial concept to market-dominant scale.
        </p>
    </div> -->
    <div class="relative z-10 mx-auto mb-14 max-w-7xl text-center sm:mb-20 md:mb-24">
      <div class="mb-7 flex items-center justify-center gap-3 sm:mb-10 sm:gap-5">
        <span class="h-0.5 w-8 bg-orange-400 sm:w-12 md:w-14"></span>
        <p class="font-mono text-xs font-bold uppercase tracking-[0.35em] text-orange-400 sm:text-base sm:tracking-[0.45em] md:text-lg md:tracking-[0.5em]">
          Steps to Growth
        </p>
        <span class="h-0.5 w-8 bg-orange-400 sm:w-12 md:w-14"></span>
      </div>

      <div class="flex flex-col items-center justify-center px-1">
        <h2 class="text-balance text-5xl font-[900] uppercase leading-[0.9] tracking-tighter text-black sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl 2xl:[font-size:clamp(5rem,7vw,8.5rem)]">
          <span class="text-orange-400">Progress</span>
          <br />
          At Every Step
        </h2>
        <div class="my-6 h-1 w-48 rounded-full bg-orange-400 opacity-50 sm:my-8 sm:w-72 md:w-80"></div>
        <p class="mx-auto max-w-2xl px-1 text-base font-light leading-relaxed text-gray-500 sm:text-lg md:text-xl">
          A clear and straightforward process designed to take your website from idea to launch without confusion or unnecessary complexity.
        </p>
      </div>
    </div>

    <div class="mx-auto max-w-5xl space-y-16 sm:space-y-24 md:space-y-32 lg:space-y-40">
      {steps.map((step) => (
        <div class="group/main relative">
          <div class="pointer-events-none absolute -top-12 left-0 z-0 select-none overflow-hidden sm:-top-16 md:-top-24 lg:-top-36 xl:-top-44">
            <span class="inline-block -translate-y-2 transform text-[5rem] font-black italic leading-none text-orange-500/[0.13] sm:text-[7rem] md:text-[11rem] lg:text-[18rem] xl:text-[24rem]">
              {step.id}
            </span>
          </div>

          <div class="relative z-10 flex flex-col gap-6 sm:gap-8">
            <div class="flex min-w-0 items-center gap-3 sm:gap-4">
              <span class="shrink-0 font-poppins text-[10px] font-black uppercase tracking-[0.25em] text-orange-400 sm:text-xs sm:tracking-[0.4em]">
                Step {step.id}
              </span>
              <div class="h-px min-w-0 flex-1 bg-black/20"></div>
            </div>

            <h3 class="-mt-2 max-w-full text-balance break-words text-3xl font-black uppercase leading-[1.05] tracking-tighter sm:-mt-4 sm:text-4xl md:text-6xl lg:text-7xl xl:text-8xl">
              {(() => {
                const mid = Math.ceil(step.phase.length / 2);
                const firstHalf = step.phase.slice(0, mid);
                const secondHalf = step.phase.slice(mid);
                return (
                  <>
                    <span class="text-black">{firstHalf}</span><span class="text-orange-400">{secondHalf}</span>
                  </>
                );
              })()}
            </h3>

            <div class="grid grid-cols-1 items-start gap-8 pt-2 sm:gap-10 sm:pt-4 md:grid-cols-2 md:gap-12">
              <div class="flex min-w-0 flex-col gap-4 sm:gap-6">
                <div class="group/status flex min-w-0 items-start gap-3 transition-transform duration-500 sm:items-center sm:gap-5">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="mt-0.5 h-6 w-6 shrink-0 text-orange-400 drop-shadow-[0_0_10px_rgba(251,146,60,0.4)] sm:mt-0 sm:h-8 sm:w-8"
                    aria-hidden="true"
                  >
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  <span class="min-w-0 text-lg font-semibold uppercase tracking-tighter text-black/90 transition-colors group-hover/status:text-black sm:text-2xl md:text-3xl lg:text-4xl">
                    {step.status}
                  </span>
                </div>

                <div class="group/status2 flex min-w-0 items-start gap-3 transition-transform duration-500 sm:items-center sm:gap-5">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="mt-0.5 h-6 w-6 shrink-0 text-orange-400 drop-shadow-[0_0_10px_rgba(251,146,60,0.4)] sm:mt-0 sm:h-8 sm:w-8"
                    aria-hidden="true"
                  >
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  <span class="min-w-0 text-lg font-semibold uppercase tracking-tighter text-black/90 transition-colors group-hover/status2:text-black sm:text-2xl md:text-3xl lg:text-4xl">
                    {step.status2}
                  </span>
                </div>
              </div>

              <div class="group/card relative overflow-hidden rounded-2xl border border-white/10 bg-neutral-950 p-5 shadow-2xl transition-all duration-500 hover:border-orange-400/40 sm:p-7 md:p-9 lg:p-10">
                <div class="pointer-events-none absolute -right-2 -top-2 text-orange-400 opacity-20 transition-all duration-700 sm:-right-4 sm:-top-4 [&>svg]:h-24 [&>svg]:w-24 sm:[&>svg]:h-32 sm:[&>svg]:w-32 md:[&>svg]:h-40 md:[&>svg]:w-40 lg:[&>svg]:h-[180px] lg:[&>svg]:w-[180px]">
                  <step.icon size={180} strokeWidth={0.5} />
                </div>

                <div class="relative z-10 flex h-full min-h-0 flex-col">
                  <div class="mb-6 flex items-center justify-between sm:mb-10">
                    <div class="flex flex-col gap-2">
                      <p class="font-mono text-[9px] font-bold uppercase tracking-[0.3em] text-orange-400 sm:text-[10px] sm:tracking-[0.4em]">
                        Outcome Module
                      </p>
                      <div class="h-px w-8 origin-left bg-orange-400/40 transition-all duration-700 group-hover/card:w-full"></div>
                    </div>
                  </div>
                  <p class="text-base font-light leading-relaxed tracking-tight text-white/95 sm:text-lg md:text-xl lg:text-2xl">
                    {step.outcome}
                  </p>
                </div>

                <div class="absolute bottom-0 left-0 w-full h-[2px] bg-white/5 overflow-hidden">
                    <div class="h-full w-full bg-orange-400 scale-x-0 group-hover/card:scale-x-100 transition-transform duration-500 origin-left shadow-[0_0_15px_#fb923c]"></div>
                </div>
              </div>
              
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>