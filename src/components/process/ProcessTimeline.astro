---
/**
 * Timeline_Tabular_Precision.astro
 * Style: Technical Spec Table / Minimalist Industrial
 * Theme: Black & Orange-400
 */
import { Search, PenTool, Code2, Rocket } from "lucide-react";

const schedule = [
  {
    phase: "01. Discovery",
    duration: "2–3 Days",
    icon: Search,
    details: "Understanding your business, goals, and website requirements"
  },
  {
    phase: "02. Design",
    duration: "4–7 Days",
    icon: PenTool,
    details: "Designing a clear, user-friendly layout focused on engagement and trust"
  },
  {
    phase: "03. Development",
    duration: "1–2 Weeks",
    icon: Code2,
    details: "Building a fast, responsive website with clean structure and functionality"
  },
  {
    phase: "04. Launch",
    duration: "24–48 Hours",
    icon: Rocket,
    details: "Final testing, optimization, and making your website live"
  }
];
---

<section class="w-full scroll-mt-24 bg-[#050505] px-4 py-16 font-sans antialiased sm:scroll-mt-28 sm:px-6 sm:py-24 md:py-32 lg:py-36" id="timeline">
  <div class="mx-auto max-w-4xl">
    <div class="mb-10 flex flex-col items-center text-center sm:mb-12 md:mb-14">
      <div class="mb-6 flex items-center justify-center gap-2 sm:mb-8 sm:gap-4">
        <span class="block h-px w-8 bg-orange-400 sm:w-10"></span>
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.3em] text-orange-400 sm:text-sm sm:tracking-[0.45em] md:text-[14px] md:tracking-[0.5em]">
          Process Timeline
        </p>
        <span class="block h-px w-8 bg-orange-400 sm:w-10"></span>
      </div>
      <h2 class="text-balance text-4xl font-black uppercase leading-[0.95] tracking-[-0.05em] text-white sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl">
        <span class="text-orange-400">Delivery</span>
        <span class="text-white"> Steps</span>
      </h2>
      <div class="my-5 h-1 w-44 rounded-full bg-orange-400 opacity-50 sm:my-6 sm:w-60 md:w-72"></div>
      <p class="mx-auto max-w-3xl px-1 text-base font-light leading-relaxed text-zinc-400 sm:text-lg md:text-lg">
        Most websites are completed within 2–3 weeks, with a clear timeline for each phase so you always know what’s happening and when.
      </p>
    </div>

    <div class="mt-10 divide-y divide-white/10 rounded-sm border border-white/10 sm:mt-14 md:mt-16">
      <div class="hidden bg-white/[0.02] text-[10px] font-inter uppercase tracking-[0.3em] text-gray-500 md:flex">
        <div class="w-1/3 py-3 pl-4 pr-2 font-bold text-orange-400/80 sm:px-6 md:px-8 md:py-4">Phase</div>
        <div class="w-1/3 py-3 px-2 font-bold text-orange-400/80 sm:px-6 md:px-8 md:py-4">Process</div>
        <div class="w-1/3 py-3 pl-2 pr-4 text-right font-bold text-orange-400/80 sm:px-6 md:px-8 md:py-4">Duration</div>
      </div>

      {schedule.map((item) => (
        <div class="group flex flex-col transition-all duration-300 hover:bg-orange-400/[0.02] md:flex-row md:items-center">
          <div class="flex w-full items-center gap-3 border-b border-white/5 px-4 py-5 sm:gap-4 sm:px-6 md:w-1/3 md:border-b-0 md:py-6 md:pl-4 md:pr-2 lg:px-8">
            <div class="shrink-0 rounded-sm border border-white/10 bg-white/5 p-2 transition-colors group-hover:border-orange-400/40">
              <item.icon size={16} className="text-gray-400 transition-colors group-hover:text-orange-400" />
            </div>
            <span class="min-w-0 text-left text-xs font-bold uppercase tracking-tight text-white sm:text-sm">{item.phase}</span>
          </div>

          <div class="w-full border-b border-white/5 px-4 py-4 sm:px-6 md:w-1/3 md:border-b-0 md:py-6 md:px-4 lg:px-8">
            <p class="mb-1 font-mono text-[9px] uppercase tracking-widest text-orange-400/90 md:hidden">Process</p>
            <span class="text-xs uppercase tracking-wider text-gray-500 transition-colors group-hover:text-gray-300 sm:text-[13px]">
              {item.details}
            </span>
          </div>

          <div class="flex w-full items-center justify-between px-4 py-4 sm:px-6 md:w-1/3 md:justify-end md:py-6 md:pl-2 md:pr-4 lg:px-8">
            <p class="font-mono text-[9px] uppercase tracking-widest text-orange-400/90 md:hidden">Duration</p>
            <span class="text-base font-black tabular-nums text-white transition-colors group-hover:text-orange-400 sm:text-lg md:text-right">
              {item.duration}
            </span>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-center justify-center gap-6 border-t border-white/10 pt-10 sm:mt-14 md:mt-16 md:gap-10">
      <div class="group relative mt-4 inline-block max-w-full overflow-hidden rounded-full bg-gradient-to-r from-white/10 via-orange-500/60 to-white/10 p-[2px] shadow-2xl shadow-orange-500/10 sm:mt-6 md:mt-10">
        <div class="absolute -inset-4 bg-orange-500/20 opacity-0 blur-3xl transition-opacity duration-700 group-hover:opacity-100"></div>

        <a
          href="/contact"
          class="relative flex w-full max-w-lg items-center gap-4 rounded-full bg-[#080808] py-2.5 pl-2.5 pr-4 transition-all duration-500 hover:bg-black sm:w-auto sm:max-w-none sm:gap-8 sm:py-3 sm:pl-3 sm:pr-8 md:gap-12 md:pr-12"
        >
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-orange-400 text-black shadow-[0_0_30px_rgba(251,133,0,0.4)] transition-transform duration-1000 ease-in-out group-hover:rotate-[360deg] sm:h-14 sm:w-14 md:h-16 md:w-16">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
            </svg>
          </div>

          <div class="min-w-0 flex flex-col text-left">
            <p class="mb-1 text-[9px] font-black uppercase leading-none tracking-[0.35em] text-orange-400 sm:mb-2 sm:tracking-[.4em]">Ready to Build?</p>
            <span class="text-base font-black uppercase tracking-tight text-white transition-colors group-hover:text-orange-400 sm:text-lg md:text-xl">
              Start Your Project
            </span>
          </div>
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  /* Pixel-perfect typography and smoothing */
  section {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  ::selection {
    background: #fb923c;
    color: #000;
  }
</style>