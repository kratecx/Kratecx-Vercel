---
/**
 * Deliverables_Tabular_Precision.astro
 * Style: Technical Spec Table (Matches Timeline)
 * Theme: Black & Orange-400
 */
import { Check, MonitorSmartphone, Zap, Settings, Globe, FileCode2 } from 'lucide-react';

const deliverables = [
  {
    asset: "01. Responsive Website",
    spec: "Works perfectly on all devices (mobile, tablet, desktop)",
    icon: MonitorSmartphone,
  },
  {
    asset: "02. High Performance Setup",
    spec: "Fast loading speed with optimized Core Web Vitals",
    icon: Zap,
  },
  {
    asset: "03. Easy Content Management",
    spec: "Simple system to update text, images, and pages anytime",
    icon: Settings,
  },
  {
    asset: "04. SEO Ready Structure",
    spec: "Built to rank better on search engines from day one",
    icon: Globe,
  },
  {
    asset: "05. Full Source Ownership",
    spec: "You get clean code, documentation, and full ownership",
    icon: FileCode2,
  }
];
---

<section class="w-full scroll-mt-24 bg-[#050505] px-4 py-16 font-sans antialiased sm:scroll-mt-28 sm:px-6 sm:py-20 md:py-24 lg:py-28" id="deliverables">
  <div class="mx-auto max-w-4xl" data-reveal>
    
    <!-- <div class="text-center mb-40 md:mb-16">
        <div class="flex items-center justify-center gap-4 mb-8">
          <span class="h-[2px] w-10 bg-orange-400 block"></span>
          <p class="font-mono text-[14px] uppercase tracking-[0.5em] text-orange-400 font-bold">
            Project Handover
          </p>
          <span class="h-[2px] w-10 bg-orange-400 block"></span>
        </div>

        <h2 class="relative w-fit mx-auto text-6xl md:text-8xl font-black text-white mb-4 tracking-tighter uppercase pb-8">
            What You <span class="text-orange-400">Receive</span>
            <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-48 md:w-80 h-[4px] bg-orange-400 opacity-60 rounded-full"></span>
        </h2>

        <p class="text-gray-500 max-w-2xl mx-auto text-xl mt-8 font-light leading-relaxed">
             A complete, production-ready website with all assets, documentation, and ownership transferred to you at project completion.
        </p>
    </div> -->

    <div class="mb-10 flex flex-col items-center text-center sm:mb-12 md:mb-14">
      <div class="mb-6 flex items-center justify-center gap-2 sm:mb-8 sm:gap-4">
        <span class="block h-px w-8 bg-orange-400 sm:w-10"></span>
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.3em] text-orange-400 sm:text-sm sm:tracking-[0.45em] md:text-[14px] md:tracking-[0.5em]">
          Project Handover
        </p>
        <span class="block h-px w-8 bg-orange-400 sm:w-10"></span>
      </div>
      <h2 class="text-balance text-4xl font-black uppercase leading-[0.95] tracking-[-0.05em] text-white sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl">
        <span class="text-white">What You </span>
        <span class="text-orange-400">Receive</span>
      </h2>
      <div class="my-5 h-1 w-44 rounded-full bg-orange-400 opacity-50 sm:my-6 sm:w-60 md:w-72"></div>
      <p class="mx-auto max-w-3xl px-1 text-base font-light leading-relaxed text-zinc-400 sm:text-lg">
        A complete, production-ready website with all assets, documentation, and ownership transferred to you at project completion.
      </p>
    </div>

    <div class="mt-10 divide-y divide-white/10 rounded-sm border border-white/10 sm:mt-12 md:mt-14">
      <div class="hidden bg-white/[0.02] text-[10px] font-inter uppercase tracking-[0.3em] text-gray-500 md:flex">
        <div class="w-1/3 py-3 pl-4 pr-2 font-bold text-orange-400/80 sm:px-6 md:px-8 md:py-4">Asset Type</div>
        <div class="w-1/3 py-3 px-2 font-bold text-orange-400/80 sm:px-6 md:px-8 md:py-4">Specification</div>
        <div class="w-1/3 py-3 pl-2 pr-4 text-right font-bold text-orange-400/80 sm:px-6 md:px-8 md:py-4">Status</div>
      </div>

      {deliverables.map((item) => (
        <div class="group flex flex-col transition-all duration-300 hover:bg-orange-400/[0.02] md:flex-row md:items-center">
          <div class="flex w-full items-center gap-3 border-b border-white/5 px-4 py-5 sm:gap-4 sm:px-6 md:w-1/3 md:border-b-0 md:py-6 md:pl-4 md:pr-2 lg:px-8">
            <div class="shrink-0 rounded-sm border border-white/10 bg-white/5 p-2 transition-colors group-hover:border-orange-400/40">
              <item.icon size={16} className="text-gray-400 transition-colors group-hover:text-orange-400" />
            </div>
            <span class="min-w-0 text-left text-xs font-bold uppercase tracking-tight text-white sm:text-sm">{item.asset}</span>
          </div>

          <div class="w-full border-b border-white/5 px-4 py-4 sm:px-6 md:w-1/3 md:border-b-0 md:py-6 md:px-4 lg:px-8">
            <p class="mb-1 font-mono text-[9px] uppercase tracking-widest text-orange-400/90 md:hidden">Specification</p>
            <span class="text-xs uppercase tracking-wider text-gray-500 transition-colors group-hover:text-gray-300 sm:text-[13px]">
              {item.spec}
            </span>
          </div>

          <div class="flex w-full items-center justify-between px-4 py-4 sm:px-6 md:w-1/3 md:justify-end md:py-6 md:pl-2 md:pr-4 lg:px-8">
            <p class="font-mono text-[9px] uppercase tracking-widest text-orange-400/90 md:hidden">Status</p>
            <div class="flex h-8 w-8 items-center justify-center rounded-full border border-orange-400/20 bg-orange-400/10 transition-all duration-300 group-hover:bg-orange-400">
              <Check size={16} className="text-orange-400 transition-colors group-hover:text-black" strokeWidth={3} />
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="my-12 flex flex-col items-center justify-center gap-6 border-t border-white/10 pt-8 sm:my-14 sm:gap-10 sm:pt-10 md:my-16">
      <div class="group relative mt-4 inline-block max-w-full overflow-hidden rounded-full bg-gradient-to-r from-white/10 via-orange-500/60 to-white/10 p-[2px] shadow-2xl shadow-orange-500/10 sm:mt-6 md:mt-8">
        <div class="absolute -inset-4 bg-orange-500/20 opacity-0 blur-3xl transition-opacity duration-700 group-hover:opacity-100"></div>

        <a
          href="/contact"
          class="relative flex w-full max-w-lg items-center gap-4 rounded-full bg-[#080808] py-2.5 pl-2.5 pr-4 transition-all duration-500 hover:bg-black sm:w-auto sm:max-w-none sm:gap-8 sm:py-3 sm:pl-3 sm:pr-8 md:gap-10"
        >
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-orange-400 text-black shadow-[0_0_30px_rgba(251,133,0,0.4)] transition-transform duration-1000 ease-in-out group-hover:rotate-[360deg] sm:h-14 sm:w-14 md:h-16 md:w-16">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
            </svg>
          </div>

          <div class="min-w-0 flex flex-col text-left">
            <p class="mb-1 text-[9px] font-black uppercase leading-none tracking-[0.35em] text-orange-400 sm:mb-2 sm:tracking-[.4em]">Ready to Grow?</p>
            <span class="text-base font-black uppercase tracking-tight text-white transition-colors group-hover:text-orange-400 sm:text-lg md:text-xl">
              We’ll help you build it
            </span>
          </div>
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  section {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  ::selection {
    background: #fb923c;
    color: #000;
  }
</style>