---
import { Image } from "astro:assets";

const { categories, filters } = Astro.props;
---

<div 
  id="portfolio-sticky-bar"
  class="relative z-20 w-full border-b border-white/5 bg-black pb-2 backdrop-blur-none transition-all duration-500 ease-in-out sm:bg-black/95 sm:backdrop-blur-2xl sm:supports-[backdrop-filter]:bg-black/80 sm:sticky sm:top-15 sm:z-[1000] sm:pb-1 sm:pt-1"
>
  <div class="max-w-7xl mx-auto px-3 sm:px-6">
    <div class="flex flex-wrap justify-center gap-2 py-1 sm:items-center sm:gap-3">
      {filters.map((f: { id: string; label: string }) => (
        <a
          href={`#${f.id}`}
          data-section={f.id}
          class="portfolio-nav-btn flex min-h-[2.5rem] min-w-0 shrink-0 grow-0 basis-[calc((100%-1rem)/3)] max-w-[calc((100%-1rem)/3)] items-center justify-center rounded-full border border-white/10 bg-black px-2 py-2 text-center text-[11px] font-medium capitalize leading-tight tracking-normal text-gray-400 transition-all duration-300 hover:border-orange-400 hover:text-white sm:min-h-0 sm:max-w-none sm:basis-auto sm:shrink-0 sm:grow-0 sm:bg-white/5 sm:px-5 sm:py-2 sm:text-[13px]"
        >
          {f.label}
        </a>
      ))}
    </div>
  </div>
</div>

<section id="portfolio-display" class="relative min-h-0 bg-white py-14 sm:py-20 lg:py-32 z-20 overflow-x-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6" data-reveal>
    {categories.map((group: any) => (
      <div id={group.id} class="mb-20 sm:mb-28 lg:mb-40 last:mb-0 scroll-mt-24 sm:scroll-mt-28 md:scroll-mt-32">
<div class="flex flex-col items-center text-center mb-12 sm:mb-16 lg:mb-24 group/header">
  <div class="flex w-full max-w-full items-center justify-center gap-2 sm:gap-4 mb-6 sm:mb-8 animate-fade-in px-1">
    <span class="h-0.5 w-6 shrink-0 bg-orange-400 sm:w-10"></span>
    <p class="min-w-0 font-mono text-[11px] uppercase tracking-[0.25em] text-orange-400 font-bold sm:text-sm sm:tracking-[0.5em]">
      {group.subheading}
    </p>
    <span class="h-0.5 w-6 shrink-0 bg-orange-400 sm:w-10"></span>
  </div>

  <h2 class="text-balance break-words px-2 text-6xl sm:text-7xl md:text-[4.75rem] lg:text-[118px] font-semibold text-[#111] leading-[0.9] sm:leading-[0.85] tracking-tighter uppercase mb-4 sm:mb-6">
    {group.heading.split(' ').slice(0, -1).join(' ')}{' '}
    <span class="text-orange-400">Archive</span>
  </h2>

  <p class="max-w-3xl px-2 text-base leading-relaxed font-light text-gray-500 sm:text-lg md:text-2xl">
    <span class="block text-gray-700">{group.desc}</span>
  </p>
</div>

        <div class="grid grid-cols-1 gap-6 sm:gap-8 md:grid-cols-2 md:gap-10">
          {group.projects.map((post: any) => (
            <a href={`/portfolio/${post.id}`} class="group relative aspect-[16/11] min-h-[220px] overflow-hidden rounded-2xl bg-gray-100 shadow-sm transition-all duration-700 sm:aspect-[16/10] sm:rounded-3xl md:rounded-[3rem] md:hover:-translate-y-2 md:hover:shadow-2xl">
              <Image
                src={post.img}
                alt={post.title}
                width={1200}
                height={800}
                loading="lazy"
                decoding="async"
                sizes="(max-width: 768px) 100vw, 50vw"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-1000 md:group-hover:scale-110"
              />
              <div class="absolute inset-x-3 bottom-3 sm:inset-x-4 sm:bottom-4">
                <div class="flex flex-row items-start justify-between gap-3 rounded-2xl border border-white/40 bg-white/75 p-4 backdrop-blur-2xl sm:items-end sm:rounded-[2rem] sm:p-6 md:p-8">
                  <div class="min-w-0 flex-1 text-left">
                    <span class="mb-1 block text-[9px] font-black uppercase tracking-[0.3em] text-[#FB8500] sm:mb-2">ID_{post.id}</span>
                    <h3 class="text-xl font-semibold uppercase tracking-tighter text-[#111] sm:text-2xl md:text-3xl">{post.title}</h3>
                    <p class="mt-1.5 text-[9px] font-bold uppercase tracking-widest text-gray-500 sm:mt-2 sm:text-[10px]">// {post.tech}</p>
                  </div>
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#111] text-white sm:h-11 sm:rounded-2xl md:h-12 md:w-12 md:group-hover:bg-[#FB8500] md:transition-colors">
                    <svg class="h-4 w-4 md:h-5 md:w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .portfolio-nav-btn.active {
    border-color: #fb923c !important;
    color: white !important;
    background: rgba(251, 146, 60, 0.2);
    box-shadow: 0 0 20px rgba(251, 146, 60, 0.3);
  }

  .is-hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-20px);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const stickyBar = document.getElementById('portfolio-sticky-bar');
    const navButtons = document.querySelectorAll('.portfolio-nav-btn');
    const footer = document.querySelector('footer');

    // 1. SCROLLSPY (FOCUS LOGIC)
    const observerOptions = {
      root: null,
      rootMargin: '-30% 0px -60% 0px',
      threshold: 0
    };

    const sectionObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          navButtons.forEach(btn => {
            btn.classList.toggle('active', btn.getAttribute('data-section') === id);
          });
        }
      });
    }, observerOptions);

    // Watch all categories passed via props
    document.querySelectorAll('[id]').forEach(section => {
      if (['business', 'startup', 'ecommerce', 'landing', 'redesign'].includes(section.id)) {
        sectionObserver.observe(section);
      }
    });

    // 2. FOOTER AVOIDANCE
    if (stickyBar && footer) {
      const footerObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) stickyBar.classList.add('is-hidden');
          else stickyBar.classList.remove('is-hidden');
        });
      }, { threshold: 0.1 });
      footerObserver.observe(footer);
    }
  });
</script>