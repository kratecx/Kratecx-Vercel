---
// Problem Data - Hardcoded for impact
const problem = {
  title: "The Friction",
  title_1st_half: "The ",
  title_2nd_half: "Friction",
  subtitle: "Helplessness in the Analog",
  painPoints: [
    { id: "01", label: "Data Decay", description: "Information lost in paper logs and fragmented spreadsheets." },
    { id: "02", label: "User Blindness", description: "Zero visibility into athlete fatigue or equipment utilization." },
    { id: "03", label: "Stagnation", description: "Manual systems that break as soon as you scale." }
  ],
  images: [
    "https://images.unsplash.com/photo-1594882645126-14020914d58d?q=80&w=800",
    "https://images.unsplash.com/photo-1517836357463-d25dfeac3438?q=80&w=800",
    "https://images.unsplash.com/photo-1552674605-db6ffd4facb5?q=80&w=800"
  ]
};
---

<section class="relative bg-white text-black py-24 px-6 font-sans selection:bg-orange-600 selection:text-white">
  
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    
    <nav class="mb-12">
      <a href="/" class="group inline-flex items-center gap-2 text-black/30 hover:text-orange-600 transition-all">
        <span class="text-xs font-bold tracking-[0.3em] uppercase">The Status Quo</span>
      </a>
    </nav>

    <div class="grid md:grid-cols-2 gap-12 mb-24 items-start">
      <div>
        <h1 class="text-7xl md:text-[10rem] text-black font-black uppercase leading-[0.8] tracking-tighter mb-6 italic">
          {problem.title_1st_half}<span class="text-orange-500">{problem.title_2nd_half}.</span>
        </h1>
        <p class="text-3xl font-bold text-neutral-400 uppercase tracking-widest leading-none">
          {problem.subtitle}
        </p>
      </div>
      <div class="md:pt-4">
        <p class="text-xl md:text-2xl text-neutral-800 font-medium leading-tight max-w-md border-l-4 border-orange-600 pl-6">
          Gym owners are trapped in a cycle of <span class="underline decoration-orange-600 underline-offset-4">manual friction</span>, losing athletes to smarter facilities every single day.
        </p>
      </div>
    </div>

    <div class="relative h-[600px] mb-32">
      <div class="absolute top-0 left-0 w-3/5 h-[450px] rounded-2xl overflow-hidden shadow-2xl  hover:grayscale-0 transition-all duration-700 z-10 shadow-black rotate-[-2deg]">
        <img src={problem.images[1]} class="w-full h-full object-cover" alt="The stress" />
        <div class="absolute inset-0 bg-orange-900/10 mix-blend-multiply"></div>
      </div>

      <div class="absolute top-20 right-0 w-2/5 h-[380px] rounded-2xl overflow-hidden shadow-2xl  brightness-50 z-20 rotate-[3deg] translate-x-4 shadow-black">
        <img src={problem.images[0]} class="w-full h-full object-cover" alt="Clutter" />
      </div>

      <div class="absolute bottom-0 left-1/4 w-1/4 h-[220px] rounded-2xl overflow-hidden shadow-2xl z-30 -translate-y-4 border-2 border-black/20 shadow-black rotate-[-5deg]">
        <img src={problem.images[2]} class="w-full h-full object-cover" alt="Old tech" />
      </div>
    </div>

<div class="mt-32 grid md:grid-cols-3 gap-8 relative">
      {/* Background Glow Orbs for Glass Effect Depth */}
      <div class="absolute -top-20 left-10 w-64 h-64 bg-orange-500/10 blur-[120px] rounded-full"></div>
      <div class="absolute -bottom-20 right-10 w-64 h-64 bg-orange-600/10 blur-[120px] rounded-full"></div>

      {problem.painPoints.map((point) => (
        <div class="group relative">
          {/* Card Body with Glassmorphism */}
          <div class="h-full backdrop-blur-md bg-white/40 border border-orange-200 rounded-3xl p-10 
                      shadow-[0_8px_32px_0_rgba(0,0,0,0.05)] hover:shadow-orange-500/10 
                      transition-all duration-500 hover:-translate-y-2 flex flex-col">
            
            {/* Glass Icon / Number Circle */}
            <div class="w-14 h-14 rounded-2xl bg-orange-500/10 flex items-center justify-center 
                        border border-orange-500/20 mb-8 group-hover:bg-orange-500 group-hover:rotate-[10deg] transition-all duration-500">
              <span class="text-orange-600 group-hover:text-white font-black italic tracking-tighter">
                {point.id}
              </span>
            </div>

            <h3 class="text-3xl font-black uppercase tracking-tight mb-4 text-neutral-900 leading-none">
              {point.label}
            </h3>

            <p class="text-neutral-600 font-medium leading-relaxed italic border-l-2 border-orange-500/30 pl-4 group-hover:border-orange-500 transition-colors">
              "{point.description}"
            </p>

            {/* Subtle "Data Line" at bottom */}
            <div class="mt-auto pt-8">
              <div class="flex justify-between items-center opacity-40 group-hover:opacity-100 transition-opacity">
                <span class="text-[10px] font-bold tracking-[0.2em] text-neutral-400">ANALYSIS_COMPLETE</span>
                <div class="h-[1px] w-12 bg-orange-500/50 group-hover:w-20 transition-all duration-500"></div>
              </div>
            </div>
          </div>

          {/* Hidden Glow behind card on hover */}
          <div class="absolute inset-0 bg-orange-500/5 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity -z-10 rounded-3xl"></div>
        </div>
      ))}
    </div>

<div class="mt-32 pb-24 flex flex-col items-center relative">
      
      {/* Background Radial Glow to draw focus */}
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-orange-500/5 blur-[120px] rounded-full pointer-events-none"></div>

      <div class="group relative px-2 py-2">
        {/* Animated Border Glow - The 'Energy' around the button */}
        <div class="absolute inset-0 bg-orange-600 rounded-full blur-md opacity-20 group-hover:opacity-60 group-hover:blur-xl transition-all duration-500"></div>

        {/* The Obsidian Button */}
        <button class="relative flex items-center gap-6 px-16 py-7 bg-black rounded-full border border-white/10 overflow-hidden transition-all duration-300 group-hover:border-orange-500/50 group-hover:scale-[1.02] active:scale-[0.98]">
          
          {/* Internal Reflection Sweep */}
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite] pointer-events-none"></div>

          <div class="flex flex-col items-start">
            <span class="text-[10px] font-black uppercase tracking-[0.5em] text-orange-500 mb-1">
              Initiate Protocol
            </span>
            <span class="text-white text-xl font-black uppercase tracking-[0.2em]">
              Fix the System
            </span>
          </div>

          {/* Icon / Action Indicator */}
          <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-orange-600 group-hover:border-orange-400 transition-all duration-500">
            <svg class="w-5 h-5 text-white group-hover:rotate-45 transition-transform duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>

          {/* Subtle Outer Ring */}
          <div class="absolute inset-0 rounded-full border border-white/5 group-hover:scale-110 group-hover:opacity-0 transition-all duration-700"></div>
        </button>
      </div>

      {/* Subtext Branding */}
      <p class="mt-10 text-[10px] font-mono text-neutral-400 tracking-[0.4em] uppercase opacity-50">
        Secure Handover // 256-Bit Intelligence
      </p>

    </div>

    {/* Required Tailwind Custom Animation in your globals.css or Tailwind config */}
    <style>
      @keyframes shimmer {
        100% { transform: translateX(100%); }
      }
    </style>

  </div>
</section>