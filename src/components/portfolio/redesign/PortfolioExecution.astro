---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import PortfolioExecutionGallery from "./PortfolioExecutionGallery";

/**
 * Execution case-study layout — hero, checkpoints, parity, and project gallery.
 */

interface Checkpoint {
  title: string;
  text: string;
}

interface ParityCheck {
  title: string;
  text: string;
}

interface Props {
  tagline?: string;
  heroHeadingTop?: string;
  heroHeadingBottom?: string;
  heroDescription?: string;
  heroImage?: string;
  /** Mobile screenshot paired with hero (from `mobImage` in portfolio data). */
  heroMobileImage?: ImageMetadata;
  section2Title?: string;
  checkpoints?: Checkpoint[];
  section3TitleTop?: string;
  section3TitleBottom?: string;
  section3Description?: string;
  section3ImageBack?: string;
  section3ImageFront?: string;
  parityChecks?: ParityCheck[];
  galleryTitleTop?: string;
  galleryTitleBottom?: string;
  caseStudyTitle?: string;
  galleryImages?: (ImageMetadata | string)[];
}
---

<section class="bg-white text-black py-16 sm:py-20 px-5 sm:px-6 lg:px-24 font-sans antialiased overflow-hidden selection:bg-orange-100 selection:text-orange-600 relative z-10">
  <div class="max-w-7xl mx-auto" data-reveal>
    <div class="mb-10 sm:mb-14 flex flex-col items-center text-center">
      <div class="flex items-center justify-center gap-3 sm:gap-4 mb-6 sm:mb-8">
        <span class="h-px w-8 sm:w-10 bg-orange-400 block"></span>
        <p class="font-mono text-[11px] sm:text-[14px] uppercase tracking-[0.35em] sm:tracking-[0.5em] text-orange-400 font-bold">
          {Astro.props.tagline}
        </p>
        <span class="h-px w-8 sm:w-10 bg-orange-400 block"></span>
      </div>
      <h2 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-semibold uppercase tracking-[-0.05em] leading-[0.9] lg:leading-[0.85] text-black">
        {Astro.props.heroHeadingTop} <br />
        <span class="text-orange-400 inline-block mt-2">{Astro.props.heroHeadingBottom}</span>
      </h2>
      <div class="w-40 sm:w-60 h-1 bg-orange-400 my-5 sm:my-6 rounded-full opacity-50"></div>
      <p class="text-gray-800 max-w-2xl mx-auto text-base sm:text-lg font-light">{Astro.props.heroDescription}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 sm:gap-16 lg:gap-32 lg:items-start">
      {Astro.props.heroImage || Astro.props.heroMobileImage ? (
        <div
          class:list={[
            "relative isolate mx-auto w-full max-w-2xl lg:mx-0 lg:max-w-none",
            Astro.props.heroMobileImage && Astro.props.heroImage ? "overflow-visible pb-16 pt-1 sm:pb-20 lg:pb-24 lg:pt-2" : "",
          ]}
        >
          {Astro.props.heroImage ? (
            <div class="relative z-10 overflow-visible rounded-lg border border-zinc-200/90 p-1 shadow-[0_20px_55px_-28px_rgba(0,0,0,0.28)] sm:rounded-xl sm:p-1.5">
              <div class="relative overflow-hidden rounded-md sm:rounded-lg">
                <Image
                  src={Astro.props.heroImage}
                  width={1600}
                  height={1067}
                  alt={`${Astro.props.caseStudyTitle ?? "Project"} — desktop`}
                  sizes="(max-width: 1024px) 100vw, 50vw"
                  class="h-auto w-full object-contain grayscale-[0.06] brightness-[1.02]"
                />
              </div>

              {/* Mobile screenshot: desktop frame ke NICHE‑DAHINE corner (ref. Victory layout) */}
              {Astro.props.heroMobileImage ? (
                <div class="absolute z-20 w-[min(5.5rem,calc(100%-24%))] max-w-[6rem] right-0 bottom-0 translate-x-[8%] translate-y-[14%] sm:translate-x-[7%] sm:translate-y-[14%] lg:right-0 lg:bottom-0 lg:translate-x-[9%] lg:translate-y-[16%]">
                  <div class="w-full">
                    <div class="overflow-hidden rounded-md border border-zinc-200/90 shadow-[0_14px_36px_-12px_rgba(0,0,0,0.48)] sm:rounded-lg ring-1 ring-black/[0.04] [&_img]:max-h-[12.75rem] sm:[&_img]:max-h-[13.25rem] lg:[&_img]:max-h-[13.75rem]">
                      <Image
                        inferSize
                        src={Astro.props.heroMobileImage as ImageMetadata}
                        alt={`${Astro.props.caseStudyTitle ?? "Project"} — mobile screenshot`}
                        sizes="(max-width: 1024px) 80px, 100px"
                        class="block h-auto w-full object-cover object-top"
                      />
                    </div>
                  </div>
                </div>
              ) : null}
            </div>
          ) : Astro.props.heroMobileImage ? (
            <div class="relative z-20 flex justify-center px-6">
              <div class="w-[min(5.5rem,calc(100vw-8rem))] max-w-[6rem]">
                <div class="overflow-hidden rounded-md border border-zinc-200/90 shadow-md sm:rounded-lg [&_img]:max-h-[13.75rem]">
                  <Image
                    inferSize
                    src={Astro.props.heroMobileImage as ImageMetadata}
                    alt={`${Astro.props.caseStudyTitle ?? "Project"} — mobile screenshot`}
                    sizes="84px"
                    class="block h-auto w-full object-cover object-top"
                  />
                </div>
              </div>
            </div>
          ) : null}
        </div>
      ) : null}
      <div class="space-y-8 sm:space-y-12 pt-2">
        <div class="border-b-2 border-black pb-4 mb-6 sm:mb-10">
            <h3 class="text-3xl sm:text-4xl lg:text-5xl uppercase font-kanit font-medium text-black italic leading-[1.05]">
              {(Astro.props.section2Title || "").split(' ')[0]} 
              <span class="text-orange-400">{(Astro.props.section2Title || "").split(' ').slice(1).join(' ')}</span>
            </h3>
        </div>
        {Astro.props.checkpoints?.map((item) => (
          <div class="flex items-start gap-4 sm:gap-6 group">
            <svg class="shrink-0 w-5 h-5 sm:w-6 sm:h-6 text-[#FB8500] mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <div class="space-y-2">
              <h4 class="text-xl sm:text-2xl font-medium uppercase tracking-tighter leading-none text-black">{item.title}</h4>
              <p class="text-zinc-500 text-sm leading-relaxed max-w-sm">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>


<!-- Section no 2 -->
<section class="bg-white text-black py-16 sm:py-20 lg:py-32 px-5 sm:px-6 lg:px-24 font-sans antialiased border-t border-gray-300 overflow-hidden relative">
  <div class="max-w-7xl mx-auto relative z-10" data-reveal>
    <div class="grid lg:grid-cols-2 gap-10 sm:gap-12 lg:gap-16 items-start">
      <div class="space-y-8 sm:space-y-12">
        <div>
          <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-6xl italic font-kanit font-medium uppercase leading-[0.95] lg:leading-[0.85] text-black">
            {Astro.props.section3TitleTop} <br> 
            <span class="text-orange-400 inline-block mt-2">{Astro.props.section3TitleBottom}</span>
          </h2>
          <div class="h-[2px] w-full bg-black rounded-full my-4"></div>
          <p class="text-zinc-500 text-base sm:text-lg lg:text-xl font-light leading-relaxed max-w-lg">
            {Astro.props.section3Description}
          </p>
        </div>

        <div class="space-y-5 sm:space-y-6">
          {Astro.props.parityChecks?.map((item) => (
            <div class="flex items-start gap-4 sm:gap-6 group">
              <svg xmlns="http://www.w3.org/2000/svg" class="shrink-0 w-6 h-6 sm:w-8 sm:h-8 text-orange-400 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div class="space-y-2">
                <h4 class="text-xl sm:text-2xl lg:text-3xl font-semibold uppercase tracking-tighter leading-[1.05] lg:leading-none text-black">{item.title}</h4>
                <p class="text-zinc-400 text-sm leading-relaxed max-w-sm">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="relative w-full aspect-[4/3] flex items-center justify-center pt-8 pb-20 sm:py-14 lg:py-20 lg:mt-10">
        <div class="relative z-10 w-[100%] aspect-video overflow-hidden rounded-2xl bg-zinc-950 shadow-[0_60px_120px_-40px_rgba(0,0,0,0.45)] lg:shadow-[0_100px_180px_-40px_rgba(0,0,0,0.55)]">
          <div class="relative h-full w-full bg-black">
            {Astro.props.section3ImageBack ? (
              <Image
                src={Astro.props.section3ImageBack}
                width={1600}
                height={900}
                alt="Primary interface parity reference"
                sizes="(max-width: 1024px) 100vw, 50vw"
                class="absolute inset-0 h-full w-full object-cover"
              />
            ) : null}
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-transparent via-white/[0.03] to-white/[0.08]"></div>
          </div>
        </div>
        <div class="absolute z-20 -bottom-10 sm:-bottom-14 lg:-bottom-16 -right-4 sm:-right-6 lg:-right-8 w-[72%] sm:w-[68%] overflow-hidden rounded-2xl border border-zinc-200/90 bg-white shadow-[-25px_25px_60px_-20px_rgba(0,0,0,0.22)] sm:rounded-3xl lg:shadow-[-50px_50px_120px_-30px_rgba(0,0,0,0.28)] aspect-video">
          <div class="relative w-full h-full bg-black">
            {Astro.props.section3ImageFront ? (
              <Image
                src={Astro.props.section3ImageFront}
                width={1200}
                height={675}
                alt="Overlapping interface parity reference"
                sizes="(max-width: 1024px) 68vw, 34vw"
                class="absolute inset-0 h-full w-full object-cover"
              />
            ) : null}
            <div class="absolute inset-0 grid grid-cols-8 gap-px opacity-[0.07] pointer-events-none">
              {Array(64).fill(0).map(() => <div class="border-[0.5px] border-zinc-400"></div>)}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- Section no 3 — project gallery -->
<section class="bg-white text-black py-16 sm:py-20 lg:py-28 px-5 sm:px-6 lg:px-24 font-sans antialiased border-t border-zinc-200">
  <div class="max-w-7xl mx-auto" data-reveal>
    <div class="mb-8 sm:mb-10 lg:mb-12 flex flex-col items-center text-center gap-4">
      <div class="flex flex-col items-center">
        <div class="mb-6 flex items-center justify-center gap-3 sm:gap-4">
          <span class="h-px w-8 sm:w-10 bg-orange-400 block shrink-0" aria-hidden />
          <p class="font-mono text-[11px] uppercase tracking-[0.35em] text-orange-400 font-bold sm:text-[14px] sm:tracking-[0.42em]">
            Screenshots
          </p>
          <span class="h-px w-8 sm:w-10 bg-orange-400 block shrink-0" aria-hidden />
        </div>
        <h2 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-semibold uppercase tracking-[-0.05em] leading-[0.9] lg:leading-[0.85] text-black">
          {Astro.props.galleryTitleTop} <br />
          <span class="text-orange-400 inline-block mt-2">{Astro.props.galleryTitleBottom}</span>
        </h2>
        <div class="mx-auto mt-5 sm:mt-6 h-1 w-40 sm:w-60 max-w-full rounded-full bg-orange-400 opacity-60" aria-hidden />
      </div>
      <p class="max-w-md text-sm font-light leading-relaxed text-zinc-500 lg:text-base">
        Slide through project frames or pick a thumbnail. Up to six views per case study.
      </p>
    </div>

    {Astro.props.galleryImages?.length ? (
      <PortfolioExecutionGallery
        client:visible
        images={Astro.props.galleryImages}
        projectTitle={Astro.props.caseStudyTitle}
      />
    ) : null}
  </div>
</section>

<style>
  h2, h4 { letter-spacing: -0.07em; }
  section { text-rendering: optimizeLegibility; -webkit-font-smoothing: antialiased; }
  h2 { filter: drop-shadow(0 20px 40px rgba(0,0,0,0.03)); }
</style>