---
/**
 * DYNAMIC BLUEPRINT COMPONENT: Seamless Blend
 * Optimized for a perfect 50/50 split where the image bleeds into the UI.
 * Zero-destructuring version: fed entirely by Astro.props.
 */
interface Props {
  category?: string;
  title?: string;
  clientType?: string;
  heroImage?: string;
  description?: string;
  vLabel?: string;
  vValue?: string;
  vUnit?: string;
  vTag?: string;
  cLabel?: string;
  cValue?: string;
  cUnit?: string;
  cTag?: string;
}
---

<section class="relative min-h-screen w-full bg-[#050505] flex flex-col lg:flex-row overflow-hidden font-sans">
  
  <div class="absolute top-0 right-0 w-full lg:w-1/2 h-full z-0 overflow-hidden lg:border-l border-zinc-900/20">
    <img 
      src={Astro.props.heroImage} 
      class="w-full h-full object-cover grayscale-0 contrast-110 brightness-[0.7] lg:scale-100 scale-110 seamless-mask" 
      alt={`${Astro.props.title} Architectural Visual`} 
    />
  </div>

  <div class="relative z-20 w-full lg:w-1/2 flex items-center pt-32 pb-20 lg:py-16">
    <div class="max-w-[700px] mx-auto px-8 xl:px-16 flex flex-col justify-center h-full">
      
      <div class="flex items-center gap-6 mb-12">
        <span class="text-orange-400 font-bold text-[11px] tracking-[0.8em] uppercase whitespace-nowrap">
          {Astro.props.category}
        </span>
        <div class="h-[1px] w-full bg-orange-400/30"></div>
      </div>

      <h1 class="text-6xl md:text-8xl xl:text-[100px] leading-[0.8] tracking-tighter uppercase mb-12">
        <span class="block text-white font-light mb-1">
          {(Astro.props.title || "").split(' ')[0]}
        </span>
        <span class="text-orange-400 font-black block">
          {(Astro.props.title || "").split(' ').slice(1).join(' ')}
        </span>
      </h1>

      <p class="max-w-xl text-zinc-500 text-sm md:text-base font-light leading-relaxed tracking-wide border-l border-orange-500/40 pl-8 mb-16 lg:mb-10">
        {Astro.props.description} <span class="text-zinc-200">{Astro.props.clientType}</span>
      </p>

      <div class="mt-auto py-8 border-t border-zinc-900/50 flex flex-wrap gap-4">
        
        <div class="relative p-6 bg-white/[0.02] border border-white/5 rounded-sm transition-all hover:border-orange-400/30 w-fit min-w-[240px] flex-grow">
          <div class="flex items-end gap-6">
            <div class="flex flex-col">
              <span class="text-zinc-600 font-mono text-[7px] uppercase tracking-[0.4em] mb-2">{Astro.props.vLabel}</span>
              <div class="flex items-baseline gap-2">
                <span class="text-5xl font-black text-white tracking-tighter tabular-nums leading-none">{Astro.props.vValue}</span>
                <span class="text-orange-400 font-black text-xs italic uppercase">{Astro.props.vUnit}</span>
              </div>
            </div>
            <div class="flex gap-[3px] items-end h-10 border-l border-white/5 pl-4">
                <div class="w-1 h-1/4 bg-zinc-800"></div>
                <div class="w-1 h-2/4 bg-zinc-800"></div>
                <div class="w-1 h-full bg-orange-400 shadow-[0_0_15px_#fb8500]"></div>
            </div>
          </div>
          <p class="mt-6 pt-3 border-t border-white/5 text-zinc-600 font-mono text-[7px] uppercase tracking-widest">{Astro.props.vTag}</p>
        </div>

        <div class="relative p-6 bg-white/[0.02] border border-white/5 rounded-sm transition-all hover:border-orange-400/30 w-fit min-w-[240px] flex-grow">
          <div class="flex items-end gap-6">
            <div class="flex flex-col">
              <span class="text-zinc-600 font-mono text-[7px] uppercase tracking-[0.4em] mb-2">{Astro.props.cLabel}</span>
              <div class="flex items-baseline gap-2">
                <span class="text-5xl font-black text-white tracking-tighter tabular-nums leading-none">{Astro.props.cValue}</span>
                <span class="text-orange-400 font-black text-xs italic uppercase">{Astro.props.cUnit}</span>
              </div>
            </div>
            <div class="flex items-center justify-center h-10 w-10 border border-white/5 rounded-full relative">
                <div class="w-2 h-2 bg-orange-400/20 rounded-full animate-ping absolute"></div>
                <div class="w-2 h-2 bg-orange-400 rounded-full z-10 shadow-[0_0_15px_#fb8500]"></div>
            </div>
          </div>
          <p class="mt-6 pt-3 border-t border-white/5 text-zinc-600 font-mono text-[7px] uppercase tracking-widest">{Astro.props.cTag}</p>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .seamless-mask {
    -webkit-mask-image: linear-gradient(to left, black 60%, transparent 100%),
                        linear-gradient(to top, black 80%, transparent 100%);
    mask-image: linear-gradient(to left, black 70%, transparent 100%),
                linear-gradient(to top, black 80%, transparent 100%);
    -webkit-mask-composite: source-in;
    mask-composite: intersect;
  }
</style>