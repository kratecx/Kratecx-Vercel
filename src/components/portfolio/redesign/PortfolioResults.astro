---
/**
 * ARCHITECTURAL IMPACT MINIMALIST
 * Refactored: All text, metrics, and CTA content via Props.
 */
import { TrendingUp, Target, ShieldCheck, Zap } from 'lucide-react';

interface ResultItem {
  metric: string;
  legacy: string;
  stable: string;
  logic: string;
  // This allows passing any Lucide icon component
  icon: any; 
}

interface Props {
  tagline?: string;
  headingTop?: string;
  headingBottom?: string;
  description?: string;
  results?: ResultItem[];
  // CTA Section Props
  ctaTitlePrefix?: string;
  ctaTitleHighlight?: string;
  ctaDescription?: string;
  ctaButtonText?: string;
  ctaLink?: string;
}


---

<section class="w-full bg-white px-6 font-sans antialiased text-slate-900 py-12" id="results">
  <div class="max-w-5xl mx-auto">
    
    <div class="mb-12 flex flex-col items-center text-center">
      <div class="flex items-center justify-center gap-4 mb-8">
        <span class="h-px w-10 bg-orange-400 block"></span>
        <p class="font-mono text-[14px] uppercase tracking-[0.5em] text-orange-400 font-bold">
          {Astro.props.tagline}
        </p>
        <span class="h-px w-10 bg-orange-400 block"></span>
      </div>
      <h2 class="text-7xl md:text-8xl font-black uppercase tracking-[-0.05em] leading-[0.85] text-black">
        {Astro.props.headingTop} <br />
        <span class="text-orange-400 inline-block mt-2">{Astro.props.headingBottom}</span>
      </h2>
      <div class="w-60 h-1 bg-orange-400 my-4 rounded-full opacity-50"></div>
      <p class="text-gray-800 max-w-2xl mx-auto text-lg font-light">
        {Astro.props.description}
      </p>
    </div>

    <div class="border-t border-slate-200">
      <div class="hidden md:flex bg-slate-50/50 border-b border-slate-100 text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400 py-4 px-8">
        <div class="w-1/3 text-left">Performance Metric</div>
        <div class="w-1/6 text-left">Legacy_V1</div>
        <div class="w-1/6 text-left">Stable_V4</div>
        <div class="w-1/3 text-right">Strategic Logic</div>
      </div>

      {Astro.props.results?.map((item) => {
        const Icon = item.icon; // Assign to uppercase for component rendering
        return (
          <div class="flex flex-col md:flex-row items-start md:items-center py-10 px-8 border-b border-slate-100 group hover:bg-slate-50/50 transition-colors">
            <div class="w-full md:w-1/3 flex items-center gap-4 mb-4 md:mb-0">
              <Icon size={18} strokeWidth={2.5} className="text-orange-400" />
              <span class="text-lg font-black uppercase tracking-tight text-black">{item.metric}</span>
            </div>

            <div class="w-1/2 md:w-1/6 mb-2 md:mb-0">
              <span class="font-mono text-sm text-slate-500 line-through decoration-slate-400">{item.legacy}</span>
            </div>

            <div class="w-1/2 md:w-1/6 mb-4 md:mb-0">
              <span class="text-2xl font-black text-orange-400 tracking-tighter">{item.stable}</span>
            </div>

            <div class="w-full md:w-1/3 md:text-right">
              <span class="text-xs font-medium text-slate-500 uppercase tracking-widest">{item.logic}</span>
            </div>
          </div>
        );
      })}
    </div>



     <div
      class="relative mt-12 group overflow-hidden rounded-[2.5rem] border border-white/5 bg-[#0a0a0a] p-8 md:p-16 flex flex-col md:flex-row items-center justify-between gap-8 shadow-2xl transition-all duration-500"
    >
      <div
        class="absolute -right-20 -bottom-20 w-80 h-80 bg-orange-400/10 rounded-full blur-[100px] group-hover:bg-orange-400/20 transition-all duration-700"
      >
      </div>
      <div
        class="absolute -left-20 -top-20 w-80 h-80 bg-orange-600/5 rounded-full blur-[100px]"
      >
      </div>

      <div class="text-center md:text-left relative z-10">
        <h3
          class="text-4xl md:text-6xl font-black text-white uppercase tracking-tighter leading-none mb-4"
        >
          Explore the <span class="text-orange-400">Builds.</span>
        </h3>
        <p
          class="text-gray-400 font-mono text-xs uppercase tracking-[0.2em] max-w-md leading-relaxed"
        >
          Access the full technical documentation and architectural performance
          reports.
        </p>
      </div>

      <a
        href="/portfolio"
        class="group/btn relative z-10 inline-flex items-center gap-6 px-12 py-7 bg-orange-400 text-black rounded-full font-black uppercase text-xs tracking-[0.2em] transition-all duration-500 hover:bg-white hover:scale-105 active:scale-95 shadow-[0_20px_40px_-10px_rgba(249,115,22,0.4)]"
      >
        View Portfolio

        <div
          class="transition-transform duration-700 ease-[cubic-bezier(0.68,-0.55,0.27,1.55)] group-hover/btn:[transform:rotate(360deg)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="3"
              d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </div>
      </a>
    </div>

  </div>
</section>

<style>
  h2, span, h4 { -webkit-font-smoothing: antialiased; }
</style>