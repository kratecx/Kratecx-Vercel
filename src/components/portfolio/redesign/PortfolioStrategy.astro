---
import { Image } from "astro:assets";
/**
 * FINAL STRATEGIC AUDIT INTERFACE
 * Refactored: Internal Y-logic, zero-destructuring.
 */
import gear_image from "@/assets/Portfolio/gear_image_w_lines2.png";
import gear_image_2 from "@/assets/Portfolio/gear_final2.png";
// import gear_image_2 from "@/assets/Portfolio/gear_final.png";

interface AuditItem {
  id: string;
  tag: string;
  title: string;
  desc: string;
  // y removed from interface
}

interface Props {
  tagline?: string;
  mainHeadingTop?: string;
  mainHeadingBottom?: string;
  mainDescription?: string;
  auditRegistry?: AuditItem[];
}

// Configuration for spacing
const Y_START = 120; // First item position
const Y_GAP = 200;   // Distance between items
---

<section class="relative w-full lg:min-h-screen bg-[#000000] text-white flex flex-col justify-start overflow-hidden font-sans antialiased">
  
  <div class="mb-6 flex flex-col items-center text-center pt-16 sm:pt-20 lg:pt-12 px-5 sm:px-8" data-reveal>
    <div class="flex items-center justify-center gap-3 sm:gap-4 mb-6 sm:mb-8">
      <span class="h-px w-8 sm:w-10 bg-orange-400 block"></span>
      <p class="font-mono text-[11px] sm:text-[14px] uppercase tracking-[0.35em] sm:tracking-[0.5em] text-orange-400 font-bold">
        {Astro.props.tagline}
      </p>
      <span class="h-px w-8 sm:w-10 bg-orange-400 block"></span>
    </div>

    <h2 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black uppercase tracking-[-0.05em] leading-[0.9] lg:leading-[0.85] text-white">
      {Astro.props.mainHeadingTop} <br />
      <span class="text-orange-400 inline-block mt-2">{Astro.props.mainHeadingBottom}</span>
    </h2>

    <div class="w-40 sm:w-60 h-1 bg-orange-400 my-5 sm:my-6 rounded-full opacity-50"></div>
    
    <p class="text-gray-400 max-w-2xl mx-auto text-base sm:text-lg font-light px-2 sm:px-4">
      {Astro.props.mainDescription}
    </p>
  </div>

  {/* Desktop (original SVG) layout */}
  <div class="relative ps-12 flex-grow hidden lg:flex items-center justify-start py-20 z-20" data-reveal>
    <div class="relative">
        <Image
          src={gear_image}
          alt=""
          width={1000}
          height={667}
          class="h-auto max-w-none w-[1000px] brightness-50 contrast-115"
        />
        <div class="absolute inset-0 bg-gradient-to-r z-0 from-black via-transparent to-black opacity-60"></div>
        
        <div class="absolute inset-0 bg-black opacity-100 w-120 ps-4">
          <Image
            src={gear_image_2}
            width={440}
            height={440}
            class="w-[440px] animate-gear-rotate brightness-50 contrast-105"
            alt="Rotating gear asset"
          />
        </div>
    </div>

    <svg class="absolute left-[300px] w-[1200px] h-[700px] pointer-events-none" viewBox="0 0 1200 700">
      {Astro.props.auditRegistry?.map((node, index) => {
        const calculatedY = Y_START + (index * Y_GAP);
        return (
          <g key={node.id} class="reveal-content">
            <foreignObject x="410" y={calculatedY - 20} width="600" height="150">
              <div class="flex items-center gap-8">
                <div class="flex-shrink-0 w-20 h-20 rounded-full bg-black border-2 border-[#fe8a02] flex items-center justify-center shadow-[0_0_40px_rgba(254,138,2,0.15)] ring-1 ring-[#fe8a02]/30">
                    <div class="flex flex-col items-center leading-none">
                        <span class="text-[10px] font-mono text-[#fe8a02] font-bold tracking-tighter">PHASE</span>
                        <span class="text-white font-black text-2xl italic tracking-tighter">
                          {node.id.includes('-') ? node.id.split('-')[1] : node.id}
                        </span>
                    </div>
                </div>
                
                <div class="flex flex-col space-y-1">
                   <span class="text-[#fe8a02] font-mono text-[9px] tracking-[0.4em] font-black uppercase">
                     {node.tag}
                   </span>
                   <h3 class="text-white text-3xl font-black italic tracking-tighter uppercase leading-none">
                     {node.title}
                   </h3>
                   <p class="text-zinc-500 text-[10px] font-bold tracking-wide uppercase max-w-xs leading-relaxed border-l-2 border-zinc-800 pl-4 mt-2">
                     {node.desc}
                   </p>
                </div>
              </div>
            </foreignObject>
          </g>
        );
      })}
    </svg>
  </div>

  {/* Mobile / tablet stacked layout */}
  <div class="relative lg:hidden px-5 sm:px-8 pt-12 pb-20" data-reveal>
    {/* Decorative rotating gear, subtle */}
    <div class="pointer-events-none absolute -right-20 -top-6 w-[320px] h-[320px] opacity-25 sm:opacity-30">
      <Image
        src={gear_image_2}
        width={440}
        height={440}
        class="w-full h-full animate-gear-rotate brightness-50 contrast-105"
        alt=""
      />
    </div>

    <ol class="relative z-10 max-w-xl mx-auto space-y-8 sm:space-y-10 border-l border-orange-400/25 pl-6 sm:pl-8">
      {Astro.props.auditRegistry?.map((node) => (
        <li class="relative reveal-content">
          <span class="absolute -left-[34px] sm:-left-[42px] top-0 w-14 h-14 sm:w-16 sm:h-16 rounded-full bg-black border-2 border-[#fe8a02] flex items-center justify-center shadow-[0_0_30px_rgba(254,138,2,0.2)] ring-1 ring-[#fe8a02]/30">
            <div class="flex flex-col items-center leading-none">
              <span class="text-[8px] font-mono text-[#fe8a02] font-bold tracking-tighter">PHASE</span>
              <span class="text-white font-black text-lg sm:text-xl italic tracking-tighter">
                {node.id.includes('-') ? node.id.split('-')[1] : node.id}
              </span>
            </div>
          </span>

          <div class="pl-14 sm:pl-16 pt-1 space-y-2">
            <span class="block text-[#fe8a02] font-mono text-[9px] tracking-[0.35em] font-black uppercase">
              {node.tag}
            </span>
            <h3 class="text-white text-2xl sm:text-3xl font-black italic tracking-tighter uppercase leading-[1.05]">
              {node.title}
            </h3>
            <p class="text-zinc-400 text-[11px] sm:text-xs font-bold tracking-wide uppercase leading-relaxed border-l-2 border-zinc-800 pl-4 mt-3">
              {node.desc}
            </p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  /* Same styles as before */
  @import url('https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,900;1,900&family=JetBrains+Mono:wght@700&display=swap');
  section { font-family: 'Inter', sans-serif; }
  span[class*="font-mono"] { font-family: 'JetBrains Mono', monospace; }
  .animate-gear-rotate { animation: gear-spin 60s linear infinite; }
  @keyframes gear-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .reveal-content { opacity: 0; animation: revealIn 0.8s ease-out forwards; }
  .reveal-content:nth-child(1) { animation-delay: 0.2s; }
  .reveal-content:nth-child(2) { animation-delay: 0.4s; }
  .reveal-content:nth-child(3) { animation-delay: 0.6s; }
  @keyframes revealIn { from { opacity: 0; transform: translateX(-20px); } to { opacity: 1; transform: translateX(0); } }
</style>