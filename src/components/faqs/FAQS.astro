---
const categories = [
  {
    name: "Delivery & timelines",
    id: "time",
    faqs: [
      {
        question: "What is a typical project duration?",
        answer:
          "Most engagements run between six and twelve weeks end to end, including discovery, build, and acceptance. Duration depends on scope, integrations, and approval cycles; a detailed schedule is agreed before work begins.",
      },
    ],
  },
  {
    name: "Process & integrations",
    id: "process",
    faqs: [
      {
        question: "Can you connect to our existing CRM or data systems?",
        answer:
          "Yes. We design for integration where required—commonly via REST or vendor APIs—with platforms such as Salesforce, HubSpot, and internal tools. Technical constraints and security requirements are reviewed during discovery.",
      },
      {
        question: "Is ongoing support available after launch?",
        answer:
          "Yes. Maintenance and support can be provided under a defined service level, covering updates, monitoring, and incident response according to the arrangement you select.",
      },
    ],
  },
  {
    name: "Legal & intellectual property",
    id: "legal",
    faqs: [
      {
        question: "Who owns deliverables and intellectual property?",
        answer:
          "Upon completion of the engagement and settlement of fees as contractually specified, ownership of agreed deliverables—including applicable source materials and assets—is assigned to your organization as set out in your statement of work or agreement.",
      },
    ],
  },
];
---

<section
  id="faqs-root"
  class="relative bg-white px-4 pb-20 pt-12 font-sans text-neutral-900 antialiased sm:px-6 sm:pb-24 sm:pt-16 md:px-10 md:pb-28 lg:px-12"
>
  <div class="relative z-10 mx-auto max-w-3xl" data-reveal>
    <nav
      class="flex flex-col gap-3 rounded-2xl border border-neutral-200/90 bg-white/80 px-4 py-4 shadow-sm backdrop-blur-sm sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-2 sm:gap-y-2 sm:px-5"
      aria-label="FAQ sections"
    >
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-neutral-500 sm:mr-2">Jump to</span>
      {categories.map((cat, i) => (
        <>
          {i > 0 && (
            <span class="hidden text-neutral-300 sm:inline" aria-hidden="true">
              ·
            </span>
          )}
          <a
            href={`#${cat.id}`}
            class="text-[13px] font-medium text-neutral-600 transition-colors hover:text-orange-600 sm:text-sm"
          >
            {cat.name}
          </a>
        </>
      ))}
    </nav>

    <div class="mt-12 space-y-14 sm:mt-14 sm:space-y-16 md:space-y-20">
      {categories.map((cat) => (
        <section id={cat.id} class="faq-category scroll-mt-28 sm:scroll-mt-32">
          <h2
            class="mb-6 flex items-center gap-3 text-[13px] font-semibold uppercase tracking-[0.14em] text-neutral-500 sm:mb-8 sm:text-sm"
          >
            <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400" aria-hidden="true"></span>
            {cat.name}
          </h2>

          <ul class="space-y-3" role="list">
            {cat.faqs.map((faq, index) => (
              <li>
                <div
                  class="faq-card group cursor-pointer overflow-hidden rounded-2xl border border-white/10 bg-[#0a0a0a] shadow-md transition-all duration-200 hover:border-orange-400/25"
                  role="button"
                  tabindex="0"
                  aria-expanded="false"
                >
                  <div class="faq-question-row flex items-start gap-4 bg-black px-4 py-5 sm:gap-5 sm:px-6 sm:py-5">
                    <span
                      class="faq-index shrink-0 pt-0.5 font-mono text-[11px] font-semibold tabular-nums text-orange-400 sm:text-xs"
                      aria-hidden="true"
                    >
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <div class="flex min-w-0 flex-1 flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-8">
                      <h3
                        class="text-left text-[15px] font-semibold leading-snug text-white sm:text-base"
                      >
                        {faq.question}
                      </h3>
                      <div
                        class="faq-chevron relative mt-1 flex h-5 w-5 shrink-0 items-center justify-center text-orange-400 sm:mt-0.5"
                        aria-hidden="true"
                      >
                        <span class="absolute h-[1.5px] w-3 bg-current"></span>
                        <span
                          class="faq-chevron-v absolute h-3 w-[1.5px] bg-current transition-transform duration-200"
                        ></span>
                      </div>
                    </div>
                  </div>

                  <div
                    class="faq-content grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out"
                  >
                    <div class="overflow-hidden">
                      <div
                        class="border-t border-white/10 bg-neutral-950 px-4 py-5 pl-[3.25rem] sm:px-6 sm:py-6 sm:pl-[3.75rem]"
                      >
                        <p
                          class="max-w-2xl text-[14px] leading-[1.75] text-zinc-400 sm:text-[15px]"
                        >
                          {faq.answer}
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-content {
    display: grid;
    grid-template-rows: 0fr;
  }

  .faq-card.is-active .faq-content {
    grid-template-rows: 1fr;
  }

  .faq-card.is-active {
    border-color: rgba(251, 146, 60, 0.45);
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.2),
      0 12px 32px -12px rgba(251, 146, 60, 0.25);
  }

  .faq-card.is-active .faq-chevron-v {
    transform: rotate(90deg);
    opacity: 0;
  }

  .faq-card.is-active h3 {
    color: rgb(255 255 255);
  }

  .faq-card.is-active .faq-question-row {
    background-color: rgb(0 0 0);
  }

  .faq-card:focus-visible {
    outline: 2px solid rgb(251 146 60);
    outline-offset: 3px;
  }
</style>

<script>
  (function () {
    const g = globalThis as typeof globalThis & { __kratecsFaqAccordion?: boolean };
    if (g.__kratecsFaqAccordion) return;
    g.__kratecsFaqAccordion = true;

    document.addEventListener("click", (e) => {
      const el = e.target;
      if (!(el instanceof Element)) return;
      const card = el.closest(".faq-card");
      if (!card) return;
      const root = document.getElementById("faqs-root");
      if (!root || !root.contains(card)) return;

      const wasActive = card.classList.contains("is-active");
      root.querySelectorAll(".faq-card").forEach((c) => {
        c.classList.remove("is-active");
        c.setAttribute("aria-expanded", "false");
      });
      if (!wasActive) {
        card.classList.add("is-active");
        card.setAttribute("aria-expanded", "true");
      }
    });

    document.addEventListener("keydown", (e) => {
      const t = e.target;
      if (!(t instanceof HTMLElement) || !t.classList.contains("faq-card")) return;
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        t.click();
      }
    });
  })();
</script>
