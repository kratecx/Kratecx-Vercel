---
/**
 * FAQ page hero — background art from local asset.
 */
import { Image } from "astro:assets";
import questionMarkImg from "../../assets/faqs/faq.png";
---

<section
  class="relative isolate overflow-hidden border-b border-white/10 bg-black px-4 pb-14 pt-28 font-sans antialiased sm:px-6 sm:pb-16 sm:pt-32 md:px-8 md:pb-20 lg:px-10"
  aria-labelledby="faq-hero-title"
>
  <!-- Full-bleed background from CDN -->
  <div
    class="pointer-events-none absolute inset-0 z-0 overflow-hidden select-none"
    aria-hidden="true"
  >
    <Image
      src={questionMarkImg}
      alt=""
      width={1920}
      height={1080}
      decoding="async"
      fetchpriority="high"
      class="faq-hero-bg-img block h-full w-full object-cover object-[50%_35%] md:object-[60%_30%] lg:object-right"
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/45 to-black/20"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/35 via-transparent to-black/55"></div>
  </div>

  <div
    class="pointer-events-none absolute inset-0 z-[1] bg-[radial-gradient(ellipse_85%_55%_at_50%_-10%,rgba(251,146,60,0.12),transparent_58%)]"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto max-w-7xl" data-reveal>
    <div class="mb-6 flex flex-col items-center text-center sm:mb-8">
      <div class="mb-8 w-full max-w-full px-1 text-center leading-snug">
        <span class="mr-2 inline-block h-px w-10 bg-orange-400/60 align-middle sm:mr-4" aria-hidden="true"></span>
        <span
          class="inline-block max-w-[calc(100%-6rem)] align-middle font-mono text-[12px] font-bold uppercase tracking-[0.45em] text-orange-400 sm:max-w-none sm:text-[14px] sm:tracking-[0.5em]"
        >
          Resources
        </span>
        <span class="ml-2 inline-block h-px w-10 bg-orange-400/60 align-middle sm:ml-4" aria-hidden="true"></span>
      </div>

      <h1
        id="faq-hero-title"
        class="max-w-full px-1 text-balance text-5xl font-semibold uppercase leading-[0.9] tracking-[-0.05em] text-white sm:text-6xl md:text-8xl md:leading-[0.95]"
      >
        <span class="block text-white">Frequently Asked</span>
        <span class="mt-2 inline-block text-orange-400">Questions</span>
      </h1>

      <div
        class="mx-auto my-6 h-1 w-60 max-w-[85vw] rounded-full bg-gradient-to-r from-orange-400/70 via-orange-400 to-orange-400/70 sm:my-8"
        aria-hidden="true"
      ></div>

      <p
        class="max-w-3xl px-1 text-balance text-lg font-normal leading-relaxed text-zinc-400"
      >
        Clear, friendly answers on timelines, integrations, support, and ownership—so you always know what to expect.
      </p>
    </div>
  </div>
</section>

<style>
  h1 {
    letter-spacing: -0.05em;
  }

  .faq-hero-bg-img {
    position: absolute;
    inset: 0;
    min-height: 100%;
    min-width: 100%;
    filter: brightness(0.78) contrast(1.05);
  }
</style>
