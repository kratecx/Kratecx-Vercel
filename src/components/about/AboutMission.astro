---
// Mission.astro - Refined Agency Trust Section
---

<section class="relative w-full min-h-screen bg-[#050505] text-white overflow-hidden flex items-center font-sans">

  <!-- Background Effects -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute right-[-10%] top-1/2 -translate-y-1/2 w-[50%] h-[70%] bg-orange-400/[0.08] blur-[120px] rounded-full"></div>
    <div class="absolute left-1/2 top-0 w-[1px] h-full bg-orange-400/10 hidden lg:block"></div>
  </div>

  <div
    class="relative z-10 w-full max-w-[1440px] mx-auto px-6 md:px-12 flex flex-col lg:flex-row items-center gap-16 lg:gap-0"
    data-reveal
  >

    <!-- LEFT SIDE -->
    <div class="w-full lg:w-1/2 lg:pr-20 py-12 reveal-left">
      <div class="space-y-8">

        <!-- Section Label -->
        <div class="flex items-center gap-3">
          <div class="w-10 h-[2px] bg-orange-400/50"></div>
          <span class="text-orange-400 font-mono text-[14px] uppercase tracking-[0.3em]">
            Our Mission
          </span>
        </div>

        <!-- Heading -->
        <h2 class="text-5xl md:text-7xl font-kanit font-semibold leading-[0.85] tracking-tighter uppercase">
          Websites For
          <span class="text-orange-400">Outcomes</span>
        </h2>

        <!-- Description -->
        <p class="text-zinc-400 text-lg md:text-xl leading-relaxed max-w-md font-light">
          We serve structured, high-performance websites focused on trust, clarity, and measurable growth.
        </p>

      </div>
    </div>

    <!-- RIGHT SIDE -->
    <div class="w-full lg:w-1/2 lg:pl-10 py-12 space-y-6">

      <!-- CARD 01 -->
      <div class="trust-card group relative p-8 bg-white/[0.02] border border-white/5 hover:border-orange-400/40 transition-all duration-500">
        <div class="absolute -left-4 top-1/2 -translate-y-1/2 text-6xl font-black text-orange-400/[0.06] group-hover:text-orange-400/10 transition-colors pointer-events-none font-mono">
          01
        </div>
        <div class="relative z-10 flex gap-6">
          <div class="w-1 h-12 bg-orange-400 shadow-[0_0_15px_#f97316]"></div>
          <div class="space-y-2">
            <h3 class="text-2xl font-semibold uppercase tracking-tight text-white/90 group-hover:text-orange-400 transition-colors">
              Precision-Driven Development
            </h3>
            <p class="text-gray-400 text-sm leading-relaxed max-w-sm">
              Clean, structured builds focused on performance, reliability, and long-term stability.
            </p>
          </div>
        </div>
      </div>

      <!-- CARD 02 -->
      <div class="trust-card group relative p-8 bg-white/[0.02] border border-white/5 hover:border-orange-400/40 transition-all duration-500">
        <div class="absolute -left-4 top-1/2 -translate-y-1/2 text-6xl font-black text-orange-400/[0.06] group-hover:text-orange-400/10 transition-colors pointer-events-none font-mono">
          02
        </div>
        <div class="relative z-10 flex gap-6">
          <div class="w-1 h-12 bg-orange-400 shadow-[0_0_15px_#f97316]"></div>
          <div class="space-y-2">
            <h3 class="text-2xl font-semibold uppercase tracking-tight text-white/90 group-hover:text-orange-400 transition-colors">
              User-Focused Experience
            </h3>
            <p class="text-gray-400 text-sm leading-relaxed max-w-sm">
              Interfaces designed to guide users clearly, build trust, and improve conversions.
            </p>
          </div>
        </div>
      </div>

      <!-- CARD 03 -->
      <div class="trust-card group relative p-8 bg-white/[0.02] border border-white/5 hover:border-orange-400/40 transition-all duration-500">
        <div class="absolute -left-4 top-1/2 -translate-y-1/2 text-6xl font-black text-orange-400/[0.06] group-hover:text-orange-400/10 transition-colors pointer-events-none font-mono">
          03
        </div>
        <div class="relative z-10 flex gap-6">
          <div class="w-1 h-12 bg-orange-400 shadow-[0_0_15px_#f97316]"></div>
          <div class="space-y-2">
            <h3 class="text-2xl font-semibold uppercase tracking-tight text-white/90 group-hover:text-orange-400 transition-colors">
              Scalable Systems
            </h3>
            <p class="text-gray-400 text-sm leading-relaxed max-w-sm">
              Future-ready websites built to grow with your business and evolving requirements.
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .reveal-left, .trust-card {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-left.active {
    opacity: 1;
    transform: translateY(0);
  }

  .trust-card.active {
    opacity: 1;
    transform: translateY(0);
  }

  h2, h3 {
    letter-spacing: -0.05em;
  }
</style>

<script>
  const observerOptions = { threshold: 0.2 };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');

        if (entry.target.classList.contains('space-y-6')) {
          const cards = entry.target.querySelectorAll('.trust-card');
          cards.forEach((card, i) => {
            setTimeout(() => card.classList.add('active'), i * 200);
          });
        }
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal-left, .space-y-6').forEach(el =>
    observer.observe(el)
  );
</script>