---
/**
 * Jratecs_Mixed_Text_Mosaic.astro
 * Style: Large Opaque Icons / Mixed Orange-White Typography
 * Feature: Vertical Slide-up reveal with bullet points on hover
 */
import { Target, Zap, Shield, Activity, BarChart3, ArrowUpRight } from 'lucide-react';

const values = [
  {
    title: "Growth",
    highlight: "Systems",
    desc: "We build structured digital systems designed to generate consistent leads and long-term business growth.",
    bullets: ["Market Positioning", "Scalable Web Architecture", "Revenue-Focused Strategy"],
    icon: Target,
    width: "md:col-span-8", 
    img: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1200"
  },
  {
    title: "Performance",
    highlight: "Engineering",
    desc: "Every website is optimized for speed, responsiveness, and measurable conversion performance.",
    bullets: ["Core Web Vitals Optimization", "Fast Load Architecture", "Conversion-Ready UX"],
    icon: Zap,
    width: "md:col-span-4",
    img: "https://images.unsplash.com/photo-1504384308090-c894fdcc538d?q=80&w=1200"
  },
  {
    title: "Trust",
    highlight: "Integrity",
    desc: "We prioritize clarity, transparency, and credibility to build user trust and business authority.",
    bullets: ["Clean UI Systems", "Transparent Structure", "Reliable User Experience"],
    icon: Shield,
    width: "md:col-span-4",
    img: "https://images.unsplash.com/photo-1558494949-ef010cbdcc51?q=80&w=1200" 
  },
  {
    title: "Execution",
    highlight: "Speed",
    desc: "Fast, structured delivery with clear workflows from idea to fully functional product.",
    bullets: ["Agile Development Process", "Structured Milestones", "Rapid Deployment Cycles"],
    icon: Activity,
    width: "md:col-span-4",
    img: "https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=1200"
  },
  {
    title: "Data",
    highlight: "Driven Metrics",
    desc: "We design and optimize based on data, not assumptions — ensuring measurable business outcomes.",
    bullets: ["Conversion Tracking", "User Behavior Analysis", "Performance Optimization"],
    icon: BarChart3,
    width: "md:col-span-4",
    img: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=1200"
  }
];
---

<section class="w-full bg-white px-4 sm:px-6 pb-16 font-sans antialiased text-black">
  <div class="max-w-7xl mx-auto">

        <div class="max-w-7xl mx-auto mb-14 sm:mb-20 md:mb-24 relative z-10 text-center">
      <div class="flex items-center justify-center gap-2 sm:gap-4 mb-8">
        <span class="h-0.5 w-10 bg-orange-400"></span>
        <p class="font-mono text-[12px] sm:text-sm uppercase tracking-[0.35em] sm:tracking-[0.5em] text-orange-400 font-bold">Our Values</p>
        <span class="h-0.5 w-10 bg-orange-400"></span>
      </div>

      <div class="flex flex-col justify-center items-center">
        <h2 class="text-5xl sm:text-6xl md:text-8xl font-[900] text-black uppercase tracking-tighter leading-[0.9] md:leading-[0.85] text-balance max-w-full">
          Core <span class="text-orange-400">Principles </span> 
        </h2>
        <div class="w-60 h-1 bg-orange-400 my-6 rounded-full opacity-50"></div>
        <p class="text-gray-500 max-w-2xl mx-auto text-base sm:text-lg md:text-xl font-light leading-relaxed text-balance">
          We follow defined principles for turning web design into measurable business performance, user engagement, and consistent lead generation.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
        {values.map((item, index) => (
            <div class={`group relative ${item.width} h-auto min-h-[420px] md:h-[480px] overflow-hidden rounded-2xl sm:rounded-3xl bg-black cursor-default`}>
                
                <div class="absolute inset-0 z-0">
                    <img 
                        src={item.img} 
                        alt={item.title} 
                        class="w-full h-full object-cover grayscale brightness-50 contrast-125 transition-all duration-700 opacity-45 md:opacity-70 md:group-hover:scale-110 md:group-hover:opacity-30"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
                </div>

                <div class="absolute right-[-8%] sm:right-[-5%] bottom-[-8%] sm:bottom-[-5%] z-10 opacity-10 text-orange-400 rotate-12 transition-all duration-1000 md:group-hover:scale-110 md:group-hover:opacity-20 md:group-hover:-rotate-6">
                    <item.icon className="w-44 h-44 sm:w-56 sm:h-56 md:w-[280px] md:h-[280px]" strokeWidth={0.5} />
                </div>

                <div class="absolute inset-0 z-20 p-5 sm:p-7 md:p-10 flex flex-col justify-end">
                    
                    <div class="translate-y-0 md:translate-y-[120px] md:group-hover:translate-y-0 transition-all duration-900 ease-[cubic-bezier(0.23,1,0.32,1)]">
                        
                        <div class="mb-4">
                            <span class="font-mono text-[10px] font-bold text-orange-400 tracking-[0.3em] uppercase bg-white/5 backdrop-blur-md px-3 py-1.5 rounded-full border border-white/10">
                                PILLAR {index + 1}
                            </span>
                        </div>

                        <h3 class="text-2xl sm:text-3xl md:text-4xl font-black uppercase tracking-tight text-white mb-3">
                            {item.title} <span class="text-orange-400">{item.highlight}</span>
                        </h3>

                        <p class="text-white/70 text-sm font-medium tracking-wide leading-relaxed max-w-md">
                            {item.desc}
                        </p>

                        <div class="mt-6 md:mt-8 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-700 delay-100">
                           <ul class="space-y-3">
                              {item.bullets.map((bullet) => (
                                <li class="flex items-center gap-3 text-white/90 font-mono text-[11px] uppercase tracking-wider">
                                  <span class="h-1.5 w-1.5 bg-orange-400 rounded-full"></span>
                                  {bullet}
                                </li>
                              ))}
                           </ul>
                           
                           <div class="mt-6 md:mt-8 h-[2px] w-full md:w-12 bg-orange-400 transition-all duration-500 md:group-hover:w-full"></div>
                        </div>
                    </div>
                </div>
            </div>
        ))}
    </div>

    <div class="mt-12 sm:mt-16 group relative bg-black p-6 sm:p-8 md:p-12 rounded-2xl sm:rounded-3xl flex flex-col md:flex-row items-center justify-between gap-6 sm:gap-8 border border-orange-400/20 overflow-hidden">
        <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-orange-400/5 blur-[100px] rounded-full md:group-hover:bg-orange-400/10 transition-colors duration-700"></div>

        <div class="max-w-xl relative z-10 text-center md:text-left">
            <h4 class="text-white font-black font-inter text-3xl sm:text-4xl md:text-5xl uppercase mb-2 text-balance">
                Ready For <span class="text-orange-400">Growth?</span>
            </h4>
            <p class="text-white/50 text-xs font-poppins uppercase tracking-widest font-bold">
                 Let’s build a website that <span class="text-white">drives trust</span> and <span class="text-orange-400">business results</span>.
            </p>
        </div>
        
        <div class="relative group/cta w-full md:w-auto max-w-full">
          <div class="absolute -inset-1 bg-orange-400/20 blur-xl opacity-0 transition-opacity duration-500 group-hover/cta:opacity-100"></div>
          <div class="relative rounded-full p-px overflow-hidden bg-gradient-to-r from-white/10 via-orange-400/50 to-white/10">
            <a
              href="/contact"
              class="relative flex max-w-full items-center gap-4 rounded-full bg-[#0a0a0a] px-3 py-3 transition-all duration-300 hover:bg-black sm:gap-6 sm:px-4"
            >
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-orange-400 text-black shadow-[0_0_18px_rgba(251,133,0,0.35)] transition-transform duration-700 group-hover/cta:rotate-[360deg]">
                <ArrowUpRight className="w-6 h-6" strokeWidth={3} />
              </div>
              <div class="min-w-0 pr-3 text-left sm:pr-6">
                <p class="mb-0.5 text-[10px] font-black uppercase tracking-[.25em] text-orange-400">Ready to Grow?</p>
                <span class="text-white font-bold text-lg tracking-tight whitespace-normal sm:whitespace-nowrap">Let's Build Your Website</span>
              </div>
            </a>
          </div>
        </div>
    </div>

  </div>
</section>

<style>
  section {
    -webkit-font-smoothing: antialiased;
  }

  ::selection {
    background: #FB923C;
    color: #000;
  }
</style>