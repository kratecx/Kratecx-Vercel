---
// Journey.astro - Structured Agency Journey
---

<section
  class="relative w-full py-16 sm:py-20 md:py-32 bg-[#050505] text-white overflow-hidden font-sans"
>
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60%] h-[60%] bg-orange-400/10 blur-[260px] rounded-full"
    ></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6" data-reveal>

    <!-- HEADER -->
    <div class="mb-14 sm:mb-20 md:mb-28 flex flex-col text-center items-center">

      <div class="flex items-center justify-center gap-4 mb-8">
        <span class="h-0.5 w-10 bg-orange-400"></span>
        <p class="font-mono text-sm uppercase tracking-[0.3em] text-orange-400 font-bold">
          Our Journey
        </p>
        <span class="h-0.5 w-10 bg-orange-400"></span>
      </div>

      <h2 class="text-5xl sm:text-6xl md:text-8xl font-inter font-black uppercase tracking-[-0.03em] leading-[0.9] md:leading-[0.85] text-white text-balance max-w-full">
        The Evolution of <br />
        <span class="text-orange-400 inline-block mt-2">Our Approach</span>
      </h2>

      <div class="w-60 h-1 bg-orange-400 rounded-full my-6 opacity-50"></div>

      <p class="text-zinc-400 max-w-2xl mx-auto text-base sm:text-lg font-light text-balance">
        Our journey reflects how we evolved over time, refined our process, and built a team focused on delivering meaningful outcomes for every client.
      </p>
    </div>

    <!-- TIMELINE -->
    <div class="relative">

      <!-- CENTER LINE -->
      <div
        class="absolute left-2 sm:left-3 md:left-1/2 top-0 w-[1px] h-full bg-gradient-to-b from-orange-400/50 via-white/10 to-transparent -translate-x-1/2"
      ></div>

      <div class="space-y-12 sm:space-y-16 md:space-y-24">

        <!-- STEP 01 -->
        <div class="relative flex flex-col md:flex-row items-start md:items-center justify-between journey-item pl-7 sm:pl-9 md:pl-0">

          <div class="w-full md:w-[45%] mb-6 md:mb-0 text-left md:text-right">
            <span class="text-orange-400 font-mono text-xs">Discovery Phase</span>
            <h4 class="text-xl sm:text-2xl font-bold uppercase mt-2">Business & Growth Analysis</h4>
            <p class="text-gray-500 mt-4 text-sm leading-relaxed">
              We evaluate your business goals, audience, market position, and current website performance to define clear growth opportunities.
            </p>
          </div>

          <div class="absolute left-2 sm:left-3 md:left-1/2 top-2 md:top-auto -translate-x-1/2 w-3 h-3 bg-orange-400 rounded-full shadow-[0_0_15px_#f97316] z-20"></div>

          <div class="w-full md:w-[45%]"></div>
        </div>

        <!-- STEP 02 -->
        <div class="relative flex flex-col md:flex-row items-start md:items-center justify-between journey-item pl-7 sm:pl-9 md:pl-0">

          <div class="w-full md:w-[45%] order-2 md:order-1"></div>

          <div class="absolute left-2 sm:left-3 md:left-1/2 top-2 md:top-auto -translate-x-1/2 w-3 h-3 bg-white rounded-full z-20"></div>

          <div class="w-full md:w-[45%] order-1 md:order-2">
            <span class="text-orange-400 font-mono text-xs">Strategy Phase</span>
            <h4 class="text-xl sm:text-2xl font-bold uppercase mt-2">Positioning & Website Blueprint</h4>
            <p class="text-gray-500 mt-4 text-sm leading-relaxed">
              We create the right structure, messaging direction, and conversion path so your website supports business growth from day one.
            </p>
          </div>
        </div>

        <!-- STEP 03 -->
        <div class="relative flex flex-col md:flex-row items-start md:items-center justify-between journey-item pl-7 sm:pl-9 md:pl-0">

          <div class="w-full md:w-[45%] text-left md:text-right">
            <span class="text-orange-400 font-mono text-xs">Execution Phase</span>
            <h4 class="text-xl sm:text-2xl font-bold uppercase mt-2">Design & Development Delivery</h4>
            <p class="text-gray-500 mt-4 text-sm leading-relaxed">
              We design and develop a high-performance, scalable website aligned with your brand, offers, and long-term business objectives.
            </p>
          </div>

          <div class="absolute left-2 sm:left-3 md:left-1/2 top-2 md:top-auto -translate-x-1/2 w-3 h-3 bg-orange-400 rounded-full shadow-[0_0_15px_#f97316] z-20"></div>

          <div class="w-full md:w-[45%]"></div>
        </div>

        <!-- STEP 04 -->
        <div class="relative flex flex-col md:flex-row items-start md:items-center justify-between journey-item pl-7 sm:pl-9 md:pl-0">

          <div class="w-full md:w-[45%] order-2 md:order-1"></div>

          <div class="absolute left-2 sm:left-3 md:left-1/2 top-2 md:top-auto -translate-x-1/2 w-3 h-3 bg-white rounded-full z-20"></div>

          <div class="w-full md:w-[45%] order-1 md:order-2">
            <span class="text-orange-400 font-mono text-xs">Optimization Phase</span>
            <h4 class="text-xl sm:text-2xl font-bold uppercase mt-2">Conversion & Performance Optimization</h4>
            <p class="text-gray-500 mt-4 text-sm leading-relaxed">
              We refine speed, UX, trust signals, and key conversion elements so the website performs reliably as your business scales.
            </p>
          </div>
        </div>

        <!-- STEP 05 -->
        <div class="relative flex flex-col md:flex-row items-start md:items-center justify-between journey-item pl-7 sm:pl-9 md:pl-0">

          <div class="w-full md:w-[45%] text-left md:text-right">
            <span class="text-orange-400 font-mono text-xs">Growth Phase</span>
            <h4 class="text-xl sm:text-2xl font-bold uppercase mt-2">Launch, Support & Scale</h4>
            <p class="text-gray-500 mt-4 text-sm leading-relaxed">
              We launch with confidence, then support ongoing improvements so your website keeps generating leads and enabling sustainable growth.
            </p>
          </div>

          <div class="absolute left-2 sm:left-3 md:left-1/2 top-2 md:top-auto -translate-x-1/2 w-3 h-3 bg-orange-400 rounded-full shadow-[0_0_15px_#f97316] z-20"></div>

          <div class="w-full md:w-[45%]"></div>
        </div>

      </div>
    </div>

    <!-- FINAL CTA -->
    <div
      class="mt-16 sm:mt-24 md:mt-40 p-6 sm:p-8 md:p-12 backdrop-blur-sm text-center relative overflow-hidden"
    >
      <div
        class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-orange-400/50 to-transparent"
      ></div>

      <h4 class="text-xl sm:text-2xl font-bold mb-6 italic text-balance">
        "A professional website is not just a design asset; it is a growth system for trust, leads, and long-term scale."
      </h4>

      <p class="text-zinc-400 mb-8 max-w-lg mx-auto text-sm text-balance">
        As a professional agency, we build business websites with a structured approach focused on performance, conversion, and scalable growth.
      </p>

      <div class="relative group p-[1px] rounded-full overflow-hidden bg-gradient-to-r from-white/10 via-[#FB8500]/50 to-white/10 inline-block">

        <div class="absolute -inset-1 bg-[#FB8500]/20 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

        <a
          href="/contact"
          class="relative flex items-center gap-6 px-4 py-3 bg-[#0a0a0a] rounded-full hover:bg-black transition-all duration-300"
        >
          <div
            class="w-12 h-12 rounded-full bg-[#FB8500] flex items-center justify-center text-black shadow-[0_0_15px_rgba(251,133,0,0.4)] group-hover:rotate-[360deg] transition-transform duration-700"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
            </svg>
          </div>

          <div class="pr-4 text-left">
            <p class="text-[9px] font-black tracking-[.3em] text-[#FB8500] uppercase mb-0.5">
              Ready to Grow?
            </p>
            <span class="text-white font-bold text-lg tracking-tight block">
              Let's Build Your Website
            </span>
          </div>
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .journey-item {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .journey-item.active {
    opacity: 1;
    transform: translateY(0);
  }

  h3 {
    text-wrap: balance;
  }
</style>

<script>
  const journeyObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("active");
        }
      });
    },
    { threshold: 0.3 }
  );

  document
    .querySelectorAll(".journey-item")
    .forEach((el) => journeyObserver.observe(el));
</script>