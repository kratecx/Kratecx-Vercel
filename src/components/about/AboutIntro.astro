---
import { Image } from "astro:assets";
import heroImage from "../../assets/about/kratecx_full.svg";

const aboutIntroBg =
  "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&q=80&w=2070";
---

<section class="relative w-full bg-[#050505] overflow-hidden pt-24 pb-12 sm:pt-28 sm:pb-16 md:pt-32 md:pb-20 lg:pt-30">
  <div class="absolute inset-0 z-0">
    <Image
      src={aboutIntroBg}
      alt=""
      width={2070}
      height={1380}
      class="h-full w-full object-cover opacity-20 grayscale"
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a]/80 via-[#0a0a0a]/40 to-[#0a0a0a]"></div>
  </div>

  <div class="relative z-10 mx-auto w-full max-w-5xl px-4 sm:px-6 text-center" data-reveal>
    <div class="mb-6 flex items-center justify-center gap-2 sm:gap-4">
      <span class="h-px w-6 sm:w-8 bg-orange-500/60" aria-hidden="true"></span>
      <span class="font-mono text-xs sm:text-sm uppercase tracking-[0.3em] sm:tracking-[0.5em] text-orange-400 font-bold">
        About Kratex
      </span>
      <span class="h-px w-6 sm:w-8 bg-orange-500/60" aria-hidden="true"></span>
    </div>

    <div class="mx-auto mb-6 sm:mb-10 w-full max-w-3xl">
      <Image
        src={heroImage}
        width={1640}
        height={342}
        alt="KRATEX full logo"
        class="h-auto w-full object-contain"
      />
    </div>

    <div class="mx-auto mb-6 h-1 w-40 sm:w-60 rounded-full bg-orange-400/60"></div>

    <p class="mx-auto max-w-2xl text-sm sm:text-base md:text-lg lg:text-xl leading-relaxed font-light text-zinc-300">
      We design and develop websites that help businesses generate qualified leads, establish credibility, and scale with confidence through performance-driven execution.
    </p>

    <div class="mt-8 flex justify-center">
      <a
        href="/contact"
        class="group inline-flex items-center gap-3 sm:gap-4 rounded-full bg-[#0a0a0a] border border-white/10 pl-2 pr-5 py-2 sm:pl-3 sm:pr-8 sm:py-3 hover:border-orange-500/50 transition-colors duration-300"
      >
        <span class="flex h-10 w-10 sm:h-12 sm:w-12 shrink-0 items-center justify-center rounded-full bg-orange-400 text-black group-hover:rotate-45 transition-transform duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 sm:h-6 sm:w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 17l10-10M7 7h10v10"/>
          </svg>
        </span>
        <span class="flex flex-col text-left">
          <span class="text-[10px] font-bold tracking-[0.25em] text-orange-400 uppercase">Ready to Grow?</span>
          <span class="text-sm sm:text-base md:text-lg font-bold tracking-tight text-white">Let's Build Your Website</span>
        </span>
      </a>
    </div>
  </div>
</section>
