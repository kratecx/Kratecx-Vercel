---
/**
 * ServiceHero.astro
 * Aesthetic: Industrial Infrastructure / High-Contrast Black
 */
import { Image } from "astro:assets";

interface Props {
  title: string;       // e.g., "BACKEND"
  subtitle?: string;    // e.g., "ENGINEERING"
  tag?: string;         // e.g., "SYSTEM_ARCHITECTURE"
  description: string;
  mainImage: ImageMetadata;
  imageAlt?: string;
  primaryCTA?: { text: string; link: string };
}

const { 
  title, 
  subtitle,
  tag = "OPERATIONAL_PROTOCOL",
  description, 
  mainImage,
  imageAlt = "Technical Infrastructure",
  primaryCTA = { text: "Initiate Deployment", link: "#initiate" }
} = Astro.props;
---

<section class="relative flex min-h-0 overflow-hidden bg-black pb-12 pt-24 font-sans sm:pb-16 sm:pt-28 md:min-h-[85vh] md:pb-20 lg:min-h-screen lg:pt-16">
  <div class="absolute inset-0 z-0 bg-[radial-gradient(#ffffff0a_1px,transparent_1px)] [background-size:40px_40px]"></div>

  <div class="relative z-10 mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-12 xl:px-16">
    <div class="grid grid-cols-1 items-start gap-10 lg:grid-cols-2 lg:gap-14 xl:gap-20">
      <div class="reveal space-y-6 sm:space-y-8 lg:space-y-10">
        <div class="inline-flex items-center gap-3 sm:gap-4">
          <div class="h-px w-6 bg-orange-400 sm:w-8"></div>
          <span class="text-[9px] font-bold uppercase tracking-[0.35em] text-orange-400 sm:text-[10px] sm:tracking-[0.45em] md:tracking-[0.5em]"
            >{tag}</span
          >
        </div>

        <h1
          class="mb-4 text-4xl font-black uppercase leading-[0.85] tracking-tighter text-white sm:mb-6 sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl 2xl:text-[110px]"
        >
          {title}
          <br />
          {subtitle && <span class="text-orange-400">{subtitle}</span>}
        </h1>

        <p
          class="max-w-md border-l border-zinc-800 pl-4 text-sm font-medium leading-relaxed text-zinc-500 sm:pl-6 sm:text-base md:pl-8"
        >
          {description}
        </p>

        <div
          class="group relative inline-block max-w-full overflow-hidden rounded-full bg-linear-to-r from-white/5 via-orange-500/50 to-white/5 p-[1.5px] shadow-2xl"
        >
          <div
            class="absolute -inset-2 opacity-0 blur-2xl transition-opacity duration-500 group-hover:opacity-100 bg-orange-500/10"
          ></div>

          <a
            href={primaryCTA.link}
            class="relative flex max-w-full items-center justify-between gap-4 rounded-full bg-[#0a0a0a] py-3 pl-3 pr-5 transition-all duration-300 hover:bg-black sm:gap-8 sm:py-3.5 sm:pl-4 sm:pr-8 md:pr-10"
          >
            <div
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-orange-400 text-black shadow-[0_0_20px_rgba(251,133,0,0.3)] transition-transform duration-700 group-hover:rotate-180 sm:h-14 sm:w-14"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 sm:h-7 sm:w-7"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </div>

            <div class="min-w-0 flex-1 text-left">
              <p class="mb-0.5 text-[9px] font-black uppercase tracking-[0.25em] text-orange-400 sm:text-[11px] sm:tracking-[.3em]">
                Ready to Scale?
              </p>
              <span
                class="block truncate text-base font-bold tracking-tight text-white sm:text-lg md:text-xl whitespace-normal"
              >
                {primaryCTA.text}
              </span>
            </div>
          </a>
        </div>
      </div>

      <div class="reveal-image relative min-h-[220px] w-full sm:min-h-[280px] lg:min-h-0 lg:h-full">
        <div class="image-mask pointer-events-none absolute inset-0 z-10"></div>
        <Image
          src={mainImage}
          alt={imageAlt}
          class="h-full min-h-[220px] w-full object-cover brightness-70 contrast-105 sm:min-h-[280px] lg:min-h-[320px] lg:rounded-sm"
        />
        
        <!-- <div class="absolute top-0 right-0 w-32 h-32 border-t border-r border-orange-400/30 z-20"></div>
        <div class="absolute bottom-0 left-0 w-32 h-32 border-b border-l border-orange-400/30 z-20"></div> -->
      </div>

    </div>
  </div>
</section>

<style>
  /* Seamless Blending Mask */
  .image-mask {
    background: linear-gradient(to right, #000 0%, transparent 20%, transparent 80%, #000 100%),
                linear-gradient(to bottom, #000 0%, transparent 15%, transparent 85%, #000 100%);
  }

  .reveal {
    opacity: 0;
    transform: translateX(-40px);
    transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-image {
    opacity: 0;
    transform: scale(1.05);
    transition: all 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.active, .reveal-image.active {
    opacity: 1;
    transform: translate(0) scale(1);
  }
</style>

<script is:inline>
  function initHeroReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1 });
    
    document.querySelectorAll('.reveal, .reveal-image').forEach(el => observer.observe(el));
  }
  document.addEventListener('DOMContentLoaded', initHeroReveal);
  document.addEventListener('astro:page-load', initHeroReveal);
</script>