---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

type CaseStudy = {
  tag: string;
  title: string;
  desc: string;
  image: string | ImageMetadata;
  link: string;
};

interface Props {
  title?: string;
  titleAccent?: string;
  eyebrow?: string;
  intro?: string;
  projects: CaseStudy[];
}

const {
  title = "Digital",
  titleAccent = "Mastery",
  eyebrow = "Case Studies",
  intro = "A selection of projects focused on improving performance, building trust, and driving measurable business growth.",
  projects,
} = Astro.props;

if (!projects?.length) {
  throw new Error("ServiceCaseStudies: `projects` is required and must not be empty.");
}

const sectionId = "service-case-studies-carousel";
---

<section
  class="relative overflow-hidden bg-white py-16 sm:py-20 md:py-24"
  id={sectionId}
  aria-label="Case studies"
>
  <div
    id="service-case-zone-left"
    class="absolute left-0 top-0 z-30 hidden h-full w-[12%] cursor-w-resize sm:w-[15%] md:block"
    aria-hidden="true"
  ></div>
  <div
    id="service-case-zone-right"
    class="absolute right-0 top-0 z-30 hidden h-full w-[12%] cursor-e-resize sm:w-[15%] md:block"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto mb-12 max-w-7xl px-4 text-center sm:mb-16 md:mb-20 sm:px-6" data-reveal>
    <div class="mb-8 w-full max-w-full px-1 text-center leading-snug">
      <span class="mr-2 inline-block h-0.5 w-10 align-middle bg-orange-400 sm:mr-4" aria-hidden="true"></span>
      <span
        class="inline-block max-w-[calc(100%-6rem)] align-middle font-mono text-sm font-bold uppercase tracking-[0.5em] text-orange-400 sm:max-w-none"
      >
        {eyebrow}
      </span>
      <span class="ml-2 inline-block h-0.5 w-10 align-middle bg-orange-400 sm:ml-4" aria-hidden="true"></span>
    </div>

    <div class="flex flex-col items-center justify-center">
      <h2
        class="max-w-full px-1 text-balance text-5xl font-semibold uppercase leading-[0.9] tracking-tighter text-black sm:text-6xl md:text-8xl md:leading-[0.85]"
      >
        <span class="text-black">{title}</span>{" "}
        <span class="text-orange-400">{titleAccent}</span>
      </h2>

      <div class="mx-auto my-6 h-1 w-60 max-w-[85vw] rounded-full bg-orange-400 opacity-50"></div>

      <p class="mx-auto max-w-2xl px-1 text-lg font-light text-balance text-gray-800">
        {intro}
      </p>
    </div>

    <p class="mb-3 font-mono text-[9px] font-bold uppercase tracking-[0.4em] text-black/25 md:hidden" aria-hidden="true">
      Swipe to browse
    </p>

    <div
      class="mt-10 flex flex-wrap justify-center gap-2 px-2 sm:mt-14 sm:gap-4 md:mt-16"
      id="service-case-indicators"
      aria-hidden="true"
    >
      {
        projects.map((_, i) => (
          <div class="service-carousel-indicator h-1 w-14 max-w-[28vw] overflow-hidden rounded-full bg-black/5 sm:w-20">
            <div
              class="service-indicator-progress h-full w-0 bg-[#FB8500] transition-all duration-500"
              data-i={i}
            />
          </div>
        ))
      }
    </div>
  </div>

  <!-- Small screens: same snap row as home Featured -->
  <div
    id="service-case-mobile-scroll"
    data-reveal
    class="service-case-mobile-strip flex gap-3 overflow-x-auto pb-3 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden -mx-4 snap-x snap-mandatory scroll-smooth scroll-pl-4 scroll-pr-4 px-4 md:hidden"
    tabindex="0"
    aria-label="Case studies — swipe horizontally"
  >
    {
      projects.map((project, i) => (
        <article
          class="service-case-mobile-card w-[min(19.5rem,calc(100vw-2rem))] shrink-0 snap-start"
          data-slide-index={i}
        >
          <div class="group relative aspect-[4/5] overflow-hidden rounded-2xl border border-black/5 bg-black shadow-xl sm:aspect-video sm:rounded-[2rem]">
            {typeof project.image === "string" ? (
              <img
                src={project.image}
                alt={project.title}
                width={1200}
                height={675}
                class="h-full w-full object-cover opacity-90 transition-transform duration-700 group-hover:scale-105"
                loading={i === 0 ? "eager" : "lazy"}
                decoding="async"
              />
            ) : (
              <Image
                src={project.image as ImageMetadata}
                alt={project.title}
                width={1200}
                height={675}
                class="h-full w-full object-cover opacity-90 transition-transform duration-700 group-hover:scale-105"
                loading={i === 0 ? "eager" : "lazy"}
                decoding="async"
              />
            )}
            <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-black via-black/50 to-transparent p-4 sm:p-5">
              <p class="mb-2 text-[10px] font-black uppercase tracking-[0.35em] text-[#FB8500]">{project.tag}</p>
              <h3 class="mb-2 text-2xl font-semibold uppercase leading-none tracking-tighter text-balance text-white sm:text-3xl">
                {project.title}
              </h3>
              <p class="mb-4 line-clamp-2 text-sm font-medium leading-relaxed text-balance text-white/75">
                {project.desc}
              </p>
              <div class="group relative w-full max-w-full overflow-hidden rounded-full bg-gradient-to-r from-black/10 via-orange-400/50 to-black/10 p-px">
                <div class="absolute -inset-1 opacity-0 blur-xl transition-opacity duration-500 group-hover:opacity-100 bg-orange-400/20" />
                <a
                  href={project.link}
                  class="relative flex w-full max-w-full items-center gap-3 rounded-full bg-[#0a0a0a] px-3 py-2.5 transition-all duration-300 hover:bg-black sm:gap-4 sm:px-4 sm:py-3"
                >
                  <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-orange-400 text-white shadow-[0_0_15px_rgba(251,133,0,0.4)] transition-transform duration-700 group-hover:rotate-[360deg] sm:h-10 sm:w-10">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="size-[18px] sm:size-5"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </svg>
                  </div>
                  <div class="min-w-0 flex-1 pr-1 text-left">
                    <p class="mb-0.5 text-[9px] font-black uppercase tracking-[.22em] text-orange-400 sm:text-[10px] sm:tracking-[.25em]">
                      Project Preview
                    </p>
                    <span class="block text-sm font-bold leading-tight tracking-tight text-white sm:text-base">
                      View Case Study
                    </span>
                  </div>
                </a>
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </div>

  <!-- md+: home Featured carousel sizing -->
  <div class="relative hidden w-full overflow-visible md:block" data-reveal>
    <div
      id="service-apple-track"
      class="flex items-center transition-transform duration-1000 ease-[cubic-bezier(0.23,1,0.32,1)]"
    >
      {
        projects.map((project, i) => (
          <div
            class="service-apple-card min-w-[75vw] px-2 transition-all duration-1000 sm:px-4 lg:min-w-[70vw]"
            data-index={i}
          >
            <div class="group relative aspect-video overflow-hidden rounded-[3rem] border border-black/5 bg-black shadow-2xl">
              {typeof project.image === "string" ? (
                <img
                  src={project.image}
                  alt={project.title}
                  width={1200}
                  height={675}
                  class="h-full w-full object-cover opacity-50 grayscale-[0.2] transition-transform duration-1000 group-hover:scale-105"
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
              ) : (
                <Image
                  src={project.image as ImageMetadata}
                  alt={project.title}
                  width={1200}
                  height={675}
                  class="h-full w-full object-cover opacity-50 grayscale-[0.2] transition-transform duration-1000 group-hover:scale-105"
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
              )}

              <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-black via-black/20 to-transparent p-8 md:p-12 lg:p-20">
                <p class="mb-3 text-[10px] font-black uppercase tracking-[0.4em] text-[#FB8500] sm:mb-4 md:text-xs">
                  {project.tag}
                </p>
                <h3 class="mb-6 text-5xl font-semibold uppercase leading-none tracking-tighter text-balance text-white sm:mb-8 md:text-8xl">
                  {project.title}
                </h3>

                <div class="service-apple-reveal translate-y-10 opacity-0 transition-all delay-300 duration-700">
                  <p class="mb-8 max-w-2xl text-balance text-lg font-medium leading-relaxed text-white/70 sm:mb-12 md:text-2xl">
                    {project.desc}
                  </p>
                  <div class="group relative w-full max-w-md overflow-hidden rounded-full bg-gradient-to-r from-white/10 via-orange-400/50 to-white/10 p-px lg:max-w-lg">
                    <div class="absolute -inset-1 opacity-0 blur-xl transition-opacity duration-500 group-hover:opacity-100 bg-orange-400/20" />
                    <a
                      href={project.link}
                      class="relative flex max-w-full items-center gap-4 rounded-full bg-[#0a0a0a] px-3 py-3 transition-all duration-300 hover:bg-black sm:gap-6 sm:px-4 lg:px-6 lg:py-4"
                    >
                      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-orange-400 text-white shadow-[0_0_15px_rgba(251,133,0,0.4)] transition-transform duration-700 group-hover:rotate-[360deg] lg:h-14 lg:w-14">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="size-6 lg:size-7"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="M5 12h14" />
                          <path d="m12 5 7 7-7 7" />
                        </svg>
                      </div>
                      <div class="min-w-0 pr-3 text-left sm:pr-6">
                        <p class="mb-0.5 text-[10px] font-black uppercase tracking-[.25em] text-orange-400 lg:text-[11px]">
                          Project Preview
                        </p>
                        <span class="text-lg font-bold tracking-tight text-white whitespace-normal sm:whitespace-nowrap lg:text-xl">
                          View Case Study
                        </span>
                      </div>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-apple-card {
    opacity: 0.15;
    transform: scale(0.85);
    filter: blur(8px);
    pointer-events: none;
    transition: all 1.2s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .service-apple-card.is-active {
    opacity: 1;
    transform: scale(1);
    filter: blur(0);
    pointer-events: auto;
  }

  .service-apple-card.is-active .service-apple-reveal {
    opacity: 1;
    transform: translateY(0);
  }

  .service-indicator-progress.is-active {
    width: 100%;
  }

  #service-apple-track {
    will-change: transform;
    display: flex;
    align-items: center;
  }

  .service-case-mobile-strip:focus-visible {
    outline: 2px solid rgb(251 146 60 / 0.6);
    outline-offset: 4px;
  }
</style>

<script>
  const SECTION = "#service-case-studies-carousel";

  function initServiceCaseHoverCarousel() {
    const track = document.getElementById("service-apple-track");
    const cards = document.querySelectorAll(`${SECTION} .service-apple-card`);
    const indicators = document.querySelectorAll(`${SECTION} .service-indicator-progress`);
    const zoneLeft = document.getElementById("service-case-zone-left");
    const zoneRight = document.getElementById("service-case-zone-right");

    let currentIndex = 0;
    let isMoving = false;
    let interval: ReturnType<typeof setInterval> | null = null;

    function desktopActive() {
      return window.matchMedia("(min-width: 768px)").matches;
    }

    function updateCarousel() {
      if (!track || cards.length === 0 || !desktopActive()) return;
      isMoving = true;

      const viewportCenter = window.innerWidth / 2;
      const currentCard = cards[currentIndex] as HTMLElement;
      if (!currentCard) return;
      const cardOffset = currentCard.offsetLeft;
      const cardWidth = currentCard.offsetWidth;

      const move = viewportCenter - cardOffset - cardWidth / 2;

      track.style.transform = `translateX(${move}px)`;

      cards.forEach((card, i) => card.classList.toggle("is-active", i === currentIndex));
      indicators.forEach((ind, i) => ind.classList.toggle("is-active", i === currentIndex));

      setTimeout(() => {
        isMoving = false;
      }, 1000);
    }

    function startAutoMove(direction: "left" | "right") {
      if (interval) return;
      interval = setInterval(() => {
        if (isMoving) return;
        if (direction === "right" && currentIndex < cards.length - 1) {
          currentIndex++;
          updateCarousel();
        } else if (direction === "left" && currentIndex > 0) {
          currentIndex--;
          updateCarousel();
        } else {
          stopAutoMove();
        }
      }, 200);
    }

    function stopAutoMove() {
      if (interval) {
        clearInterval(interval);
        interval = null;
      }
    }

    zoneRight?.addEventListener("mouseenter", () => {
      if (desktopActive()) startAutoMove("right");
    });
    zoneRight?.addEventListener("mouseleave", stopAutoMove);
    zoneLeft?.addEventListener("mouseenter", () => {
      if (desktopActive()) startAutoMove("left");
    });
    zoneLeft?.addEventListener("mouseleave", stopAutoMove);

    function onResize() {
      if (desktopActive()) {
        updateCarousel();
      } else if (track) {
        track.style.transform = "";
      }
    }

    window.addEventListener("resize", onResize);
    setTimeout(() => {
      if (desktopActive()) updateCarousel();
    }, 150);
  }

  function initServiceCaseMobileIndicators() {
    const scrollEl = document.getElementById("service-case-mobile-scroll");
    const cards = document.querySelectorAll(`${SECTION} .service-case-mobile-card`);
    const indicators = document.querySelectorAll(`${SECTION} .service-indicator-progress`);
    if (!scrollEl || cards.length === 0 || indicators.length === 0) return;

    const scroll = scrollEl;

    function sync() {
      if (window.matchMedia("(min-width: 768px)").matches) return;

      const scRect = scroll.getBoundingClientRect();
      const mid = scRect.left + scRect.width / 2;
      let best = 0;
      let bestDist = Infinity;

      cards.forEach((card, i) => {
        const r = card.getBoundingClientRect();
        const c = r.left + r.width / 2;
        const d = Math.abs(c - mid);
        if (d < bestDist) {
          bestDist = d;
          best = i;
        }
      });

      indicators.forEach((ind, i) => ind.classList.toggle("is-active", i === best));
    }

    scroll.addEventListener("scroll", sync, { passive: true });
    window.addEventListener("resize", sync);
    sync();
  }

  function boot() {
    initServiceCaseHoverCarousel();
    initServiceCaseMobileIndicators();
  }

  boot();
  document.addEventListener("astro:after-swap", boot);
  document.addEventListener("astro:page-load", boot);
</script>
