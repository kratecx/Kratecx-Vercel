---
/**
 * ServiceDeliverables.astro
 * Two-Half Layout: Checklist (Left) | Blended Image (Right)
 */
import { Image } from "astro:assets";

interface Props {
  title?: string;
  deliverables: Array<{
    title: string; // Matches your page data
    description: string; // Matches your page data
  }>;
  mainImage: ImageMetadata;
}

const { 
  title = "Service Ledger", 
  deliverables = [],
  mainImage
} = Astro.props;
---

<section class="py-24 bg-[#050505] text-white relative overflow-hidden font-sans">
  <div class="absolute inset-0 bg-[radial-gradient(#FB850008_1px,transparent_1px)] [background-size:30px_30px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-24 relative z-10">
    
    <div class="mb-14 flex flex-col items-center text-center reveal">
      <div class="flex items-center justify-center gap-4 mb-6">
        <span class="h-px w-10 bg-orange-400"></span>
        <p class="font-mono text-[12px] uppercase tracking-[0.5em] text-orange-400 font-bold">
          System Verification
        </p>
        <span class="h-px w-10 bg-orange-400"></span>
      </div>
      <h2 class="text-6xl md:text-8xl font-black uppercase tracking-tight leading-[0.85]">
        Service <span class="text-orange-400">Ledger</span>
      </h2>
      <div class="w-60 h-1 bg-orange-400 my-4 rounded-full opacity-50"></div>
      <p class="text-zinc-500 max-w-2xl mx-auto text-base font-light leading-relaxed">
        A precision-engineered lifecycle designed to transition your product
        from initial concept to market-dominant scale.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center border-t border-white/10 pt-16">
      
      <div class="space-y-4">
        {deliverables.map((item, index) => (
          <div 
            class="group flex items-start gap-5 py-5 px-6 rounded-lg transition-all duration-500 hover:bg-white/[0.02] border-l-2 border-transparent hover:border-orange-400 reveal"
            style={`transition-delay: ${index * 100}ms`}
          >
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-orange-400 flex items-center justify-center text-black group-hover:shadow-[0_0_15px_rgba(251,133,0,0.4)] transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            
            <div class="flex-1">
              <h3 class="text-sm font-black uppercase tracking-widest text-white group-hover:text-orange-400 transition-colors">
                {item.title}
              </h3>
              <p class="text-xs text-zinc-500 font-medium leading-relaxed max-w-[320px] mt-1">
                {item.description}
              </p>
            </div>
          </div>
        ))}
      </div>

      <div class="relative flex items-center justify-center p-8 reveal" style="transition-delay: 300ms">
        <div class="relative w-full max-w-[400px] aspect-square group">
          <div class="absolute inset-0 z-10 pointer-events-none shadow-[inset_0_0_60px_40px_#050505]"></div>
          
          {mainImage ? (
            <Image 
              src={mainImage} 
              alt="Technical Infrastructure" 
              class="w-full h-full object-cover  brightness-[1] contrast-125 "
            />
          ) : (
            <div class="w-full h-full bg-zinc-900 flex items-center justify-center text-[10px] font-mono opacity-20 uppercase tracking-[0.5em]">
                Missing_Asset
            </div>
          )}

          <!-- <div class="absolute top-0 right-0 w-16 h-16 border-t border-r border-orange-400/40 z-20"></div>
          <div class="absolute bottom-0 left-0 w-16 h-16 border-b border-l border-orange-400/40 z-20"></div> -->
        </div>
      </div>

    </div>
  </div>
</section>

<style is:global>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  function initDeliverableAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }
  document.addEventListener('DOMContentLoaded', initDeliverableAnimations);
  document.addEventListener('astro:page-load', initDeliverableAnimations);
</script>