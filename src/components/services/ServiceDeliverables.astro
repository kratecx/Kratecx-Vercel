---
/**
 * ServiceDeliverables.astro
 * Two-Half Layout: Checklist (Left) | Blended Image (Right)
 */
import { Image } from "astro:assets";

interface Props {
  title?: string;
  deliverables: Array<{
    title: string; // Matches your page data
    description: string; // Matches your page data
  }>;
  mainImage: ImageMetadata;
}

const { 
  title = "Service Ledger", 
  deliverables = [],
  mainImage
} = Astro.props;
---

<section class="relative overflow-hidden bg-[#050505] py-14 font-sans text-white sm:py-20 lg:py-24">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(#FB850008_1px,transparent_1px)] [background-size:30px_30px]"
  ></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-12 xl:px-16">
    <div class="reveal mb-10 flex flex-col items-center text-center sm:mb-12 md:mb-14">
      <div class="mb-5 flex items-center justify-center gap-2 sm:mb-6 sm:gap-4">
        <span class="h-px w-8 bg-orange-400 sm:w-10"></span>
        <p
          class="font-mono text-[10px] font-bold uppercase tracking-[0.35em] text-orange-400 sm:text-xs sm:tracking-[0.45em] md:text-[12px] md:tracking-[0.5em]"
        >
          System Verification
        </p>
        <span class="h-px w-8 bg-orange-400 sm:w-10"></span>
      </div>
      <h2
        class="text-balance text-4xl font-black uppercase leading-[0.88] tracking-tight sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl"
      >
        Service <span class="text-orange-400">Ledger</span>
      </h2>
      <div class="my-3 h-1 w-48 max-w-[85vw] rounded-full bg-orange-400 opacity-50 sm:my-4 sm:w-60"></div>
      <p class="mx-auto max-w-2xl px-1 text-sm font-light leading-relaxed text-zinc-500 sm:text-base md:text-lg">
        A precision-engineered lifecycle designed to transition your product from initial concept to
        market-dominant scale.
      </p>
    </div>

    <div class="grid grid-cols-1 items-center gap-10 border-t border-white/10 pt-10 sm:gap-12 sm:pt-14 lg:grid-cols-2 lg:gap-12 lg:pt-16">
      
      <div class="min-w-0 space-y-3 sm:space-y-4">
        {deliverables.map((item, index) => (
          <div 
            class="reveal group flex items-start gap-4 rounded-lg border-l-2 border-transparent px-4 py-4 transition-all duration-500 hover:border-orange-400 hover:bg-white/[0.02] sm:gap-5 sm:px-6 sm:py-5"
            style={`transition-delay: ${index * 100}ms`}
          >
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-orange-400 text-black transition-all group-hover:shadow-[0_0_15px_rgba(251,133,0,0.4)]">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            
            <div class="min-w-0 flex-1">
              <h3 class="text-xs font-black uppercase tracking-wider text-white transition-colors group-hover:text-orange-400 sm:text-sm">
                {item.title}
              </h3>
              <p class="mt-1 max-w-none text-xs font-medium leading-relaxed text-zinc-500 sm:max-w-md sm:text-[13px] md:text-sm">
                {item.description}
              </p>
            </div>
          </div>
        ))}
      </div>

      <div class="relative flex items-center justify-center p-4 reveal sm:p-6 lg:p-8" style="transition-delay: 300ms">
        <div class="group relative aspect-square w-full max-w-[min(100%,400px)]">
          <div class="absolute inset-0 z-10 pointer-events-none shadow-[inset_0_0_60px_40px_#050505]"></div>
          
          {mainImage ? (
            <Image 
              src={mainImage} 
              alt="Technical Infrastructure" 
              class="w-full h-full object-cover  brightness-[1] contrast-125 "
            />
          ) : (
            <div class="w-full h-full bg-zinc-900 flex items-center justify-center text-[10px] font-mono opacity-20 uppercase tracking-[0.5em]">
                Missing_Asset
            </div>
          )}

          <!-- <div class="absolute top-0 right-0 w-16 h-16 border-t border-r border-orange-400/40 z-20"></div>
          <div class="absolute bottom-0 left-0 w-16 h-16 border-b border-l border-orange-400/40 z-20"></div> -->
        </div>
      </div>

    </div>
  </div>
</section>

<style is:global>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  function initDeliverableAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }
  document.addEventListener('DOMContentLoaded', initDeliverableAnimations);
  document.addEventListener('astro:page-load', initDeliverableAnimations);
</script>