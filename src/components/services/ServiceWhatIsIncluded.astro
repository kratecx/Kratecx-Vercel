---
/**
 * BinaryLedger.astro
 * Aesthetic: Surgical Dark / Two-Column Protocol
 * Palette: 70% Black, 20% White, 10% Orange-400
 */
interface Props {
  items?: Array<{
    icon: string;
    label: string;
    value: string;
  }>;
}

const { items = [] } = Astro.props;
---

<section class="overflow-hidden bg-[#050505] py-14 font-sans text-white sm:py-20 lg:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8" data-reveal>
    <div class="mb-12 flex flex-col items-center text-center sm:mb-16 md:mb-20">
      <div class="mb-6 flex items-center justify-center gap-2 sm:mb-8 sm:gap-4">
        <span class="block h-px w-8 bg-orange-400 sm:w-10"></span>
        <p
          class="font-mono text-[10px] font-bold uppercase tracking-[0.35em] text-orange-400 sm:text-xs sm:tracking-[0.45em] md:text-[14px] md:tracking-[0.5em]"
        >
          System Verification
        </p>
        <span class="block h-px w-8 bg-orange-400 sm:w-10"></span>
      </div>
      <h2
        class="text-balance text-4xl font-semibold uppercase leading-[0.88] tracking-[-0.05em] text-white sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl"
      >
        Service
        <span class="mt-1 block text-orange-400 sm:mt-2 sm:inline sm:mt-0">Ledger</span>
      </h2>
      <div class="my-3 h-1 w-48 max-w-[85vw] rounded-full bg-orange-400 opacity-50 sm:my-4 sm:w-60"></div>
      <p class="mx-auto max-w-2xl px-1 text-sm font-light leading-relaxed text-gray-400 sm:text-base md:text-lg">
        A precision-engineered lifecycle designed to transition your product from initial concept to
        market-dominant scale.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-x-8 border-t border-white/10 md:grid-cols-2 md:gap-x-12 lg:gap-x-16">
      {
        items.map((item) => (
          <div class="group flex items-start gap-4 border-b border-white/5 py-8 transition-all duration-300 hover:bg-white/[0.02] sm:gap-6 sm:py-10">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg border border-orange-400/20 bg-orange-400/5 transition-colors group-hover:border-orange-400 sm:h-12 sm:w-12">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 text-orange-400 sm:h-6 sm:w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>

            <div class="min-w-0 flex-1 space-y-1">
              <h3 class="text-base font-semibold uppercase tracking-wider text-white transition-colors group-hover:text-orange-400 sm:text-lg md:text-xl">
                {item.label}
              </h3>
              <p class="max-w-none text-sm font-medium leading-relaxed text-zinc-500 sm:max-w-md md:text-[15px] lg:max-w-sm">
                {item.value}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
