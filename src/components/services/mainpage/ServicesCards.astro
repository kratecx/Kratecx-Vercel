---
import { servicesCatalog as services } from "@/data/servicesCatalog";

const totalServices = services.length;
---

<section class="relative z-20 overflow-hidden bg-black px-4 pb-12 pt-12 sm:px-6 sm:pb-14 sm:pt-14 md:pb-16 md:pt-16 lg:px-12 xl:px-24">
  <div class="mx-auto max-w-7xl" data-reveal>
    <div class="mb-8 flex flex-col items-center text-center sm:mb-10 md:mb-12">
      <div class="mb-5 flex items-center justify-center gap-2 sm:mb-6 sm:gap-4">
        <span class="block h-px w-8 bg-orange-400 sm:w-10"></span>
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.3em] text-orange-400 sm:text-sm sm:tracking-[0.45em] md:text-[14px] md:tracking-[0.5em]">
          Solutions
        </p>
        <span class="block h-px w-8 bg-orange-400 sm:w-10"></span>
      </div>
      <h2 class="text-balance text-5xl font-semibold uppercase leading-[0.88] tracking-[-0.05em] text-white sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl">
        <span class="text-white">What We</span>
        <br />
        <span class="text-orange-400">Offer</span>
      </h2>
      <div class="my-4 h-1 w-48 max-w-[90vw] rounded-full bg-orange-400 opacity-50 sm:my-5 sm:w-64 md:my-6 md:w-80"></div>
      <p class="mx-auto max-w-2xl px-1 text-sm font-light leading-snug text-gray-400 sm:text-base md:text-lg">
        A range of website solutions designed to help your business grow, build trust, and generate consistent leads.
      </p>
    </div>

    <div
      id="services-cards-grid"
      class="mt-8 grid grid-cols-1 gap-4 sm:mt-10 sm:grid-cols-2 sm:gap-4 md:gap-5 lg:grid-cols-3 lg:gap-6"
      data-mobile-stage="0"
      data-total-services={totalServices}
    >
      {services.map((service, index) => (
        <div
          class="service-card-item group relative flex flex-col justify-between rounded-xl p-5 sm:rounded-2xl sm:p-6 md:rounded-[2rem] md:p-8 md:transition-all md:duration-500 md:ease-[cubic-bezier(0.19,1,0.22,1)] lg:rounded-[2.5rem] lg:p-9 xl:rounded-[3rem] xl:p-10"
        >
          <!-- Glow + motion: md+ only -->
          <div class="pointer-events-none absolute inset-0 hidden scale-90 rounded-xl bg-orange-600/0 blur-[50px] md:block md:rounded-[2rem] md:transition-all md:duration-700 md:group-hover:scale-110 md:group-hover:bg-orange-600/20 lg:rounded-[2.5rem] xl:rounded-[3rem]"></div>

          <div class="pointer-events-none absolute inset-0 rounded-xl border border-white/5 bg-gradient-to-b from-[#111] to-[#080808] shadow-xl sm:rounded-2xl md:rounded-[2rem] md:shadow-2xl md:transition-all md:duration-500 md:group-hover:-translate-y-1 md:group-hover:border-orange-400/40 lg:rounded-[2.5rem] md:group-hover:shadow-orange-400/10 xl:rounded-[3rem]"></div>

          <a
            href={service.href}
            class="absolute inset-0 z-20 rounded-xl sm:rounded-2xl md:rounded-[2rem] lg:rounded-[2.5rem] xl:rounded-[3rem]"
            aria-label={`Open ${service.title} service`}
          >
            <span class="sr-only">{service.title}</span>
          </a>

          <div class="pointer-events-none absolute inset-0 rounded-xl bg-gradient-to-br from-white/[0.08] via-transparent to-transparent opacity-100 sm:rounded-2xl md:rounded-[2rem] md:opacity-100 md:transition-opacity md:group-hover:opacity-50 lg:rounded-[2.5rem] xl:rounded-[3rem]"></div>

          <div class="pointer-events-none relative z-10 md:transition-transform md:duration-700 md:ease-[cubic-bezier(0.19,1,0.22,1)] md:group-hover:-translate-y-4 lg:group-hover:-translate-y-5">
            <div class="mb-5 flex items-start justify-between sm:mb-6 md:mb-8">
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg border border-white/5 bg-[#1a1a1a] shadow-[4px_4px_12px_rgba(0,0,0,0.45)] sm:h-12 sm:w-12 sm:rounded-xl md:h-14 md:w-14 md:rounded-[1.1rem] md:transition-all md:duration-500 md:group-hover:scale-110 md:group-hover:bg-orange-400 md:group-hover:shadow-[0_0_28px_rgba(251,133,0,0.35)] md:group-hover:-rotate-12 lg:h-[3.5rem] lg:w-[3.5rem] lg:rounded-[1.35rem]">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-orange-400 sm:h-6 sm:w-6 md:transition-colors md:duration-500 md:group-hover:text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
                  <path d={service.icon}></path>
                </svg>
              </div>
              <span class="text-3xl font-black italic text-white/[0.04] sm:text-4xl md:text-5xl md:transition-colors md:duration-700 md:group-hover:text-orange-400/10 lg:text-6xl">
                0{index + 1}
              </span>
            </div>

            <div class="min-w-0">
              <h3 class="mb-2 text-lg font-semibold uppercase leading-tight tracking-tighter text-white sm:text-xl md:mb-3 md:text-2xl md:transition-colors md:duration-500 md:group-hover:text-orange-400 lg:text-[1.35rem] xl:text-2xl">
                {service.title}
              </h3>
              <p
                class="max-w-[98%] text-[12px] font-medium leading-snug text-gray-500 sm:text-[13px] md:text-sm md:leading-relaxed md:transition-colors md:duration-500 md:group-hover:text-gray-300"
              >
                {service.description}
              </p>
            </div>
          </div>

          <div class="pointer-events-none relative z-10 mt-4 flex items-center justify-between border-t border-white/5 pt-3 sm:mt-5 sm:pt-3.5 md:mt-5 md:border-t-0 md:pt-0 md:opacity-0 md:invisible md:translate-y-3 md:transition-all md:duration-700 md:group-hover:visible md:group-hover:translate-y-0 md:group-hover:opacity-100">
            <div class="flex items-center gap-2.5 md:gap-3">
              <div class="h-px w-7 bg-orange-400/50 md:w-6 md:transition-all md:duration-700 md:group-hover:w-11 md:group-hover:bg-orange-400"></div>
              <span class="text-[9px] font-black uppercase tracking-[0.3em] text-white/45 md:tracking-[0.35em] md:transition-colors md:group-hover:text-white lg:tracking-[0.4em]">
                Explore
              </span>
            </div>
            <div class="text-orange-400 md:opacity-0 md:transition-all md:duration-700 md:group-hover:translate-x-1.5 md:group-hover:opacity-100">
              <svg class="h-[18px] w-[18px] text-orange-400 sm:h-5 sm:w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M5 12h14m-7-7l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Progressive load: small screens only (md:hidden); empty state hidden via script when ≤4 cards -->
    <div
      id="services-mobile-see-more-wrap"
      class="mt-6 flex flex-col items-center gap-3 sm:mt-8 md:hidden"
      aria-live="polite"
    >
      <button
        type="button"
        id="services-see-more-first"
        class="w-full max-w-sm rounded-xl border border-orange-400/35 bg-orange-400/10 px-6 py-3 text-center text-sm font-black uppercase tracking-wider text-orange-400 transition-colors hover:border-orange-400/55 hover:bg-orange-400/15"
      >
        See more
      </button>
      <button
        type="button"
        id="services-see-more-second"
        class="w-full max-w-sm rounded-xl border border-orange-400/35 bg-orange-400/10 px-6 py-3 text-center text-sm font-black uppercase tracking-wider text-orange-400 transition-colors hover:border-orange-400/55 hover:bg-orange-400/15"
      >
        See more
      </button>
    </div>
  </div>
</section>

<style>
  /*
   * Mobile (&lt; md): stage 0 = first 4 cards, stage 1 = first 8, stage 2 = all.
   * md+: ignore — full grid always visible.
   */
  @media (max-width: 767px) {
    #services-cards-grid[data-mobile-stage="0"] .service-card-item:nth-child(n + 5) {
      display: none;
    }
    #services-cards-grid[data-mobile-stage="1"] .service-card-item:nth-child(n + 9) {
      display: none;
    }
  }
</style>

<script define:vars={{ totalServices }}>
  const MOBILE_MAX = "(max-width: 767px)";

  function getGrid() {
    return document.getElementById("services-cards-grid");
  }

  function syncServicesMobileUi() {
    const grid = getGrid();
    const wrap = document.getElementById("services-mobile-see-more-wrap");
    const btn1 = document.getElementById("services-see-more-first");
    const btn2 = document.getElementById("services-see-more-second");
    if (!grid || !wrap || !btn1 || !btn2) return;

    const mq = window.matchMedia(MOBILE_MAX);
    const total = Number(grid.dataset.totalServices) || totalServices;
    const isMobile = mq.matches;

    if (!isMobile) {
      grid.removeAttribute("data-mobile-stage");
      return;
    }

    if (total <= 4) {
      wrap.classList.add("hidden");
      grid.dataset.mobileStage = "2";
      return;
    }

    let stage = Number(grid.dataset.mobileStage);
    if (Number.isNaN(stage) || stage < 0) stage = 0;
    if (stage > 2) stage = 2;
    grid.dataset.mobileStage = String(stage);

    const showFirst = total > 4 && stage === 0;
    const showSecond = total > 8 && stage === 1;

    btn1.hidden = !showFirst;
    btn2.hidden = !showSecond;

    const showWrap = total > 4 && (showFirst || showSecond);
    wrap.classList.toggle("hidden", !showWrap);
  }

  function onFirstSeeMore() {
    const grid = getGrid();
    if (!grid) return;
    const total = Number(grid.dataset.totalServices) || totalServices;
    grid.dataset.mobileStage = total > 8 ? "1" : "2";
    syncServicesMobileUi();
  }

  function onSecondSeeMore() {
    const grid = getGrid();
    if (!grid) return;
    grid.dataset.mobileStage = "2";
    syncServicesMobileUi();
  }

  function initServicesMobileSeeMore() {
    const grid = getGrid();
    const btn1 = document.getElementById("services-see-more-first");
    const btn2 = document.getElementById("services-see-more-second");
    if (!grid || !btn1 || !btn2) return;

    if (grid.dataset.servicesMobileBound === "1") return;
    grid.dataset.servicesMobileBound = "1";

    const mq = window.matchMedia(MOBILE_MAX);
    mq.addEventListener("change", syncServicesMobileUi);

    btn1.addEventListener("click", (e) => {
      e.preventDefault();
      onFirstSeeMore();
    });
    btn2.addEventListener("click", (e) => {
      e.preventDefault();
      onSecondSeeMore();
    });

    syncServicesMobileUi();
  }

  initServicesMobileSeeMore();
  document.addEventListener("astro:after-swap", () => {
    const g = getGrid();
    if (g) g.dataset.servicesMobileBound = "";
    initServicesMobileSeeMore();
  });
</script>
