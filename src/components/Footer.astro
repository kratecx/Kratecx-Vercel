---
import { servicesCatalog } from "@/data/servicesCatalog";
import { portfolioCaseStudiesFlat } from "@/data/portfolioIndex";
import { SITE } from "@/data/seo";

const navLinks = [
  { label: "About", href: "/about" },
  { label: "Process", href: "/process" },
  { label: "Portfolio", href: "/portfolio" },
  { label: "Services", href: "/services" },
  { label: "Contact Us", href: "/contact" },
] as const;

const socialLinks = [
  { name: "Facebook", href: SITE.social.facebook },
  { name: "Instagram", href: SITE.social.instagram },
  { name: "LinkedIn", href: SITE.social.linkedin },
] as const;

/** Show a short preview in the footer; full lists live on /services and /portfolio. */
const FOOTER_PREVIEW_COUNT = 6;

const servicesFeatured = servicesCatalog.slice(0, FOOTER_PREVIEW_COUNT);

const worksFeatured = portfolioCaseStudiesFlat.slice(0, FOOTER_PREVIEW_COUNT);
---

<footer class="bg-black text-white pt-16 pb-8 sm:pt-20 sm:pb-10 font-sans">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12" data-reveal>
    <div class="grid grid-cols-1 gap-10 sm:gap-12 md:grid-cols-2 md:gap-12 lg:grid-cols-4 lg:gap-12 mb-12 lg:mb-16">
      <div>
        <h3 class="text-white text-base font-medium mb-2 sm:text-lg">Company</h3>
        <div class="w-10 h-0.5 bg-orange-500 mb-5"></div>
        <ul class="space-y-3">
          {navLinks.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-gray-300 hover:text-orange-400 transition-colors sm:text-[15px]"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="min-w-0">
        <h3 class="text-white text-base font-medium mb-2 sm:text-lg">Our Services</h3>
        <div class="w-10 h-0.5 bg-orange-500 mb-5"></div>
        <ul class="space-y-3">
          {servicesFeatured.map((s) => (
            <li>
              <a
                href={s.href}
                class="text-sm text-gray-300 hover:text-orange-400 transition-colors sm:text-[15px] leading-snug"
              >
                {s.title}
              </a>
            </li>
          ))}
        </ul>
        <a
          href="/services"
          class="mt-5 inline-block text-sm font-semibold text-orange-400 hover:text-orange-300 transition-colors sm:text-[15px]"
        >
          Explore More
        </a>
      </div>

      <div class="min-w-0">
        <h3 class="text-white text-base font-medium mb-2 sm:text-lg">Our Works</h3>
        <div class="w-10 h-0.5 bg-orange-500 mb-5"></div>
        <ul class="space-y-3">
          {worksFeatured.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-gray-300 hover:text-orange-400 transition-colors sm:text-[15px] leading-snug"
              >
                {item.title}
              </a>
            </li>
          ))}
        </ul>
        <a
          href="/portfolio"
          class="mt-5 inline-block text-sm font-semibold text-orange-400 hover:text-orange-300 transition-colors sm:text-[15px]"
        >
          Explore More
        </a>
      </div>

      <div>
        <h3 class="text-white text-base font-medium mb-2 sm:text-lg">Business inquiries</h3>
        <div class="w-10 h-0.5 bg-orange-500 mb-5"></div>
        <ul class="space-y-4 text-sm text-gray-300 sm:text-[15px]">

          <li class="flex items-center gap-3">
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-orange-600">
              <svg class="h-4 w-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6.62 10.79a15.1 15.1 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.27 11.72 11.72 0 003.7.59 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.72 11.72 0 00.59 3.7 1 1 0 01-.27 1.11z" />
              </svg>
            </span>
            <a href="tel:+92356012589" class="hover:text-orange-400 transition-colors">+92356012589</a>
          </li>
          <li class="flex items-center gap-3">
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-orange-600">
              <svg class="h-4 w-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
              </svg>
            </span>
            <a href="mailto:info@kratecx.com" class="hover:text-orange-400 transition-colors break-all"
              >info@kratecx.com</a
            >
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-orange-600">
              <svg class="h-4 w-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z" />
              </svg>
            </span>
            <span class="text-left text-gray-400 leading-relaxed">
               Metroville Sindh Industrial Trading Estate<br />
               Sector 3, Karachi 
            </span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col items-center gap-8 md:flex-row md:justify-between md:items-center">
      <p class="text-sm text-gray-400 sm:text-[15px] order-2 md:order-1">
        © {new Date().getFullYear()} Kratecs. All rights reserved.
      </p>

      <nav class="order-1 flex flex-wrap items-center justify-center gap-3 md:order-2" aria-label="Social media">
        {socialLinks.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-white/75 transition-colors hover:border-orange-400/35 hover:bg-white/[0.07] hover:text-orange-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-400 lg:h-14 lg:w-14 xl:h-16 xl:w-16"
            aria-label={item.name}
          >
            <svg class="h-[42%] w-[42%] lg:h-[44%] lg:w-[44%]" viewBox="0 0 24 24" aria-hidden="true">
              {item.name === "Facebook" && (
                <path
                  fill="currentColor"
                  d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                />
              )}
              {item.name === "LinkedIn" && (
                <path
                  fill="currentColor"
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.063 2.063 0 1.139-.925 2.065-2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                />
              )}
              {item.name === "Instagram" && (
                <path
                  fill="currentColor"
                  d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                />
              )}
            </svg>
          </a>
        ))}
      </nav>

      <div class="flex flex-wrap justify-center gap-4 text-sm text-gray-400 sm:gap-6 sm:text-[15px] order-3">
        <a href="#" class="hover:text-white transition-colors">Terms &amp; Conditions</a>
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/contact" class="hover:text-white transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>
