---
// ArchitecturalFooter.astro
const sectors = [
  { 
    title: "Our Company", 
    links: ["About", "Portfolio", "Careers", "Blog", "Contact us"] 
  },
  { 
    title: "Our Services", 
    links: ["Android App Development", "iPhone App Development", "Game App Development", "Blockchain app Development", "Smart Chatbot solution"] 
  },
  { 
    title: "Our Industries", 
    links: ["Ecommerce", "Healthcare", "Entertainment & Media", "News & Weather", "Real Estate"] 
  }
];

const locations = ["Florida", "Austin", "Houston", "Texas", "Dallas", "Chicago", "San Francisco", "Dubai", "Karachi"];
---

<footer class="bg-black text-white pt-20 pb-10 font-sans">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      {sectors.map((s) => (
        <div>
          <h3 class="text-white text-lg font-bold mb-2">{s.title}</h3>
          <div class="w-10 h-[2px] bg-orange-500 mb-6"></div>
          <ul class="space-y-4">
            {s.links.map(link => (
              <li>
                <a href="#" class="text-[14px] text-gray-300 hover:text-orange-400 transition-colors">
                  {link}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div>
        <h3 class="text-white text-lg font-bold mb-2">Talk to Us We're Eager to Know</h3>
        <div class="w-10 h-[2px] bg-orange-500 mb-6"></div>
        <ul class="space-y-4 text-[14px]">
          <li class="flex items-center gap-3">
            <div class="bg-orange-600 p-2 rounded-full">
               <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79a15.1 15.1 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.27 11.72 11.72 0 003.7.59 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.72 11.72 0 00.59 3.7 1 1 0 01-.27 1.11z"/></svg>
            </div>
            <span class="text-gray-300">+1-844-706-0053</span>
          </li>
          <li class="flex items-center gap-3">
            <div class="bg-orange-600 p-2 rounded-full">
               <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79a15.1 15.1 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.27 11.72 11.72 0 003.7.59 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.72 11.72 0 00.59 3.7 1 1 0 01-.27 1.11z"/></svg>
            </div>
            <span class="text-gray-300">+1-888-442-4644</span>
          </li>
          <li class="flex items-center gap-3">
            <div class="bg-orange-600 p-2 rounded-full">
               <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            </div>
            <span class="text-gray-300">info@retrocube.com</span>
          </li>
          <li class="flex items-start gap-3">
             <div class="mt-1 min-w-[32px] h-8 rounded-full overflow-hidden border border-white/20">
                <div class="bg-blue-900 h-1/2 w-full flex flex-wrap p-0.5">
                    <div class="w-full bg-red-600 h-1"></div>
                </div>
                <div class="bg-white h-1/2 w-full">
                    <div class="w-full bg-red-600 h-1"></div>
                </div>
             </div>
            <span class="text-gray-400 text-[13px] leading-relaxed">
              1910 Pacific Avenue, Suite No. 8025 - 8026,<br/> Dallas Texas 75201
            </span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 py-8">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[15px] font-medium text-gray-300">
        {locations.map((loc, idx) => (
          <>
            <a href="#" class="hover:text-orange-400 transition-colors">{loc}</a>
            {idx !== locations.length - 1 && <span class="text-white/30">|</span>}
          </>
        ))}
      </div>
    </div>

    <div class="border-t border-white/10 pt-10 flex flex-col md:flex-row justify-between items-center gap-8">
      <p class="text-[15px] text-gray-400">
        All Rights Reserved © 2026 RetroCube
      </p>

      <div class="flex items-center gap-4">
        {['f', 't', 'in', 'i'].map((icon) => (
          <a href="#" class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center hover:bg-orange-500 hover:border-orange-500 transition-all text-sm font-bold">
            {icon === 'f' && 'f'}
            {icon === 't' && '𝕏'}
            {icon === 'in' && 'in'}
            {icon === 'i' && '○'}
          </a>
        ))}
      </div>

      <div class="flex flex-wrap justify-center gap-6 text-[15px] text-gray-400">
        <a href="#" class="hover:text-white">Terms & Condition</a>
        <a href="#" class="hover:text-white">Privacy Policy</a>
        <a href="#" class="hover:text-white">Contact Us</a>
        <a href="#" class="hover:text-white">Sitemap</a>
      </div>
    </div>
  </div>
</footer>