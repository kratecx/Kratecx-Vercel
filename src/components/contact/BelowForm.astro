---
// BelowForm.astro - Zero-Error Horizontal Relay
---

<section class="w-full bg-white pb-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="bg-[#050505] rounded-[2.5rem] border border-white/5 shadow-2xl overflow-hidden grid grid-cols-1 lg:grid-cols-3">
      
      <div class="p-10 border-b lg:border-b-0 lg:border-r border-white/10 flex flex-col justify-between">
        <div class="space-y-6">
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 bg-[#ea580c] rounded-full"></div>
            <span class="text-[10px] font-mono font-bold text-gray-500 tracking-[0.3em] uppercase">HQ_Node</span>
          </div>
          <div>
            <h3 class="text-white text-3xl font-medium tracking-tighter uppercase leading-none mb-4">
              System <span class="text-gray-600">Ethics</span>
            </h3>
            <address class="not-italic text-gray-500 text-xs font-mono leading-relaxed uppercase tracking-wider">
              402 Architecture Way<br/>
              Suite 105, Silicon Valley<br/>
              California, USA
            </address>
          </div>
        </div>
      </div>

      <div class="p-10 border-b lg:border-b-0 lg:border-r border-white/10 bg-[#080808] flex flex-col">
        <div class="flex items-center gap-3 mb-10">
          <div class="w-1 h-4 bg-[#ea580c]"></div>
          <span class="text-[10px] font-mono font-bold text-gray-500 tracking-[0.3em] uppercase">Connect_Matrix</span>
        </div>
        
        <div class="flex items-center gap-6">
          <a href="#" class="group flex flex-col items-center gap-3">
            <div class="w-16 h-16 flex items-center justify-center bg-white/5 rounded-2xl border border-white/10 transition-all duration-300 group-hover:bg-[#ea580c] group-hover:border-[#ea580c] group-hover:-translate-y-1">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
            </div>
            <span class="text-[9px] font-mono text-gray-700 uppercase group-hover:text-[#ea580c] transition-colors">LinkedIn</span>
          </a>

          <a href="#" class="group flex flex-col items-center gap-3">
            <div class="w-16 h-16 flex items-center justify-center bg-white/5 rounded-2xl border border-white/10 transition-all duration-300 group-hover:bg-[#ea580c] group-hover:border-[#ea580c] group-hover:-translate-y-1">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.045 4.126H5.078z"/>
              </svg>
            </div>
            <span class="text-[9px] font-mono text-gray-700 uppercase group-hover:text-[#ea580c] transition-colors">Twitter_X</span>
          </a>

          <a href="#" class="group flex flex-col items-center gap-3">
            <div class="w-16 h-16 flex items-center justify-center bg-white/5 rounded-2xl border border-white/10 transition-all duration-300 group-hover:bg-[#ea580c] group-hover:border-[#ea580c] group-hover:-translate-y-1">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
            </div>
            <span class="text-[9px] font-mono text-gray-700 uppercase group-hover:text-[#ea580c] transition-colors">GitHub</span>
          </a>
        </div>
      </div>

      <div class="p-10 flex flex-col justify-between bg-[#050505]">
        <div class="flex items-center gap-3 mb-10">
          <div class="w-3 h-[1px] bg-white/20"></div>
          <span class="text-[10px] font-mono font-bold text-gray-500 tracking-[0.3em] uppercase">Voice_Link</span>
        </div>
        
        <div class="space-y-2">
          <p class="text-[10px] font-bold text-[#ea580c] uppercase tracking-widest">Call Now</p>
          <a href="tel:+923212345678" class="text-2xl text-white font-bold tracking-tight hover:text-[#ea580c] transition-colors block">
            +92 32 12345678
          </a>
        </div>
        
        <p class="mt-8 text-[9px] font-mono text-gray-600 uppercase tracking-widest">Available 09:00 - 18:00 PST</p>
      </div>

    </div>

    <div class="mt-6 h-[1px] w-full bg-gradient-to-r from-transparent via-[#ea580c]/30 to-transparent"></div>
  </div>
</section>