---
/**
 * Dark-minimal service card.
 * — Entrance: staggered reveal via GSAP ScrollTrigger (parent has `data-animate="card-grid"`).
 * — Hover shell: pure CSS (performant, no JS work on every move).
 * — Hover inner choreography: GSAP (icon scale, title letter-spacing).
 */
interface Props {
  title: string;
  description: string;
  href?: string;
  /** SVG path d attribute (single-path icon). */
  iconPath: string;
  /** Accent color override (defaults to brand orange). */
  accent?: string;
}
const { title, description, href = '#', iconPath, accent = '#f98502' } = Astro.props as Props;
---

<a
  href={href}
  class="sc-card group"
  data-animate="card"
  style={`--sc-accent: ${accent};`}
>
  <div class="sc-icon" data-sc="icon" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
      <path d={iconPath} />
    </svg>
  </div>

  <h3 class="sc-title" data-sc="title">{title}</h3>
  <p class="sc-desc">{description}</p>

  <span class="sc-arrow" data-sc="arrow" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14" />
      <path d="m12 5 7 7-7 7" />
    </svg>
  </span>
</a>

<style>
  .sc-card {
    --sc-border: rgba(255, 255, 255, 0.08);
    --sc-border-hover: color-mix(in srgb, var(--sc-accent) 50%, transparent);

    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    border-radius: 1rem;
    border: 1px solid var(--sc-border);
    background: rgba(255, 255, 255, 0.015);
    color: inherit;
    text-decoration: none;
    overflow: hidden;

    /* Professional hover: subtle 3px lift, border fade. NO glow shadow. */
    transition:
      transform 0.25s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }
  .sc-card:hover {
    transform: translateY(-3px);
    border-color: var(--sc-border-hover);
    background: rgba(255, 255, 255, 0.03);
  }

  .sc-icon {
    display: inline-flex;
    width: 2.25rem;
    height: 2.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    border: 1px solid var(--sc-border);
    background: rgba(255, 255, 255, 0.02);
    color: var(--sc-accent);
    transition: color 0.2s ease, border-color 0.2s ease;
    will-change: transform;
  }
  .sc-card:hover .sc-icon { border-color: var(--sc-border-hover); }
  .sc-icon svg { width: 1.1rem; height: 1.1rem; }

  .sc-title {
    font-family: var(--font-poppins);
    font-weight: 600;
    font-size: 1.125rem;
    line-height: 1.3;
    color: #fff;
    margin: 0;
    will-change: transform, letter-spacing;
  }
  .sc-desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }

  .sc-arrow {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 1.75rem;
    height: 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: var(--sc-accent);
    opacity: 0;
    transform: translate(-6px, 6px);
    transition: opacity 0.25s ease, transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .sc-card:hover .sc-arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .sc-card,
    .sc-icon,
    .sc-title,
    .sc-arrow { transition: none !important; }
  }
</style>

<script>
  import { gsap } from '@/utils/animations';

  const init = () => {
    const cards = document.querySelectorAll<HTMLElement>('.sc-card');

    cards.forEach((card) => {
      // Skip if already wired (Astro re-runs scripts on navigation).
      if (card.dataset.scWired === '1') return;
      card.dataset.scWired = '1';

      const icon = card.querySelector<HTMLElement>('[data-sc="icon"]');
      const title = card.querySelector<HTMLElement>('[data-sc="title"]');

      // Scope the tweens so they can be killed on navigation.
      const ctx = gsap.context(() => {
        const tl = gsap.timeline({ paused: true, defaults: { duration: 0.3, ease: 'power1.out' } });
        if (icon) tl.to(icon, { scale: 1.05 }, 0);
        if (title) tl.to(title, { letterSpacing: '0.005em' }, 0);

        card.addEventListener('mouseenter', () => tl.play());
        card.addEventListener('mouseleave', () => tl.reverse());
      }, card);

      // Cleanup when card is removed from DOM (island unmount).
      const observer = new MutationObserver(() => {
        if (!document.body.contains(card)) {
          ctx.revert();
          observer.disconnect();
        }
      });
      observer.observe(document.body, { childList: true, subtree: true });
    });
  };

  init();
  document.addEventListener('astro:page-load', init);
</script>
