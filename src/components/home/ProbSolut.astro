---
// IntegrationSection.astro

const layers = [
  {
    title: "Clear Structure",
    desc: "We design intuitive layouts that guide users and make taking action effortless.",
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
  },
  {
    title: "Fast Performance",
    desc: "Optimized for speed to keep users engaged and reduce drop-offs.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",

  },
  {
    title: "Built for Trust",
    desc: "Professional design and UX that builds credibility and drives conversions.",
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",

  }
];


const stackLogos = [
  { name: "Astro", path: "M15.5 2.5l-9 12h5l-1 7 11-13h-6l2-6z" },
  { name: "Tailwind", path: "M12 6.036c-2.287 0-3.43 1.143-3.43 3.429 0 2.285 1.143 3.428 3.43 3.428m0-6.857c2.286 0 3.428 1.142 3.428 3.429 0 2.285-1.142 3.428-3.428 3.428m-8.571-3.429c0-2.285 1.142-3.428 3.428-3.428m0 6.857c-2.286 0-3.428-1.143-3.428-3.428" },
  { name: "Database", path: "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" },
  { name: "Edge", path: "M13 10V3L4 14h7v7l9-11h-7z" }
];
---

<section class="py-16 sm:py-20 md:py-24 px-4 sm:px-6 lg:px-32 bg-white overflow-x-hidden relative" id="integration-section">
  <!-- <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
       style="background: radial-gradient(#000 1px, transparent 0) 0 0 / 40px 40px;">
  </div> -->

  <div class="max-w-7xl mx-auto relative z-10">
    <div id="reveal-text-zone" class="text-center mb-16 sm:mb-20 md:mb-24 opacity-0 translate-y-10 transition-all duration-700 ease-out px-1">
      <div class="flex flex-col items-center">
        <div class="mb-8 text-center leading-snug w-full max-w-full">
          <span class="inline-block align-middle h-0.5 w-10 bg-orange-400 mr-2 sm:mr-4" aria-hidden="true"></span><span class="inline-block align-middle max-w-[calc(100%-6rem)] sm:max-w-none font-mono text-sm uppercase tracking-[0.5em] text-orange-400 font-bold">Solutions of Problems</span><span class="inline-block align-middle h-0.5 w-10 bg-orange-400 ml-2 sm:ml-4" aria-hidden="true"></span>
        </div>
  
        <h2 class="text-5xl sm:text-6xl md:text-8xl font-black uppercase tracking-[-0.05em] leading-[0.9] md:leading-[0.85] text-black text-balance max-w-full">
          <span>Broken Websites To </span><span class="text-orange-400 inline-block mt-2">Growth Assets</span>
        </h2>
        <div class="w-60 max-w-[85vw] h-1 bg-orange-400 my-6 rounded-full opacity-50 mx-auto"></div>
      </div>

        <p class="text-gray-800 max-w-2xl mx-auto text-lg font-light text-balance">
          Most websites fail due to poor structure, slow performance and lack of trust. We solve these core issues with results-driven approach
        </p>
    </div>

  <div id="reveal-cards-zone" class="perspective-container relative grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8 md:gap-4">
  {layers.map((layer, i) => (
    <div class="integration-layer group relative opacity-0 translate-y-10" style={`--index: ${i};`}>
      <div class="relative h-full bg-white/70 backdrop-blur-md border border-black/10 p-6 sm:p-8 md:p-10 flex flex-col justify-between rounded-[2.5rem] shadow-sm hover:shadow-2xl transition-all duration-500 overflow-hidden">
        <div class="relative z-10">
          <div class="flex justify-between items-start mb-12">
             <div class={`p-3 rounded-xl transition-all duration-300 shadow-lg 
               ${i === 1 
                 ? 'bg-orange-400 text-black shadow-orange-400/20' 
                 : 'bg-black text-white group-hover:bg-orange-400 group-hover:text-black'
               }`}>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d={layer.icon} />
                </svg>
             </div>
          </div>
          
          <h3 class="text-2xl font-black text-black uppercase mb-4 tracking-tighter">{layer.title}</h3>
          <p class="text-black/60 text-sm leading-relaxed group-hover:text-black transition-colors">{layer.desc}</p>
        </div>

        <div class="mt-10 flex items-center gap-2">
          <div class="h-1 w-8 bg-orange-400 rounded-full group-hover:w-12 transition-all duration-300"></div>
          <div class="h-1 w-1 bg-black/10 rounded-full"></div>
        </div>
      </div>
    </div>
  ))}
</div>

    <div class="mt-16 sm:mt-20 md:mt-24 flex flex-col md:flex-row justify-between items-center gap-10 md:gap-12 border-t border-black/15 pt-10 md:pt-12 w-full max-w-full">
      <div class="flex flex-col sm:flex-row items-center gap-6 sm:gap-8 text-center sm:text-left w-full md:w-auto">
        <div class="flex -space-x-3 shrink-0 justify-center">
          {stackLogos.map((logo) => (
            <div class="w-12 h-12 bg-white border border-black/10 rounded-2xl shadow-sm flex items-center justify-center p-2.5 hover:-translate-y-2 hover:z-30 hover:border-orange-400 transition-all duration-300 group/logo">
              <svg viewBox="0 0 24 24" class="w-full h-full text-black/40 group-hover/logo:text-orange-400 transition-colors" fill="none" stroke="currentColor" stroke-width="2">
                <path d={logo.path} stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          ))}
        </div>
        <div class="min-w-0 max-w-md md:max-w-none">
          <p class="text-black font-black text-sm uppercase tracking-tighter leading-none">Built for Performance</p>
          <p class="text-[9px] text-black/40 font-bold uppercase tracking-widest mt-1 italic">Focused on speed, trust, and results</p>
        </div>
      </div>
        
      <a href="/contact" class="group relative flex max-w-full items-center gap-4 sm:gap-6 px-3 py-3 sm:px-4 bg-white/40 backdrop-blur-md border border-black/15 rounded-full hover:border-orange-400/30 transition-all duration-500">
        <div class="w-12 h-12 shrink-0 rounded-full bg-black flex items-center justify-center text-orange-400 group-hover:bg-orange-400 group-hover:text-black transition-all duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 group-hover:rotate-360 transition-transform duration-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </div>
        <div class="min-w-0 pr-4 sm:pr-8 text-left">
          <p class="text-[9px] font-black tracking-widest text-black/40 uppercase mb-0.5 group-hover:text-orange-400 transition-colors">Want to know more about us?</p>
          <span class="text-black font-black text-xl tracking-tighter uppercase leading-none whitespace-normal sm:whitespace-nowrap">Explore Our Story</span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .perspective-container {
    perspective: 2000px; /* Increased perspective for a more elegant tilt */
    transform-style: preserve-3d;
  }

  /* --- THE PREMIUM CARD BASE --- */
  .integration-layer .relative.h-full {
    /* Multi-layered border: 1px solid with a very subtle inner shadow */
    /* border-color: rgba(251, 133, 0, 0.3); */
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 
      0 4px 6px -1px rgba(0, 0, 0, 0.02), 
      0 2px 4px -1px rgba(0, 0, 0, 0.01),
      inset 0 1px 0 0 rgba(255, 255, 255, 0.8); /* White top-edge highlight */
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  }

  /* --- HOVER STATE BORDERS --- */
  .integration-layer:hover .relative.h-full {
    border-color: rgba(251, 133, 0, 0.3); /* Orange tint on border */
    box-shadow: 
      0 20px 40px -12px rgba(0, 0, 0, 0.1),
      inset 0 1px 1px 0 rgba(251, 133, 0, 0.1); /* Subtle orange inner glow */
    background: white;
  }

  /* Entrance States */
  .text-revealed { opacity: 1 !important; transform: translateY(0) !important; }

  .integration-layer {
    transition: opacity 0.8s ease-out, transform 1s cubic-bezier(0.23, 1, 0.32, 1);
    transition-delay: calc(var(--index) * 150ms);
    will-change: transform, opacity;
  }

  .cards-revealed .integration-layer { 
    opacity: 1; 
    transform: translateY(0); 
  }

  @media (min-width: 768px) {
    .cards-revealed .integration-layer:nth-child(1) { transform: rotateY(15deg) rotateX(2deg); }
    .cards-revealed .integration-layer:nth-child(2) { transform: scale(1.02) translateZ(40px); z-index: 20; }
    .cards-revealed .integration-layer:nth-child(3) { transform: rotateY(-15deg) rotateX(2deg); }

    .integration-layer:hover {
      transform: translateY(-15px) rotateY(0deg) rotateX(0deg) translateZ(100px) !important;
      z-index: 50 !important;
    }
  }

  .backdrop-blur-md {
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
</style>

<script>
  function setupScrollAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if (entry.target.id === 'reveal-text-zone') entry.target.classList.add('text-revealed');
          if (entry.target.id === 'reveal-cards-zone') entry.target.classList.add('cards-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    ['reveal-text-zone', 'reveal-cards-zone'].forEach(id => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  }

  // Handle initial load and Astro transitions
  setupScrollAnimations();
  document.addEventListener('astro:after-swap', setupScrollAnimations);
</script>