---
// Services.astro
import { Image } from 'astro:assets';

// Asset Imports
import service_image_backened from "@/assets/home/service_image_backened.png"
import service_image_landingpage from "@/assets/home/service_image_landingpage.png"
import service_image_speed_optimize from "@/assets/home/service_image_speed_optimize.png"
import service_image_frontend from "@/assets/home/service_image_front.png"
import service_custom_apps from "@/assets/home/service_custom_apps.png"
import service_image_support from "@/assets/home/service_image_support.png"


const services = [
  {
    slug: "custom-web-apps",
    href: "/services/custom-web-apps",
    title: "Custom Web Apps",
    description: "Custom-built web applications designed to support your business processes, improve efficiency, and scale as you grow.",
    features: ["Business-Focused", "Scalable Architecture", "High Performance"],
    icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5",
    image: service_custom_apps 
  },
  {
    slug: "landing-pages",
    title: "Landing Pages",
    description: "High-converting landing pages designed to capture attention, build trust, and turn visitors into qualified leads.",
    features: ["Conversion Focused", "Fast Loading", "Mobile Optimized"],
    icon: "M13 2L3 14h9l-1 8 10-12h-9l1-8z",
    image: service_image_landingpage 
  },
  {
    slug: "frontend-development",
    /** Closest themed service page (no dedicated “frontend” route yet). */
    href: "/services/business-websites",
    title: "Frontend Development",
    description: "Clean, modern interfaces that deliver a smooth user experience and reflect your brand professionally.",
    features: ["Responsive Design", "Fast Performance", "User-Friendly UI"],
    icon: "M17 18h1a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1M7 18H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h1M9 20h6v-4H9v4Z",
    image: service_image_frontend 
  },
  {
    slug: "backend-development",
    href: "/services/backend-development",
    title: "Backend Development",
    description: "Reliable and secure systems that power your website, manage data, and ensure everything runs smoothly.",
    features: ["Secure Systems", "API Integration", "Reliable Performance"],
    icon: "M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83",
    image: service_image_backened 
  },
  {
    slug: "maintenance-support",
    href: "/services/maintenance-support",
    title: "Maintenance & Support",
    description: "Ongoing support to keep your website secure, updated, and performing at its best over time.",
    features: ["Regular Updates", "Security Monitoring", "Ongoing Support"],
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
    image: service_image_support 
  },
  {
    slug: "speed-optimization",
    href: "/services/speed-optimization",
    title: "Speed Optimization",
    description: "Improve your website’s speed and performance to reduce drop-offs and enhance user experience.",
    features: ["Faster Load Times", "Better Experience", "Improved Conversions"],
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    image: service_image_speed_optimize 
  }
];
---

<section 
  class="py-20 sm:py-24 md:py-32 bg-black text-white relative overflow-x-hidden glow-top" 
  id="services-section"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-24 relative z-10">
    
    <div class="mb-6 flex flex-col items-center text-center">
      <div class="mb-8 text-center leading-snug px-1 w-full max-w-full">
        <span class="inline-block align-middle h-px w-10 bg-orange-400 mr-2 sm:mr-4" aria-hidden="true"></span><span class="inline-block align-middle max-w-[calc(100%-6rem)] sm:max-w-none font-mono text-[14px] uppercase tracking-[0.5em] text-orange-400 font-bold">Our Services</span><span class="inline-block align-middle h-px w-10 bg-orange-400 ml-2 sm:ml-4" aria-hidden="true"></span>
      </div>
      <h2 class="text-5xl sm:text-6xl md:text-8xl font-semibold uppercase tracking-[-0.05em] leading-[0.9] md:leading-[0.95] text-white text-balance max-w-full px-1">
        <span class="text-orange-400 inline-block mt-2">Services</span> That Drive Results
      </h2> 
            <div class="w-60 max-w-[85vw] h-1 bg-orange-400 my-6 rounded-full opacity-50 mx-auto"></div>
      <p class="text-zinc-400 max-w-3xl mx-auto text-lg font-light text-balance px-1">
        We design and build websites focused on trust, performance, and lead generation
      </p>
    </div>

    <p class="md:hidden text-center font-mono text-[9px] font-bold uppercase tracking-[0.4em] text-white/30 mb-3" aria-hidden="true">
      Swipe to browse
    </p>

    <div
      class="services-scroller flex snap-x snap-mandatory flex-nowrap gap-3 overflow-x-auto pb-3 -mx-4 scroll-smooth px-4 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden my-10 sm:my-14 md:mx-0 md:my-24 md:grid md:grid-cols-2 md:gap-6 md:overflow-visible md:px-0 md:pb-0 lg:grid-cols-3 md:snap-none md:flex-wrap"
      aria-label="Service offerings"
    >
      {services.map((service) => (
        <a
          href={service.href}
          class="service-card group relative flex w-[min(88vw,19.5rem)] shrink-0 snap-start flex-col rounded-2xl border border-white/10 bg-neutral-900/30 p-4 max-md:min-h-[260px] md:h-auto md:min-h-[440px] md:w-auto md:max-w-full md:p-8"
          aria-label={`${service.title} — view service details`}
        >
          
          <div class="absolute inset-0 z-0 pointer-events-none rounded-2xl overflow-hidden">
            <Image 
              src={service.image} 
              alt={service.title}
              width={1000}
              class="h-full w-full object-cover opacity-25 transition-all duration-700 ease-out group-hover:scale-105 group-hover:opacity-100 max-md:opacity-35" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/75 to-black/40 md:to-transparent"></div>
          </div>

          <div class="relative z-10 flex h-full min-h-0 flex-grow flex-col">
            <div class="mb-5 flex justify-between items-start md:mb-12">
              <div class="icon-box flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 bg-white/5 text-orange-400 transition-colors duration-300 group-hover:bg-orange-400 group-hover:text-black group-hover:shadow-[0_0_20px_rgba(251,133,0,0.3)] md:h-12 md:w-12 md:rounded-xl">
                <svg xmlns="http://www.w3.org/2000/svg" class="size-[20px] md:size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={service.icon}></path></svg>
              </div>
            </div>

            <h3 class="mb-2 text-lg font-semibold uppercase tracking-tight transition-colors duration-300 group-hover:text-orange-400 md:mb-4 md:text-2xl">{service.title}</h3>
            <p class="mb-4 line-clamp-2 flex-grow text-xs leading-relaxed text-neutral-400 md:mb-10 md:line-clamp-none md:text-sm">{service.description}</p>
            
            <div class="mt-auto flex flex-col gap-3 md:gap-6">
              <div class="flex flex-nowrap gap-1.5 overflow-x-auto pb-0.5 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden md:flex-wrap md:gap-2 md:overflow-visible">
                {service.features.map(f => (
                  <span class="shrink-0 rounded border border-transparent bg-white/5 px-1.5 py-0.5 text-[7px] font-extrabold uppercase tracking-wider text-neutral-300 transition-all duration-300 group-hover:border-orange-400/30 group-hover:bg-orange-400/20 group-hover:text-white md:px-2 md:py-1 md:text-[8px] md:tracking-widest">{f}</span>
                ))}
              </div>

              <div class="flex translate-y-0 items-center gap-2 text-orange-400 opacity-100 max-md:pt-0 md:translate-y-4 md:opacity-0 md:transition-all md:duration-500 md:group-hover:translate-y-0 md:group-hover:opacity-100">
                <span class="text-[9px] font-bold uppercase tracking-[0.2em] md:text-[10px]">View Details</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="size-3 md:size-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-8 flex w-full max-w-full flex-col items-center px-1 sm:mt-10 md:mt-12">
      <div class="relative max-w-full group rounded-full p-px overflow-hidden bg-gradient-to-r from-white/10 via-orange-400/50 to-white/10">
        <div class="absolute -inset-1 bg-orange-400/20 blur-xl opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
        <a href="/services" class="relative flex max-w-full items-center gap-4 sm:gap-6 rounded-full bg-[#0a0a0a] px-3 py-3 transition-all duration-300 hover:bg-black sm:px-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-orange-400 text-white shadow-[0_0_15px_rgba(251,133,0,0.4)] transition-transform duration-700 group-hover:rotate-[360deg]">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </div>
          <div class="min-w-0 pr-3 text-left sm:pr-6">
            <p class="mb-0.5 text-[10px] font-black uppercase tracking-[.25em] text-orange-400">
              <span class="md:hidden">Something else?</span>
              <span class="hidden md:inline">Have a Different Requirement?</span>
            </p>
            <span class="text-lg font-bold tracking-tight text-white whitespace-normal sm:whitespace-nowrap">Explore All Services</span>
          </div>
        </a>
      </div>
      <p class="mt-6 max-w-lg px-2 text-center text-sm font-medium tracking-wide text-balance text-gray-500">We have more solutions tailored to your business needs</p>
    </div>

  </div>
</section>

<style>
  .service-card {
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    transition: 
      transform 0.25s ease,
      background-color 0.3s ease;
  }

  /* Optimized border transition using a separate layer */
  .service-card::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    border: 1px solid transparent;
    transition: border-color 0.3s ease;
    pointer-events: none;
    z-index: 5;
  }

  .service-card:hover {
    transform: translateY(-4px);
    background-color: rgba(251, 133, 0, 0.04);
  }

  .service-card:hover::after {
    border-color: #fb8500;
  }

  @media (max-width: 767px) {
    .service-card:hover {
      transform: translateY(0);
      background-color: rgba(251, 133, 0, 0.02);
    }
    .service-card:hover::after {
      border-color: rgba(255, 255, 255, 0.12);
    }
  }
</style>
