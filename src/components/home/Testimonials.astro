---
// BrandTestimonialHeader.astro
const averageRating = 4.9;
const totalReviews = "12,480";
---

<section id="testimonials" class="relative bg-white font-inter overflow-x-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-20"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 md:px-12 lg:px-20 xl:px-24 pt-14 pb-14 sm:pt-20 sm:pb-20 md:pb-24">
    
    <div class="max-w-7xl mx-auto mb-6 sm:mb-20 md:mb-24 relative z-10 text-center px-1">
      <div class="mb-8 text-center leading-snug w-full max-w-full">
        <span class="inline-block align-middle h-0.5 w-10 bg-orange-400 mr-2 sm:mr-4" aria-hidden="true"></span><span class="inline-block align-middle max-w-[calc(100%-6rem)] sm:max-w-none font-mono text-sm uppercase tracking-[0.5em] text-orange-400 font-bold">Testimonials</span><span class="inline-block align-middle h-0.5 w-10 bg-orange-400 ml-2 sm:ml-4" aria-hidden="true"></span>
      </div>

      <div class="flex flex-col justify-center items-center">
        <h2 class="text-5xl sm:text-6xl md:text-8xl font-[900] text-black uppercase tracking-tighter leading-[0.9] md:leading-[0.85] text-balance max-w-full">
          <span class="text-orange-400">Trusted </span>By Clients 
        </h2>
        <div class="w-60 max-w-[85vw] h-1 bg-orange-400 mt-4 sm:my-6 rounded-full opacity-50 mx-auto"></div>
        <p class="hidden max-w-2xl mx-auto text-base font-light leading-relaxed text-balance text-gray-500 sm:block sm:text-lg md:text-xl">
          Real feedback from clients who improved their online presence, built trust, and achieved measurable business growth through our work
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 sm:gap-12 lg:gap-20 items-start">
      
      <div class="lg:col-span-5 flex flex-col gap-6 sm:gap-10 text-center lg:text-left items-center lg:items-start">
        <div class="space-y-6 max-w-xl lg:max-w-none mx-auto lg:mx-0">
          <div class="hidden px-3 py-1 bg-black text-[10px] font-bold uppercase tracking-[0.2em] text-white sm:inline-block">
            Client Stories
          </div>
          <h3 class="hidden text-3xl font-[900] uppercase leading-none tracking-tighter text-balance text-black sm:block sm:text-4xl">
            Real Client <br /> Feedback
          </h3>
          <p class="text-gray-600 leading-relaxed text-base sm:text-lg font-light text-balance">
            A collection of real client feedback showcasing how our work improved performance, built trust, and delivered measurable business growth across different projects.
          </p>
        </div>
        
        <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6">
          <div class="flex gap-0.5">
            {[...Array(5)].map(() => (
              <svg class="w-6 h-6 sm:w-8 sm:h-8 text-orange-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-[12px] font-mono text-gray-400 uppercase tracking-[0.1em] font-bold text-center sm:text-left text-balance max-w-[16rem] sm:max-w-none">
            <span class="text-black">{averageRating} Score</span> / {totalReviews} Reviews
          </p>
        </div>
      </div>

      <div class="lg:col-span-7 w-full min-w-0">
        <div class="relative rounded-2xl sm:rounded-[2.0rem] overflow-hidden bg-black aspect-[4/3] sm:aspect-video shadow-[0_32px_64px_-16px_rgba(0,0,0,0.15)] ring-1 ring-black/5 group">
          <video 
            id="testimonial-video"
            class="w-full h-full object-cover opacity-60 transition-opacity duration-500"
            poster="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&q=80&w=1200"
            loop 
            muted 
            playsinline
          >
            <source src="https://www.w3schools.com/html/mov_bbb.mp4" type="video/mp4" />
          </video>
          
          <div id="video-control-btn" class="absolute inset-0 flex items-center justify-center hover:cursor-pointer p-4">
            <button 
              type="button"
              class="group/play hover:cursor-pointer w-16 h-16 sm:w-24 sm:h-24 bg-black rounded-full flex items-center justify-center transition-all duration-500 hover:scale-110 hover:bg-orange-400 shadow-2xl border border-white/10 z-20"
            >
              <svg id="play-icon" class="w-6 h-6 sm:w-10 sm:h-10 text-orange-400 transition-colors duration-500 group-hover/play:text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
              <svg id="pause-icon" class="hidden w-6 h-6 sm:w-10 sm:h-10 text-orange-400 transition-colors duration-500 group-hover/play:text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
              </svg>
            </button>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const video = document.getElementById('testimonial-video') as HTMLVideoElement;
  const btn = document.getElementById('video-control-btn') as HTMLButtonElement;
  const playIcon = document.getElementById('play-icon');
  const pauseIcon = document.getElementById('pause-icon');

  btn?.addEventListener('click', () => {
    if (video.paused) {
      // PLAYING STATE
      video.play();
      video.classList.remove('opacity-60');
      video.classList.add('opacity-100');
      
      // Toggle icons
      playIcon?.classList.add('hidden');
      pauseIcon?.classList.remove('hidden');

      // Enable "hide unless hovering" logic while playing
      btn.classList.add('opacity-0', 'group-hover:opacity-100');
    } else {
      // PAUSED STATE
      video.pause();
      video.classList.remove('opacity-100');
      video.classList.add('opacity-60');
      
      // Toggle icons
      playIcon?.classList.remove('hidden');
      pauseIcon?.classList.add('hidden');

      // Disable "hide unless hovering" logic so it stays visible when stopped
      btn.classList.remove('opacity-0', 'group-hover:opacity-100');
    }
  });
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap');
  .font-inter { font-family: 'Inter', sans-serif; }
  h2, h3 { letter-spacing: -0.05em; }
</style>