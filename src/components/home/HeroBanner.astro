---
import heroVideo from '@/assets/home/video_2.mp4'
---

<section
  id="hero-section"
  class="relative flex w-full flex-col overflow-hidden bg-black
    min-h-[88svh] sm:min-h-dvh sm:min-h-screen
    items-center justify-start pt-34 pb-0
    sm:justify-center sm:pt-24 sm:pb-12 md:pt-28 md:pb-16 lg:pt-32 lg:pb-20"
>
  
  <div class="absolute inset-0 z-0 overflow-hidden">
    <!-- Parallax on wrapper so the video stays full-bleed; overflow clips extra height -->
    <div
      id="parallax-bg"
      class="absolute left-0 right-0 top-[-12%] h-[100%] w-full will-change-transform"
      style="transform: translate3d(0, 0, 0);"
    >
      <video
        autoplay
        muted
        loop
        playsinline
        class="pointer-events-none h-full w-full object-cover object-center opacity-70"
      >
      <source src={heroVideo} type="video/mp4" />
      Your browser does not support the video tag.
    </video>
    </div>
    
    <div class="absolute inset-0 bg-gradient-to-b from-black via-transparent to-black z-10 pointer-events-none"></div>
    <div class="absolute inset-0 bg-black/50 z-[11] pointer-events-none"></div>
  </div>



  <div
    class="relative z-20 mx-auto w-full max-w-5xl px-3 text-center sm:px-5 md:px-6 lg:max-w-6xl lg:px-8 2xl:max-w-7xl"
  >
    <div class="mb-3 text-center leading-snug px-0.5 sm:mb-5 sm:px-1 md:mb-6 hero-item" style="animation-delay:0.05s">
      <span
        class="inline-block align-middle h-[1.5px] w-5 bg-orange-500/50 mr-1.5 sm:h-[1.8px] sm:w-7 sm:mr-3 md:w-8 md:mr-4"
        aria-hidden="true"
      />
      <span
        class="inline-block align-middle max-w-[calc(100%-3.5rem)] text-balance font-mono font-bold uppercase text-orange-400 text-center leading-snug
          text-[10px] tracking-[0.05em]
          sm:max-w-[calc(100%-4.5rem)] sm:text-[11px] sm:tracking-[0.1em]
          md:max-w-none md:text-xs md:tracking-[0.16em]
          lg:text-sm lg:tracking-[0.22em]
          xl:text-[15px] xl:tracking-[0.3em]
          2xl:text-base 2xl:tracking-[0.4em]"
      >
        Build Trust. Generate Leads. Grow Faster.
      </span>
      <span
        class="inline-block align-middle h-[1.5px] w-5 bg-orange-500/50 ml-1.5 sm:h-[1.8px] sm:w-7 sm:ml-3 md:w-8 md:ml-4"
        aria-hidden="true"
      />
    </div>

    <h1
      class="mx-auto mb-3 max-w-full px-0 text-balance uppercase font-semibold tracking-[-0.05em] text-white sm:mb-5 sm:px-0.5 md:mb-6 md:px-1
        text-6xl leading-[0.9] sm:text-6xl md:text-8xl md:leading-[0.95] hero-item"
      style="animation-delay:0.2s"
    >
      Websites That Drive <span class="text-orange-400">Growth</span> & <span class="text-orange-400">Business</span>
    </h1>

    <div class="mx-auto mb-5 max-w-2xl px-0 sm:mb-9 sm:px-0.5 md:mb-11 md:max-w-3xl lg:mb-12 lg:max-w-4xl hero-item" style="animation-delay:0.38s">
      <p
        class="text-balance font-light leading-relaxed tracking-wide text-zinc-400
          text-[15px] sm:text-base md:text-lg lg:text-xl xl:text-2xl xl:leading-relaxed"
      >
        We design and develop conversion-focused websites that help businesses build trust, attract leads, and grow with clarity
      </p>
    </div>

    <div
      class="group relative mx-auto inline-block max-w-full rounded-full bg-white/10 p-px overflow-hidden transition-colors duration-500 hover:bg-orange-500/50 hero-item"
      style="animation-delay:0.52s"
    >
      <a
        href="/contact"
        class="relative flex max-w-full items-center justify-between gap-3 rounded-full bg-[#0a0a0a] py-2.5 pl-2.5 pr-4 transition-all duration-300 hover:bg-black sm:gap-5 sm:py-3 sm:pl-3 sm:pr-8 md:gap-8 md:pl-4 md:pr-10"
      >
        <div
          class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-orange-400 text-black shadow-[0_0_20px_rgba(251,133,0,0.3)] transition-transform duration-500 group-hover:rotate-45 sm:h-12 sm:w-12"
        >
          <svg
            class="h-5 w-5 sm:h-6 sm:w-6"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7 17l10-10M7 7h10v10" />
          </svg>
        </div>

        <div class="flex min-w-0 flex-col text-left">
          <p
            class="font-bold uppercase text-orange-400
              text-[9px] tracking-[0.18em] sm:text-[10px] sm:tracking-[.28em] md:tracking-[.3em]"
          >
            Ready to Grow??
          </p>
          <span
            class="font-bold tracking-tight text-white whitespace-normal sm:whitespace-nowrap
              text-sm sm:text-base md:text-lg lg:text-xl"
          >
            Let’s Get Started
          </span>
        </div>
      </a>
    </div>
  </div>

</section>

<script>
  const parallaxWrap = document.getElementById('parallax-bg');
  window.addEventListener('scroll', () => {
    const scrollValue = window.scrollY;
    if (parallaxWrap && scrollValue < window.innerHeight) {
      parallaxWrap.style.transform = `translate3d(0, ${scrollValue * 0.2}px, 0)`;
    }
  });
</script>

<style>
  /* Hero items are above the fold — use a direct CSS animation, not scroll trigger.
     Starts invisible, plays immediately, no JS dependency. */
  .hero-item {
    opacity: 0;
    animation: hero-rise 0.75s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
      filter: blur(5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-item {
      opacity: 1;
      animation: none;
    }
  }

  ::selection {
    background: #fb923c;
    color: #000;
  }
</style>