---
import heroVideo from '@/assets/home/video_2.mp4'
---

<section id="hero-section" class="relative w-full min-h-screen min-h-dvh bg-black overflow-hidden flex items-center justify-center pt-28 pb-12 sm:pt-32 sm:pb-14 md:pt-40 md:pb-18">
  
  <div class="absolute inset-0 z-0 overflow-hidden">
    <!-- Parallax on wrapper so the video stays full-bleed; overflow clips extra height -->
    <div
      id="parallax-bg"
      class="absolute left-0 right-0 top-[-12%] h-[124%] w-full will-change-transform"
      style="transform: translate3d(0, 0, 0);"
    >
      <video
        autoplay
        muted
        loop
        playsinline
        class="pointer-events-none h-full w-full object-cover object-center opacity-70"
      >
      <source src={heroVideo} type="video/mp4" />
      Your browser does not support the video tag.
    </video>
    </div>
    
    <div class="absolute inset-0 bg-gradient-to-b from-black via-transparent to-black z-10 pointer-events-none"></div>
    <div class="absolute inset-0 bg-black/50 z-[11] pointer-events-none"></div>
  </div>



  <div class="relative z-20 w-full max-w-5xl text-center px-4 sm:px-6 mx-auto animate-fade-in">
    
    <div class="mb-6 text-center leading-snug px-1">
        <span class="inline-block align-middle h-[1.8px] w-8 bg-orange-500/50 mr-2 sm:mr-4" aria-hidden="true"></span><span class="inline-block align-middle max-w-[calc(100%-5.5rem)] sm:max-w-none font-mono text-[14px] uppercase tracking-[0.6em] text-orange-400 font-bold text-center">Build Trust. Generate Leads. Grow Faster.</span><span class="inline-block align-middle h-[1.8px] w-8 bg-orange-500/50 ml-2 sm:ml-4" aria-hidden="true"></span>
    </div>

    <h1 class="text-6xl md:text-[100px] font-black mb-6 leading-[0.9] tracking-tighter text-white text-balance max-w-full px-0 sm:px-1">
      Websites That Drive <span class="text-orange-400">Growth</span> & <span class="text-orange-400">Business</span>
    </h1>

    <div class="max-w-2xl mx-auto mb-8 sm:mb-10 md:mb-12 px-0 sm:px-1">
      <p class="text-zinc-400 text-lg md:text-xl font-light leading-relaxed tracking-wide text-balance">
        We design and develop conversion-focused websites that help businesses build trust, attract leads, and grow with clarity
      </p>
    </div>
    
    <div class="group relative inline-block max-w-full p-[1px] rounded-full overflow-hidden bg-white/10 hover:bg-orange-500/50 transition-colors duration-500">
        <a href="/contact" class="relative flex max-w-full items-center justify-between gap-4 sm:gap-8 pl-3 pr-6 py-3 sm:pl-4 sm:pr-10 bg-[#0a0a0a] rounded-full hover:bg-black transition-all duration-300">
            <div class="w-12 h-12 shrink-0 rounded-full bg-orange-400 flex items-center justify-center text-black shadow-[0_0_20px_rgba(251,133,0,0.3)] group-hover:rotate-45 transition-transform duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 17l10-10M7 7h10v10"/>
                </svg>
            </div>
            
            <div class="flex min-w-0 flex-col text-left">
                <p class="text-[10px] font-bold tracking-[.3em] text-orange-400 uppercase">
                    Ready to Grow??
                </p>
                <span class="text-white font-bold text-lg tracking-tight whitespace-normal sm:whitespace-nowrap">
                    Let’s Get Started
                </span>
            </div>
        </a>
    </div>
  </div>

</section>

<script>
  const parallaxWrap = document.getElementById('parallax-bg');
  window.addEventListener('scroll', () => {
    const scrollValue = window.scrollY;
    if (parallaxWrap && scrollValue < window.innerHeight) {
      parallaxWrap.style.transform = `translate3d(0, ${scrollValue * 0.2}px, 0)`;
    }
  });
</script>

<style>
  .animate-fade-in {
    animation: fade-in 1.2s forwards cubic-bezier(0.16, 1, 0.3, 1);
  }

  .animate-fade-in-delayed {
    opacity: 0;
    animation: fade-in 1.5s forwards 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(30px); filter: blur(10px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  ::selection {
    background: #fb923c;
    color: #000;
  }
</style>