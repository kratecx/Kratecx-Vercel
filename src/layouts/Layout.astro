---
import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '@/components/seo/BaseHead.astro';
import SchemaOrg from '@/components/seo/SchemaOrg.astro';
import { SITE, resolveSeo } from '@/data/seo';
import {
  organizationSchema,
  websiteSchema,
  webPageSchema,
} from '@/data/schema';

interface Props {
  /** Explicit title (optional — falls back to PAGE_SEO[pathname] or brand name). */
  title?: string;
  description?: string;
  image?: string;
  keywords?: string[];
  canonical?: string;
  noIndex?: boolean;
  ogType?: 'website' | 'article';
  preloadImages?: string[];
  /** Extra JSON-LD schemas to inject (Article, Service, FAQ, etc). */
  extraSchemas?: Record<string, any>[];
  /** Article-only */
  publishedTime?: string;
  modifiedTime?: string;
  articleAuthor?: string;
  /** Optional og:image dimensions (pixels); forwarded to BaseHead for custom `image` URLs. */
  ogImageWidth?: number;
  ogImageHeight?: number;
}

const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const seo = resolveSeo(pathname);

const {
  title = seo.title,
  description = seo.description,
  image,
  keywords = seo.keywords,
  canonical,
  noIndex = seo.index === false,
  ogType = 'website',
  preloadImages = [],
  extraSchemas = [],
  publishedTime,
  modifiedTime,
  articleAuthor,
  ogImageWidth,
  ogImageHeight,
} = Astro.props as Props;

const pageUrl = canonical ?? new URL(pathname, SITE.domain).href;

/** Site-wide schemas injected once per page. */
const coreSchemas = [
  organizationSchema(),
  websiteSchema(),
  webPageSchema({ url: pageUrl, title, description }),
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      canonical={pageUrl}
      noIndex={noIndex}
      keywords={keywords}
      preloadImages={preloadImages}
      ogType={ogType}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      articleAuthor={articleAuthor}
      ogImageWidth={ogImageWidth}
      ogImageHeight={ogImageHeight}
    />

    <SchemaOrg schema={coreSchemas} />
    {extraSchemas.length > 0 && <SchemaOrg schema={extraSchemas} />}

  </head>

  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />

    <script is:inline>
      /* ── data-anim entrance system ── */
      (function () {
        var animObs = null;

        function initDataAnim() {
          if (animObs) { try { animObs.disconnect(); } catch (e) {} animObs = null; }

          var reduced =
            typeof window.matchMedia === 'function' &&
            window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          /* Auto-stagger: children of [data-stagger] inherit data-anim + CSS delay */
          document.querySelectorAll('[data-stagger]').forEach(function (parent) {
            var step = parseInt(parent.getAttribute('data-stagger')) || 80;
            Array.from(parent.children).forEach(function (child, i) {
              if (!child.getAttribute('data-anim')) {
                child.setAttribute('data-anim', 'up');
              }
              child.style.setProperty('--_d', (i * step) + 'ms');
            });
          });

          var targets = document.querySelectorAll('[data-anim]');
          if (!targets.length) return;

          if (reduced) {
            targets.forEach(function (el) { el.classList.add('in-view'); });
            return;
          }

          animObs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('in-view');
              animObs.unobserve(entry.target);
            });
          }, { threshold: 0.01, rootMargin: '0px 0px 4% 0px' });

          targets.forEach(function (el) { animObs.observe(el); });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initDataAnim);
        } else {
          initDataAnim();
        }
        document.addEventListener('astro:page-load', initDataAnim);
      })();

      /* ── Legacy data-reveal system ── */
      (function () {
        var obs = null;
        var debounceTimer = null;

        function collectTargets() {
          var seen = new Set();
          var out = [];
          document.querySelectorAll("main [data-reveal]:not([data-reveal-off])").forEach(function (el) {
            if (seen.has(el)) return;
            seen.add(el);
            out.push(el);
          });
          document.querySelectorAll("footer [data-reveal]:not([data-reveal-off])").forEach(function (el) {
            if (seen.has(el)) return;
            seen.add(el);
            out.push(el);
          });
          return out;
        }

        function revealNow(target) {
          target.classList.add("reveal-visible");
          if (obs) obs.unobserve(target);
        }

        function flushInitialIntersecting(observer) {
          if (!observer || typeof observer.takeRecords !== "function") return;
          observer.takeRecords().forEach(function (entry) {
            if (entry.isIntersecting) revealNow(entry.target);
          });
        }

        function initViewportReveal() {
          if (obs) { try { obs.disconnect(); } catch (_) {} obs = null; }

          var reduce =
            typeof window.matchMedia === "function" &&
            window.matchMedia("(prefers-reduced-motion: reduce)").matches;

          var targets = collectTargets();
          if (!targets.length) return;

          targets.forEach(function (el) {
            el.classList.remove("reveal-pending", "reveal-visible");
            el.classList.add("reveal-pending");
            if (reduce) {
              el.classList.add("reveal-visible");
            }
          });

          if (reduce) return;

          obs = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                revealNow(entry.target);
              });
            },
            { threshold: 0.01, rootMargin: "0px 0px 8% 0px" }
          );

          targets.forEach(function (el) { obs.observe(el); });
          flushInitialIntersecting(obs);
        }

        function queueInit() {
          clearTimeout(debounceTimer);
          debounceTimer = setTimeout(function () {
            debounceTimer = null;
            initViewportReveal();
          }, 0);
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", queueInit);
        } else {
          queueInit();
        }
        document.addEventListener("astro:page-load", queueInit);
      })();
    </script>
  </body>
</html>
